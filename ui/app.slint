// NodeChat — Root Application Window
//
// ARCHITECTURE:
//   The main app is always the base layer, starting at current-screen = 0.
//   Two conditional overlays sit on top:
//     1. Onboarding overlay  — rendered when has-identity = false (new user)
//     2. Lock overlay        — rendered when is-locked = true (returning user with password)
//   Once setup is complete, has-identity = true and the overlay disappears.
//
// Main Navigation Screen IDs (current-screen):
//   0 = ChatList     (home / default)
//   1 = ChatView     (1:1 direct chat)
//   2 = GroupChat    (reuses the same chat surface with group mode)
//   3 = AddContact
//   5 = Settings
//   6 = Contacts
//   7 = SelectMembers
//   8 = CreateGroup
//   9 = ContactDetails
//   10 = ConversationActions
//   11 = EditProfileName

import { ScrollView }      from "std-widgets.slint";
import { AppTheme }           from "./theme.slint";
import { SetupNameScreen }    from "./screens/setup_name.slint";
import { IdentityCardScreen } from "./screens/identity_card.slint";
import { WelcomeScreen }      from "./screens/welcome.slint";
import { ChatListScreen, ChatPreview }     from "./screens/chat_list.slint";
import { ChatViewScreen, MessageData }     from "./screens/chat_view.slint";
import { AddContactScreen }   from "./screens/add_contact.slint";
import { SettingsScreen }     from "./screens/settings.slint";
import { ContactsScreen, ContactData }     from "./screens/contacts.slint";
import { ContactDetailsScreen } from "./screens/contact_details.slint";
import { ConversationActionsScreen } from "./screens/conversation_actions.slint";
import { SelectMembersScreen, SelectionData } from "./screens/select_members.slint";
import { CreateGroupScreen }  from "./screens/create_group.slint";
import { EditNameScreen }    from "./screens/edit_name.slint";
import { DiagnosticsScreen, LogEntry } from "./screens/diagnostics.slint";
import { ConfirmModal } from "./components/confirm_modal.slint";

export struct ConversationContext {
    kind: string,
    id: string,
    title: string,
    initials: string,
    ticket: string,
    is-online: bool,
    is-verified: bool,
    connection-stage: string,
    member-count: string,
    return-screen: int,
}

export component AppWindow inherits Window {
    title: "NodeChat — Secure Decentralized Chat";
    min-width: 360px;
    min-height: 560px;
    preferred-width: 1100px;
    preferred-height: 820px;
    background: AppTheme.surface-primary;

    // ── Responsive breakpoint ──────────────────────────────────────────────
    property <bool> is-desktop: root.width >= 750px;

    // ── Safe area metrics ─────────────────────────────────────────────────
    property <length> safe-area-top:    is-desktop ? 0px : root.safe-area-insets.top;
    property <length> safe-area-bottom: is-desktop ? 0px : root.safe-area-insets.bottom;
    property <length> kb-height:        root.virtual-keyboard-size.height;

    // ── Identity & auth state (Rust sets these at startup) ────────────────
    /// false = no identity on device → onboarding overlay is shown.
    /// Rust sets this to true before app.run() if identity exists in DB.
    in-out property <bool> has-identity: false;

    /// true = identity exists but app is locked with a password.
    /// Rust sets this to true at startup when a password is configured.
    in-out property <bool> is-locked: false;

    // ── Setup overlay internal state ──────────────────────────────────────
    /// 0 = welcome, 1 = name input, 2 = generating (loading), 3 = identity card
    in-out property <int> setup-step: 0;

    // ── Main app navigation ───────────────────────────────────────────────
    in-out property <int> current-screen: 0;
    /// Internal tracking for navigation history.
    in-out property <int> navigation-return-screen: 0;

    // ── Shared app state ──────────────────────────────────────────────────
    in property <string>  my-display-name: "";
    in property <string>  my-initials: "";
    in property <string>  my-node-id: "";
    in property <string>  my-endpoint-ticket: "";
    in property <int>     direct-peers: 0;
    in property <int>     relay-peers: 0;
    in property <bool>    is-offline: false;
    in property <[LogEntry]> debug-logs: [];
    in property <string>  relay-url: "";
    in-out property <string> runtime-error-log: "";
    in-out property <string> lock-pin: "";
    in-out property <string> lock-error: "";
    in-out property <string> change-pw-error: "";

    // --- Confirmation Modal State ---
    in-out property <string> confirm-modal-title: "";
    in-out property <string> confirm-modal-subtitle: "";
    in-out property <string> confirm-modal-action: "";
    in-out property <string> confirm-modal-target: "";
    in-out property <string> confirm-modal-pin: "";
    in-out property <string> confirm-modal-error: "";
    in-out property <bool>   is-confirm-modal-group: false;
    in-out property <bool>   show-confirm-modal: false;

    in property <[ChatPreview]> chats: [];
    in property <[ContactData]> contact-directory: [];
    in property <[SelectionData]> group-member-candidates: [];
    in property <int> selected-group-member-count: 0;

    // ── Active chat context ───────────────────────────────────────────────
    in-out property <ConversationContext> active-conversation: {
        kind: "direct",
        id: "",
        title: "",
        initials: "",
        ticket: "",
        is-online: false,
        is-verified: false,
        connection-stage: "",
        member-count: "0",
        return-screen: 0,
    };
    in property <[MessageData]> active-conversation-messages: [];

    /// Fired when the user confirms their display name during setup.
    /// Rust: kicks off identity generation, then sets setup-step=2, my-display-name, my-node-id.
    callback create-identity(string, string);
    /// Fired when user changes their name in settings.
    callback confirm-name-change(string);

    /// Fired when the user taps "Launch Chats" on the identity card.
    /// Rust: persists the has-identity flag, sets has-identity=true on the UI.
    callback setup-complete();

    callback send-message(string);
    callback send-group-message(string);
    callback add-contact(string);
    callback accept-group-invite(string, string, string);
    callback mark-verified();
    callback copy-node-id();
    callback copy-runtime-error(string);
    callback delete-conversation(string, bool, string);
    callback clear-conversation(string, bool, string);
    callback remove-contact();
    callback retry-queued();
    callback launch-group(string);
    callback toggle-group-member(string);
    callback unlock(string);        // placeholder unlock action for now
    callback load-conversation(string, bool);
    callback clear-messages(string);
    callback delete-identity(string);
    callback clear-debug-logs();
    callback copy-debug-logs();
    callback change-password(string, string);
    callback copy-text(string);

    // ── Android back button ───────────────────────────────────────────────
    forward-focus: back-handler;
    back-handler := FocusScope {
        key-pressed(event) => {
                if event.text == "\u{001b}" || event.text == Key.Escape {
                if current-screen == 9 { current-screen = active-conversation.return-screen; return accept; }
                if current-screen == 10 { current-screen = active-conversation.return-screen; return accept; }
                if current-screen == 1 { current-screen = 0; return accept; }
                if current-screen == 2 { current-screen = 0; return accept; }
                if current-screen == 3 { current-screen = navigation-return-screen; return accept; }
                if current-screen == 5 { current-screen = 0; return accept; }
                if current-screen == 6 { current-screen = 0; return accept; }
                if current-screen == 7 { current-screen = 6; return accept; }
                if current-screen == 8 { current-screen = 7; return accept; }
                if current-screen == 11 { current-screen = 5; return accept; }
            }
            return reject;
        }
    }

    // ════════════════════════════════════════════════════════════════════
    // LAYER 1 — MAIN APP (always present, base layer)
    // ════════════════════════════════════════════════════════════════════
    Rectangle {
        clip: true;
        width: root.width;
        height: root.height;

        // Desktop: two-panel layout. Mobile: full-screen single panel.
        HorizontalLayout {
            spacing: 0;
            width: parent.width;
            height: parent.height;

            // ── LEFT PANEL (Sidebar on desktop / Home on mobile) ──────────
            if is-desktop || current-screen == 0 || current-screen == 6: Rectangle {
                width: is-desktop ? 340px : parent.width; 
                background: AppTheme.surface-primary;

                if is-desktop || current-screen == 0: ChatListScreen {
                    chats:            root.chats;
                    is-desktop:        root.is-desktop;
                    safe-area-top:     root.safe-area-top;
                    safe-area-bottom:  root.safe-area-bottom;
                    direct-peers:      root.direct-peers;
                    relay-peers:       root.relay-peers;
                    is-offline:        root.is-offline;
                    open-chat(id, name, initials, is-group, is-online, is-relay, is-verified) => {
                        root.load-conversation(id, is-group);
                        active-conversation = {
                            kind: is-group ? "group" : "direct",
                            id: id, title: name, initials: initials,
                            ticket: "", is-online: is-online, is-verified: is-verified,
                            connection-stage: "", member-count: "", return-screen: 0,
                        };
                        current-screen = is-group ? 2 : 1;
                    }
                    add-contact =>    { navigation-return-screen = 0; current-screen = 3; }
                    open-contacts =>  { current-screen = 6; }
                    open-settings =>  { current-screen = 5; }
                }

                if !is-desktop && current-screen == 6: ContactsScreen {
                    is-desktop:    false;
                    safe-area-top: root.safe-area-top;
                    safe-area-bottom: root.safe-area-bottom;
                    contacts:       root.contact-directory;
                    go-back =>     { current-screen = 0; }
                    open-contact(id, name, initials, is-group, is-online, is-relay, is-verified) => {
                        if is-group {
                            root.active-conversation.kind = "group";
                            root.active-conversation.id = id;
                            root.active-conversation.title = name;
                            root.active-conversation.initials = "👥";
                            root.active-conversation.ticket = "";
                            root.active-conversation.is-online = true;
                            root.active-conversation.is-verified = true;
                            root.active-conversation.connection-stage = "";
                            root.active-conversation.member-count = "0";
                            root.active-conversation.return-screen = 6;
                        } else {
                            root.active-conversation.kind = "direct";
                            root.active-conversation.id = id;
                            root.active-conversation.title = name;
                            root.active-conversation.initials = initials;
                            root.active-conversation.ticket = "";
                            root.active-conversation.is-online = is_online;
                            root.active-conversation.is-verified = is_verified;
                            root.active-conversation.connection-stage = "";
                            root.active-conversation.member-count = "0";
                            root.active-conversation.return-screen = 6;
                        }
                        current-screen = 9;
                        root.load-conversation(id, is-group);
                    }
                    add-contact => { navigation-return-screen = 6; current-screen = 3; }
                    new-group =>   { current-screen = 7; }
                }

                if is-desktop: Rectangle {
                    x: parent.width - 1px; y: 0;
                    width: 1px; height: parent.height;
                    background: AppTheme.divider;
                }
            }

            // ── RIGHT PANEL (Active screen on desktop / full screen on mobile) ──
            if is-desktop || (current-screen >= 1 && current-screen != 6): Rectangle {
                horizontal-stretch: 1;
                background: AppTheme.surface-primary;

                // Desktop empty state
                if is-desktop && (current-screen == 0): VerticalLayout {
                    alignment: center;
                    spacing: AppTheme.sp-md;
                    Text { text: "💬"; font-size: 64px; horizontal-alignment: center; }
                    Text {
                        text: "Select a chat to start messaging.";
                        font-size: 16px; color: AppTheme.text-secondary;
                        horizontal-alignment: center;
                    }
                }

                // Desktop contacts in right panel
                if is-desktop && current-screen == 6: ContactsScreen {
                    is-desktop:    true;
                    safe-area-top: 0px;
                    safe-area-bottom: 0px;
                    contacts:       root.contact-directory;
                    go-back =>     { current-screen = 0; }
                    open-contact(id, name, initials, is-group, is-online, is-relay, is-verified) => {
                        if is-group {
                            root.active-conversation.kind = "group";
                            root.active-conversation.id = id;
                            root.active-conversation.title = name;
                            root.active-conversation.initials = "👥";
                            root.active-conversation.ticket = "";
                            root.active-conversation.is-online = true;
                            root.active-conversation.is-verified = true;
                            root.active-conversation.connection-stage = "";
                            root.active-conversation.member-count = "0";
                            root.active-conversation.return-screen = 6;
                        } else {
                            root.active-conversation.kind = "direct";
                            root.active-conversation.id = id;
                            root.active-conversation.title = name;
                            root.active-conversation.initials = initials;
                            root.active-conversation.ticket = "";
                            root.active-conversation.is-online = is-online;
                            root.active-conversation.is-verified = is-verified;
                            root.active-conversation.connection-stage = is-relay ? "relay" : "direct";
                            root.active-conversation.member-count = "0";
                            root.active-conversation.return-screen = 6;
                        }
                        current-screen = 9;
                        root.load-conversation(id, is-group);
                    }
                    add-contact => { navigation-return-screen = 6; current-screen = 3; }
                    new-group =>   { current-screen = 7; }
                }

                // Screen 1 — 1:1 Chat View
                if current-screen == 1: ChatViewScreen {
                    is-desktop:               root.is-desktop;
                    peer-name:                root.active-conversation.title;
                    peer-initials:            root.active-conversation.initials;
                    peer-node-id:             root.active-conversation.id;
                    connection-mode:          root.active-conversation.kind;
                    is-verified:              root.active-conversation.is-verified;
                    is-online:                root.active-conversation.is-online;
                    connection-stage:         root.active-conversation.connection-stage;
                    messages:                 root.active-conversation-messages;
                    safe-area-top:            is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom:         root.safe-area-bottom;
                    virtual-keyboard-height:  root.kb-height;
                    go-back =>                { current-screen = 0; }
                    send-message(msg) =>      { root.send-message(msg); }
                    open-contact-info =>      {
                        root.active-conversation.return-screen = 1;
                        current-screen = 9;
                    }
                    retry-queued =>           { root.retry-queued(); }
                    request-delete-conversation =>    {
                        root.confirm-modal-title = "Delete Conversation";
                        root.confirm-modal-subtitle = "Everything in this thread will be permanently deleted.";
                        root.confirm-modal-action = "delete-conversation";
                        root.confirm-modal-target = root.active-conversation.id;
                        root.is-confirm-modal-group = false;
                        root.show-confirm-modal = true;
                    }
                }

                // Screen 2 — Group Chat View
                if current-screen == 2: ChatViewScreen {
                    is-desktop:              root.is-desktop;
                    peer-name:               root.active-conversation.title;
                    peer-initials:           root.active-conversation.initials;
                    peer-node-id:            root.active-conversation.id;
                    connection-mode:         root.active-conversation.kind;
                    is-verified:             root.active-conversation.is-verified;
                    is-online:               root.active-conversation.is-online;
                    messages:                root.active-conversation-messages;
                    safe-area-top:           is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom:        root.safe-area-bottom;
                    virtual-keyboard-height: root.kb-height;
                    connection-stage:        root.active-conversation.connection-stage;
                    go-back =>               { current-screen = 0; }
                    send-message(msg) =>     { root.send-group-message(msg); }
                    open-contact-info =>     {
                        active-conversation.return-screen = 2;
                        current-screen = 10;
                    }
                    request-delete-conversation =>   {
                        root.confirm-modal-title = "Delete Group Thread";
                        root.confirm-modal-subtitle = "This will remove the group from your list. Other members will remain.";
                        root.confirm-modal-action = "delete-conversation";
                        root.confirm-modal-target = root.active-conversation.id;
                        root.is-confirm-modal-group = true;
                        root.show-confirm-modal = true;
                    }
                    retry-queued =>          { root.retry-queued(); }
                }

                // Screen 3 — Add Contact
                if current-screen == 3: AddContactScreen {
                    is-desktop:    root.is-desktop;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom: root.safe-area-bottom;
                    go-back =>     { current-screen = navigation-return-screen; }
                    add-contact(id) => { root.add-contact(id); }
                }

                // Screen 9 — Contact Details
                if current-screen == 9: ContactDetailsScreen {
                    is-desktop:    root.is-desktop;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom: root.safe-area-bottom;
                    peer-name:     root.active-conversation.title;
                    peer-initials: root.active-conversation.initials;
                    peer-node-id:  root.active-conversation.id;
                    endpoint-ticket: root.active-conversation.ticket;
                    connection-mode: root.active-conversation.kind;
                    connection-stage: root.active-conversation.connection-stage;
                    is-online:     root.active-conversation.is-online;
                    is-verified:   root.active-conversation.is-verified;
                    go-back =>     { current-screen = root.active-conversation.return-screen; }
                    chat-now =>    {
                        root.load-conversation(root.active-conversation.id, root.active-conversation.kind == "group");
                        current-screen = root.active-conversation.kind == "group" ? 2 : 1;
                    }
                    request-verification => { current-screen = 13; }
                    request-clear-history =>  {
                        root.confirm-modal-title = "Clear Chat History";
                        root.confirm-modal-subtitle = "All messages with " + root.active-conversation.title + " will be wiped.";
                        root.confirm-modal-action = "clear-conversation";
                        root.confirm-modal-target = root.active-conversation.id;
                        root.is-confirm-modal-group = false;
                        root.show-confirm-modal = true;
                    }
                    request-delete-conversation => {
                        root.confirm-modal-title = "Remove Contact";
                        root.confirm-modal-subtitle = "This will remove them from your list and delete the chat logs.";
                        root.confirm-modal-action = "delete-conversation";
                        root.confirm-modal-target = root.active-conversation.id;
                        root.is-confirm-modal-group = false;
                        root.show-confirm-modal = true;
                    }
                    copy-text(text) => { root.copy-text(text); }
                }

                // Screen 10 — Conversation Actions
                if current-screen == 10: ConversationActionsScreen {
                    is-desktop:    root.is-desktop;
                    is-group:      root.active-conversation.kind == "group";
                    title:         root.active-conversation.title;
                    subtitle:      root.active-conversation.kind == "group"
                        ? (root.active-conversation.member-count == "" ? "Group thread" : root.active-conversation.member-count + " members connected")
                        : root.active-conversation.connection-stage;
                    primary-id:    root.active-conversation.id;
                    secondary-id:  root.active-conversation.ticket;
                    initials:      root.active-conversation.initials;
                    connection-note: root.active-conversation.kind == "group"
                        ? "Actions for this shared group thread."
                        : (root.active-conversation.is-verified ? "Verified peer" : "Verification pending");
                    is-online:     root.active-conversation.kind == "group" ? true : root.active-conversation.is-online;
                    is-verified:   root.active-conversation.kind == "group" ? true : root.active-conversation.is-verified;
                    member-count:  root.active-conversation.member-count;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    go-back =>     { current-screen = root.active-conversation.return-screen; }
                    open-chat =>   {
                        root.load-conversation(root.active-conversation.id, root.active-conversation.kind == "group");
                        current-screen = root.active-conversation.kind == "group" ? 2 : 1;
                    }
                    retry-queued => { root.retry-queued(); }
                    request-clear-history => {
                        root.confirm-modal-title = "Clear Local History";
                        root.confirm-modal-subtitle = "Wipe all messages in this " + (root.active-conversation.kind == "group" ? "group" : "chat") + ".";
                        root.confirm-modal-action = "clear-conversation";
                        root.confirm-modal-target = root.active-conversation.id;
                        root.is-confirm-modal-group = root.active-conversation.kind == "group";
                        root.show-confirm-modal = true;
                    }
                    request-delete-conversation => {
                        root.confirm-modal-title = root.active-conversation.kind == "group" ? "Leave Group" : "Remove Peer";
                        root.confirm-modal-subtitle = "Permanently remove this conversation thread.";
                        root.confirm-modal-action = "delete-conversation";
                        root.confirm-modal-target = root.active-conversation.id;
                        root.is-confirm-modal-group = root.active-conversation.kind == "group";
                        root.show-confirm-modal = true;
                    }
                }

                // Screen 5 — Settings
                if current-screen == 5: SettingsScreen {
                    is-desktop:    root.is-desktop;
                    display-name:  root.my-display-name;
                    node-id:       root.my-node-id;
                    endpoint-ticket: root.my-endpoint-ticket;
                    direct-peers:  root.direct-peers;
                    relay-peers:   root.relay-peers;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom: root.safe-area-bottom;
                    go-back =>     { current-screen = 0; }
                    copy-node-id => { root.copy-node-id(); }
                    open-debug-console => { current-screen = 14; }
                    edit-display-name => { current-screen = 11; }
                    request-clear-history => { 
                        root.confirm-modal-title = "Clear All Messages";
                        root.confirm-modal-subtitle = "This will permanently delete all chat history. Your identity and contacts will remain.";
                        root.confirm-modal-action = "clear-messages";
                        root.show-confirm-modal = true;
                    }
                    request-reset-identity => { 
                        root.confirm-modal-title = "Delete Vault Identity";
                        root.confirm-modal-subtitle = "CRITICAL: This will destroy your private keys and all contacts. NO RECOVERY POSSIBLE.";
                        root.confirm-modal-action = "delete-identity";
                        root.show-confirm-modal = true;
                    }
                }

                // Screen 7 — Select Members (for new group)
                if current-screen == 7: SelectMembersScreen {
                    is-desktop:    root.is-desktop;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom: root.safe-area-bottom;
                    contacts:      root.group-member-candidates;
                    selected-count: root.selected-group-member-count;
                    go-back =>     { current-screen = 6; }
                    toggle-selection(id) => { root.toggle-group-member(id); }
                    next-step =>   { current-screen = 8; }
                }

                // Screen 8 — Create Group
                if current-screen == 8: CreateGroupScreen {
                    is-desktop:    root.is-desktop;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom: root.safe-area-bottom;
                    member-count:  root.selected-group-member-count;
                    go-back =>     { current-screen = 7; }
                    launch-group(name) => {
                        root.launch-group(name);
                        current-screen = 0;
                    }
                }

                // Screen 11 — Edit Profile Name
                if current-screen == 11: EditNameScreen {
                    is-desktop:    root.is-desktop;
                    display-name:  root.my-display-name;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom: root.safe-area-bottom;
                    go-back =>     { current-screen = 5; }
                    confirm-name(name) => {
                        root.confirm-name-change(name);
                        current-screen = 5; // Return to settings
                    }
                }

                // Screen 14 — Debug Console
                if current-screen == 14: DiagnosticsScreen {
                    is-desktop:    root.is-desktop;
                    node-id:       root.my-node-id;
                    relay-url:     root.relay-url;
                    direct-peers:  root.direct-peers;
                    relay-peers:   root.relay-peers;
                    logs:          root.debug-logs;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom: root.safe-area-bottom;
                    go-back =>     { current-screen = 5; }
                    clear-logs =>  { root.clear-debug-logs(); }
                }
            }
        }
    }

    // ════════════════════════════════════════════════════════════════════
    // LAYER 2 — ONBOARDING OVERLAY (shown only when !has-identity)
    // Covers the entire window. Dismissed automatically when Rust sets
    // has-identity = true after identity is generated and persisted.
    // ════════════════════════════════════════════════════════════════════
    if !has-identity: Rectangle {
        width: parent.width; height: parent.height;
        background: AppTheme.surface-primary;

        // Step 0 — Welcome
        if setup-step == 0: WelcomeScreen {
            is-locked: false;
            is-desktop: root.is-desktop;
            safe-area-bottom: root.safe-area-bottom;
            get-started => {
                root.setup-step = 1;
            }
        }

        // Step 1 or 2 — Name input (setup-step == 2 shows loading state)
        if setup-step == 1 || setup-step == 2: SetupNameScreen {
            generating:    root.setup-step == 2;
            is-desktop:    root.is-desktop;
            safe-area-top: root.safe-area-top;
            safe-area-bottom: root.safe-area-bottom;
            go-back => {
                root.setup-step = 0;
            }

            confirm-name(name, pin) => {
                // Show loading state immediately; Rust generates the identity.
                root.setup-step = 2;
                root.create-identity(name, pin);
                // Rust callback: sets my-display-name, my-node-id, then setup-step = 3.
            }
        }

        // Step 3 — Identity card (shown after Rust confirms identity generated)
        if setup-step == 3: IdentityCardScreen {
            display-name: root.my-display-name;
            node-id:      root.my-node-id;
            endpoint-ticket: root.my-endpoint-ticket;
            is-desktop:   root.is-desktop;
            safe-area-top: root.safe-area-top;
            safe-area-bottom: root.safe-area-bottom;
            copy-ticket(ticket) => { root.copy-node-id(); }
            go-to-chats => {
                root.setup-complete();
                // Rust sets has-identity = true, which dismisses this overlay.
            }
        }
    }

    // ════════════════════════════════════════════════════════════════════
    // LAYER 3 — LOCK OVERLAY (shown when is-locked = true)
    // Covers the entire window. Dismissed when Rust clears the lock flag.
    // ════════════════════════════════════════════════════════════════════
    if is-locked: Rectangle {
        width: parent.width; height: parent.height;
        background: AppTheme.surface-primary;

        WelcomeScreen {
            is-locked: true;
            is-desktop: root.is-desktop;
            safe-area-bottom: root.safe-area-bottom;
            get-started => {} // unused in locked mode
            unlock(pin) => {
                root.is-locked = false;
                root.current-screen = 0;
                root.unlock(pin);
            }
        }
    }

    // ════════════════════════════════════════════════════════════════════
    // LAYER 4 — RUNTIME ERROR PANEL (non-modal, copyable, responsive)
    // ════════════════════════════════════════════════════════════════════
    if runtime-error-log != "": Rectangle {
        property <length> panel-width: is-desktop ? 420px : root.width - 24px;
        property <length> panel-height: is-desktop ? 220px : 300px;
        x: is-desktop ? parent.width - panel-width - 16px : 12px;
        y: is-desktop ? parent.height - panel-height - safe-area-bottom - 12px : safe-area-top + 12px;
        width: panel-width;
        height: panel-height;
        background: is-desktop ? #151922 : #2D1010;
        border-radius: 18px;
        border-width: 1px;
        border-color: is-desktop ? #39424f : AppTheme.accent-danger;
        clip: true;

        HorizontalLayout {
            padding: 14px;
            spacing: 12px;
            alignment: start;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 8px;

                HorizontalLayout {
                    alignment: space-between;
                    Text {
                        text: "Runtime Errors";
                        font-size: 15px;
                        font-weight: 700;
                        color: #FFFFFF;
                    }
                    Text {
                        text: "Copyable";
                        font-size: 11px;
                        color: is-desktop ? #9AA6B2 : #FFB4B0;
                    }
                }

                ScrollView {
                    vertical-stretch: 1;
                    mouse-drag-pan-enabled: true;

                    Text {
                        text: runtime-error-log;
                        font-size: 13px;
                        color: #FCEEEE;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                }
            }

            VerticalLayout {
                alignment: start;
                spacing: 10px;

                TouchArea {
                    width: 84px;
                    height: 36px;
                    clicked => {
                        runtime-error-log = "";
                    }
                    Rectangle {
                        width: 100%; height: 100%;
                        border-radius: 10px;
                        background: AppTheme.surface-tertiary;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        Text {
                            text: "Close";
                            font-size: 13px;
                            font-weight: 700;
                            color: #FFFFFF;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                copy-error-input := TextInput { width: 0px; height: 0px; opacity: 0; }

                TouchArea {
                    width: 84px;
                    height: 36px;
                    clicked => {
                        copy-error-input.text = runtime-error-log;
                        copy-error-input.select-all();
                        copy-error-input.copy();
                        copy-error-input.clear-selection();
                        root.copy-runtime-error(runtime-error-log);
                    }
                    Rectangle {
                        width: 100%; height: 100%;
                        border-radius: 10px;
                        background: AppTheme.accent-danger;
                        Text {
                            text: "Copy";
                            font-size: 13px;
                            font-weight: 700;
                            color: #FFFFFF;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ════════════════════════════════════════════════════════════════════
    // LAYER 5 — CONFIRMATION MODAL
    // ════════════════════════════════════════════════════════════════════
    if show-confirm-modal: ConfirmModal {
        title: root.confirm-modal-title;
        subtitle: root.confirm-modal-subtitle;
        confirm-text: root.confirm-modal-action == "delete-identity" ? "Destroy Everything" : root.confirm-modal-action;
        action-slug: root.confirm-modal-action;
        error-msg: root.confirm-modal-error;
        pin: root.confirm-modal-pin;
        
        cancel => {
            root.show-confirm-modal = false;
            root.confirm-modal-error = "";
            root.confirm-modal-pin = "";
        }
        
        confirm(pin) => {
            root.confirm-modal-pin = pin;
            if (root.confirm-modal-action == "clear-conversation") {
                root.clear-conversation(root.confirm-modal-target, root.is-confirm-modal-group, pin);
            } else if (root.confirm-modal-action == "delete-conversation") {
                root.delete-conversation(root.confirm-modal-target, root.is-confirm-modal-group, pin);
            } else if (root.confirm-modal-action == "clear-messages") {
                root.clear-messages(pin);
            } else if (root.confirm-modal-action == "delete-identity") {
                root.delete-identity(pin);
            }
        }
    }
}

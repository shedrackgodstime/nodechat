// NodeChat — Root Application Window
//
// ARCHITECTURE:
//   The main app is always the base layer, starting at current-screen = 0.
//   Two conditional overlays sit on top:
//     1. Onboarding overlay  — rendered when has-identity = false (new user)
//     2. Lock overlay        — rendered when is-locked = true (returning user with password)
//   Once setup is complete, has-identity = true and the overlay disappears.
//
// Main Navigation Screen IDs (current-screen):
//   0 = ChatList     (home / default)
//   1 = ChatView     (1:1 direct chat)
//   2 = GroupView    (group chat)
//   3 = AddContact
//   4 = VerifyKey
//   5 = Settings
//   6 = Contacts
//   7 = SelectMembers
//   8 = CreateGroup

import { AppTheme }           from "./theme.slint";
import { SetupNameScreen }    from "./screens/setup_name.slint";
import { IdentityCardScreen } from "./screens/identity_card.slint";
import { WelcomeScreen }      from "./screens/welcome.slint";
import { ChatListScreen }     from "./screens/chat_list.slint";
import { ChatViewScreen }     from "./screens/chat_view.slint";
import { GroupViewScreen }    from "./screens/group_view.slint";
import { AddContactScreen }   from "./screens/add_contact.slint";
import { VerifyKeyScreen }    from "./screens/verify_key.slint";
import { SettingsScreen }     from "./screens/settings.slint";
import { ContactsScreen }     from "./screens/contacts.slint";
import { SelectMembersScreen } from "./screens/select_members.slint";
import { CreateGroupScreen }  from "./screens/create_group.slint";

export component AppWindow inherits Window {
    title: "NodeChat — Secure Decentralized Chat";
    min-width: 360px;
    min-height: 560px;
    preferred-width: 1100px;
    preferred-height: 820px;
    background: AppTheme.surface-primary;

    // ── Responsive breakpoint ──────────────────────────────────────────────
    property <bool> is-desktop: root.width >= 750px;

    // ── Safe area metrics ─────────────────────────────────────────────────
    property <length> safe-area-top:    is-desktop ? 0px : root.safe-area-insets.top;
    property <length> safe-area-bottom: is-desktop ? 0px : root.safe-area-insets.bottom;
    property <length> kb-height:        root.virtual-keyboard-size.height;

    // ── Identity & auth state (Rust sets these at startup) ────────────────
    /// false = no identity on device → onboarding overlay is shown.
    /// Rust sets this to true before app.run() if identity exists in DB.
    in-out property <bool> has-identity: false;

    /// true = identity exists but app is locked with a password.
    /// Rust sets this to true at startup when a password is configured.
    in-out property <bool> is-locked: false;

    // ── Setup overlay internal state ──────────────────────────────────────
    /// 0 = name input, 1 = generating (loading), 2 = identity card
    in-out property <int> setup-step: 0;

    // ── Main app navigation ───────────────────────────────────────────────
    in-out property <int> current-screen: 0;

    // ── Shared app state ──────────────────────────────────────────────────
    in property <string>  my-display-name: "";
    in property <string>  my-node-id: "";
    in property <int>     direct-peers: 0;
    in property <int>     relay-peers: 0;
    in property <bool>    is-offline: false;

    // ── Active chat context ───────────────────────────────────────────────
    in-out property <string> active-peer-name: "";
    in-out property <string> active-peer-initials: "";
    in-out property <string> active-peer-node-id: "";
    in-out property <string> active-connection-mode: "direct";
    in-out property <bool>   active-peer-verified: false;
    in-out property <bool>   active-peer-online: false;
    in-out property <string> active-group-name: "";
    in-out property <string> active-group-members: "0";

    /// Fired when the user confirms their display name during setup.
    /// Rust: kicks off identity generation, then sets setup-step=2, my-display-name, my-node-id.
    callback confirm-name(string);

    /// Fired when the user taps "Launch Chats" on the identity card.
    /// Rust: persists the has-identity flag, sets has-identity=true on the UI.
    callback setup-complete();

    callback send-message(string);
    callback send-group-message(string);
    callback add-contact(string, string);
    callback mark-verified();
    callback copy-node-id();
    callback launch-group(string);
    callback unlock(string);  // password string → Rust verifies and sets is-locked=false
    callback clear-messages();
    callback delete-identity();

    // ── Android back button ───────────────────────────────────────────────
    forward-focus: back-handler;
    back-handler := FocusScope {
        key-pressed(event) => {
            if event.text == "\u{001b}" || event.text == Key.Escape {
                if current-screen == 1 { current-screen = 0; return accept; }
                if current-screen == 2 { current-screen = 0; return accept; }
                if current-screen == 3 { current-screen = 0; return accept; }
                if current-screen == 4 { current-screen = 1; return accept; }
                if current-screen == 5 { current-screen = 0; return accept; }
                if current-screen == 6 { current-screen = 0; return accept; }
                if current-screen == 7 { current-screen = 6; return accept; }
                if current-screen == 8 { current-screen = 7; return accept; }
            }
            return reject;
        }
    }

    // ════════════════════════════════════════════════════════════════════
    // LAYER 1 — MAIN APP (always present, base layer)
    // ════════════════════════════════════════════════════════════════════
    Rectangle {
        clip: true;

        // Desktop: two-panel layout. Mobile: full-screen single panel.
        HorizontalLayout {
            spacing: 0;

            // ── LEFT PANEL (Sidebar on desktop / Home on mobile) ──────────
            if is-desktop || current-screen == 0 || current-screen == 6: Rectangle {
                width: is-desktop ? 340px : 0px; 
                horizontal-stretch: is-desktop ? 0 : 1;
                background: AppTheme.surface-primary;

                if is-desktop || current-screen == 0: ChatListScreen {
                    is-desktop:        root.is-desktop;
                    safe-area-top:     root.safe-area-top;
                    safe-area-bottom:  root.safe-area-bottom;
                    direct-peers:      root.direct-peers;
                    relay-peers:       root.relay-peers;
                    is-offline:        root.is-offline;
                    open-chat(id) =>  { current-screen = 1; }
                    add-contact =>    { current-screen = 3; }
                    open-contacts =>  { current-screen = 6; }
                    open-settings =>  { current-screen = 5; }
                }

                if !is-desktop && current-screen == 6: ContactsScreen {
                    is-desktop:    false;
                    safe-area-top: root.safe-area-top;
                    go-back =>     { current-screen = 0; }
                    open-chat(id) => { current-screen = 1; }
                    add-contact => { current-screen = 3; }
                    new-group =>   { current-screen = 7; }
                }

                if is-desktop: Rectangle {
                    x: parent.width - 1px; y: 0;
                    width: 1px; height: parent.height;
                    background: AppTheme.divider;
                }
            }

            // ── RIGHT PANEL (Active screen on desktop / full screen on mobile) ──
            if is-desktop || (current-screen >= 1 && current-screen != 6): Rectangle {
                horizontal-stretch: 1;
                background: AppTheme.surface-primary;

                // Desktop empty state
                if is-desktop && (current-screen == 0): VerticalLayout {
                    alignment: center;
                    spacing: AppTheme.sp-md;
                    Text { text: "💬"; font-size: 64px; horizontal-alignment: center; }
                    Text {
                        text: "Select a chat to start messaging.";
                        font-size: 16px; color: AppTheme.text-secondary;
                        horizontal-alignment: center;
                    }
                }

                // Desktop contacts in right panel
                if is-desktop && current-screen == 6: ContactsScreen {
                    is-desktop:    true;
                    safe-area-top: 0px;
                    go-back =>     { current-screen = 0; }
                    open-chat(id) => { current-screen = 1; }
                    add-contact => { current-screen = 3; }
                    new-group =>   { current-screen = 7; }
                }

                // Screen 1 — 1:1 Chat View
                if current-screen == 1: ChatViewScreen {
                    is-desktop:               root.is-desktop;
                    peer-name:                root.active-peer-name;
                    peer-initials:            root.active-peer-initials;
                    peer-node-id:             root.active-peer-node-id;
                    connection-mode:          root.active-connection-mode;
                    is-verified:              root.active-peer-verified;
                    is-online:                root.active-peer-online;
                    safe-area-top:            is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom:         root.safe-area-bottom;
                    virtual-keyboard-height:  root.kb-height;
                    go-back =>                { current-screen = 0; }
                    send-message(msg) =>      { root.send-message(msg); }
                    open-verify =>            { current-screen = 4; }
                }

                // Screen 2 — Group Chat View
                if current-screen == 2: GroupViewScreen {
                    is-desktop:              root.is-desktop;
                    group-name:              root.active-group-name;
                    member-count:            root.active-group-members;
                    safe-area-top:           is-desktop ? 0px : root.safe-area-top;
                    safe-area-bottom:        root.safe-area-bottom;
                    virtual-keyboard-height: root.kb-height;
                    go-back =>               { current-screen = 0; }
                    send-message(msg) =>     { root.send-group-message(msg); }
                }

                // Screen 3 — Add Contact
                if current-screen == 3: AddContactScreen {
                    is-desktop:    root.is-desktop;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    go-back =>     { current-screen = 0; }
                    add-contact(id, name) => {
                        root.add-contact(id, name);
                        current-screen = 0;
                    }
                }

                // Screen 4 — Verify Key
                if current-screen == 4: VerifyKeyScreen {
                    is-desktop:    root.is-desktop;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    peer-name:     root.active-peer-name;
                    go-back =>     { current-screen = 1; }
                    mark-verified => {
                        root.mark-verified();
                        current-screen = 1;
                    }
                }

                // Screen 5 — Settings
                if current-screen == 5: SettingsScreen {
                    is-desktop:    root.is-desktop;
                    display-name:  root.my-display-name;
                    node-id:       root.my-node-id;
                    direct-peers:  root.direct-peers;
                    relay-peers:   root.relay-peers;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    go-back =>     { current-screen = 0; }
                    copy-node-id => { root.copy-node-id(); }
                    clear-messages => { root.clear-messages(); }
                    delete-identity => { root.delete-identity(); }
                }

                // Screen 7 — Select Members (for new group)
                if current-screen == 7: SelectMembersScreen {
                    is-desktop:    root.is-desktop;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    go-back =>     { current-screen = 6; }
                    next-step =>   { current-screen = 8; }
                }

                // Screen 8 — Create Group
                if current-screen == 8: CreateGroupScreen {
                    is-desktop:    root.is-desktop;
                    safe-area-top: is-desktop ? 0px : root.safe-area-top;
                    go-back =>     { current-screen = 7; }
                    launch-group(name) => {
                        root.launch-group(name);
                        current-screen = 0;
                    }
                }
            }
        }
    }

    // ════════════════════════════════════════════════════════════════════
    // LAYER 2 — ONBOARDING OVERLAY (shown only when !has-identity)
    // Covers the entire window. Dismissed automatically when Rust sets
    // has-identity = true after identity is generated and persisted.
    // ════════════════════════════════════════════════════════════════════
    if !has-identity: Rectangle {
        width: parent.width; height: parent.height;
        background: AppTheme.surface-primary;

        // Step 0 or 1 — Name input (setup-step == 1 shows loading state)
        if setup-step != 2: SetupNameScreen {
            generating:    root.setup-step == 1;
            is-desktop:    root.is-desktop;
            safe-area-top: root.safe-area-top;
            go-back => {} // no back on first onboarding step

            confirm-name(name) => {
                // Show loading state immediately; Rust generates the identity.
                root.setup-step = 1;
                root.confirm-name(name);
                // Rust callback: sets my-display-name, my-node-id, then setup-step = 2.
            }
        }

        // Step 2 — Identity card (shown after Rust confirms identity generated)
        if setup-step == 2: IdentityCardScreen {
            display-name: root.my-display-name;
            node-id:      root.my-node-id;
            copy-node-id => { root.copy-node-id(); }
            go-to-chats => {
                root.setup-complete();
                // Rust sets has-identity = true, which dismisses this overlay.
            }
        }
    }

    // ════════════════════════════════════════════════════════════════════
    // LAYER 3 — LOCK OVERLAY (shown when is-locked = true)
    // Covers the entire window. Dismissed when Rust verifies password
    // and sets is-locked = false.
    // ════════════════════════════════════════════════════════════════════
    if is-locked: Rectangle {
        width: parent.width; height: parent.height;
        background: AppTheme.surface-primary;

        WelcomeScreen {
            is-locked: true;
            get-started => {} // unused in locked mode
            // WIRE: on-unlock callback (password gate — future feature)
        }
    }
}

// NodeChat New — Root Application Shell
// ---------------------------------------------------------
// This file serves as the primary layout controller.
// It manages:
//   - Responsive breakpoints (Mobile vs Tablet vs Desktop)
//   - Safe areas for mobile/keyboard
//   - Navigation state (Routing)
//   - Theme token application
// ---------------------------------------------------------

import { AppTheme } from "./theme.slint";
import {
    ChatPreview,
    ContactData,
    GroupData,
    AppInfo,
    GroupCandidateItem,
} from "./components/row_data.slint";
import { ChatListScreen } from "./screens/chat_list.slint";
import { ChatViewScreen, MessageData } from "./screens/chat_view.slint";
import { ContactsScreen } from "./screens/contacts_screen.slint";
import { SettingsScreen } from "./screens/settings_screen.slint";
import { AddScreen } from "./screens/add_screen.slint";
import { AboutScreen } from "./screens/about_screen.slint";
import { InfoScreen } from "./screens/info_screen.slint";
import { EditNameScreen } from "./screens/edit_name.slint";
import { PasswordScreen } from "./screens/password_screen.slint";
import { ConfirmModal } from "./components/confirm_modal.slint";
import { NavBar } from "./components/nav_bar.slint";
import { CreateGroupScreen } from "./screens/create_group.slint";
import { SelectContactsScreen } from "./screens/select_contacts.slint";
import { SplashScreen } from "./screens/splash.slint";
import { WelcomeScreen } from "./screens/welcome.slint";
import { SetupNameScreen } from "./screens/setup_name.slint";

export { ChatPreview, MessageData }

export enum DeviceType { mobile, tablet, desktop }

export struct ConversationContext {
    kind: string,           // "direct" | "group"
    id: string,
    title: string,
    initials: string,
    node-id: string,
    ticket: string,
    is-online: bool,
    is-relay: bool,
    is-verified: bool,
    is-session-ready: bool,
    connection-stage: string,
    return-screen: int,
}

export component AppWindow inherits Window {
    title: root.app-info.name;
    init => {
        focus-scope.focus();
    }

    property <bool> global-copied-active: false;
    Timer {
        interval: 2000ms;
        running: root.global-copied-active;
        triggered => {
            root.global-copied-active = false;
        }
    }

    forward-focus: focus-scope;
    focus-scope := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                if (root.request-back()) {
                    return accept;
                }
            }
            reject
        }
    }

    // --- Window Constraints ---
    min-width: 0px;
    min-height: 0px;
    preferred-width: 1080px;
    preferred-height: 800px;
    background: AppTheme.surface-primary;

    // --- Shell State ---
    // Breakpoints: Mobile (< 700px), Tablet (700px - 1000px), Desktop (> 1000px)
    out property <DeviceType> device: root.width > 1000px ? DeviceType.desktop : root.width > 700px ? DeviceType.tablet : DeviceType.mobile;
    out property <bool> is-desktop: root.device == DeviceType.desktop || root.device == DeviceType.tablet;
    
    // Decoupled width property to prevent binding loops in layout negotiation
    property <length> concrete-sidebar-width: (root.device == DeviceType.desktop) ? 320px : (root.device == DeviceType.tablet ? 170px : 0px);
    in-out property <int> current-screen: 0;
    property <int> last-screen: 0;

    property <bool> show-splash: true;
    property <bool> show-setup: false;

    Timer {
        interval: 2000ms;
        running: root.show-splash;
        triggered => {
            root.show-splash = false;
        }
    }

    function push-screen(target: int) {
        focus-scope.focus(); // Release the keyboard and clear cursors
        root.last-screen = root.current-screen;
        root.current-screen = target;
    }

    function back() {
        focus-scope.focus(); // Release the keyboard and clear cursors
        root.current-screen = root.last-screen;
        root.last-screen = 0; // Default fallback to Chat List
    }

    // This is the bridge for the Android Hardware Back Button + Desktop Escape key
    public function request-back() -> bool {
        // 1. Close Modals First
        if (root.confirm-modal-show) {
            root.confirm-modal-show = false;
            return true;
        }

        // 2. Tab Navigation - Allow system to exit from primary tabs
        // Screen 0 (Chats), 3 (Settings), 4 (Contacts) are the root tabs.
        if (root.current-screen == 0 || root.current-screen == 3 || root.current-screen == 4) {
            return false; // Let OS minimize the app
        }

        // 3. Sub-Screen Navigation
        root.back();
        return true; // Successfully navigated back
    }
    in-out property <bool> has-password: false;
    in-out property <bool> has-identity: false;
    in-out property <bool> is-locked: false;

    // --- App Data (Driven by Rust) ---
    in property <string> display-name: "";
    in property <string> initials: "";
    in property <string> endpoint-ticket: "";
    in property <[ChatPreview]> chats: [];
    in property <[ContactData]> contacts: [];
    in-out property <[GroupData]> groups: [];
    in-out property <string> pending-action-id: "";
    in-out property <string> operation-success-slug: "";
    property <bool> confirm-modal-requires-pin: false;
    in-out property <GroupData> active-group: { id: "", name: "", initials: "", topic: "", secret-key: "", member-count: 0 };

    // --- Temporary State for Flows ---
    property <string> temp-group-name: "";
    property <string> temp-group-desc: "";
    property <string> inviting-group-id: "";
    property <int> group-selection-return: 10;
    property <string> sharing-contact-id: "";

    in property <AppInfo> app-info: { name: "", version: "", version-type: "", description: "", website: "", repo: "" };

    in property <[MessageData]> active-messages: [];
    in-out property <ConversationContext> active-conversation: {
        kind: "direct",
        id: "",
        title: "",
        initials: "",
        is-online: false,
        is-relay: false,
        is-verified: false,
        is-session-ready: false,
        connection-stage: "",
        return-screen: 0,
    };
    in property <int> direct-peers: 0;
    in property <int> relay-peers: 0;
    in property <bool> is-offline: false;
    in property <[GroupCandidateItem]> group-candidates: [];
    in property <int> group-candidates-selected: 0;

    // --- Modal State ---
    in-out property <bool> confirm-modal-show: false;
    in-out property <string> confirm-modal-title: "Confirm Action";
    in-out property <string> confirm-modal-subtitle: "Are you sure you want to do this?";
    in-out property <string> confirm-modal-slug: "";
    in-out property <string> confirm-modal-err: "";
    in-out property <bool> confirm-modal-checked: false;

    // --- Callbacks ---
    callback open-settings;
    callback open-contacts;
    callback add-contact;
    callback open-chat(ChatPreview);
    callback add-peer(string);
    callback refresh();

    open-settings => {
        root.push-screen(3);
    }
    open-contacts => {
        root.push-screen(4);
    }
    add-contact => {
        root.push-screen(5);
    }
    open-chat(chat) => {
        // Rust handles full state population via Command::LoadConversation
        root.load-conversation(chat.id, chat.is-group);
        root.push-screen(chat.is-group ? 2 : 1);
    }

    callback send-message(string);
    callback send-group-message(string);
    callback load-conversation(string, bool);
    callback open-contact-info();
    callback open-group-info();
    callback accept-group-invite(string, string, string);
    callback retry-queued();
    callback request-delete-conversation();
    callback confirm-modal-confirmed(string, string);
    callback edit-display-name();
    callback confirm-name-change(string);
    callback share-contact(string, [string]);
    callback toggle-verify(string, bool);
    callback toggle-group-candidate(string);
    callback create-group(string, string);
    callback invite-to-group(string);
    callback copy-node-id();
    callback change-password();
    callback submit-password(string, string);
    callback open-debug-console();
    callback request-clear-history();
    callback request-reset-identity();
    callback open-url(string);
    callback copy-to-clipboard(string);
    
    // Missing P2P Callbacks
    callback unlock-app(string);
    callback do-operation-success();
    do-operation-success => {
        root.confirm-modal-show = false;
        root.pending-action-id = "";
        if (root.operation-success-slug == "unlock") {
            root.is-locked = false;
        }
        if (root.operation-success-slug == "reset-identity" || root.operation-success-slug == "delete-identity") {
            root.current-screen = 2; // Setup/Welcome
        }
        if (root.operation-success-slug == "join-group") {
            root.load-conversation(root.pending-action-id, true);
            root.current-screen = 1; // Chat view
        }
        if (root.operation-success-slug == "leave-group" || root.operation-success-slug == "delete-chat") {
            root.current-screen = 0; // Back to chats
        }
    }
    callback create-identity(string, string);
    callback finalize-identity();

    // --- Clipboard Integration ---
    in-out property <string> clipboard-buffer: "";
    // --- Debug Logs (filled by the tracing subscriber via AppEvent::Log) ---
    in-out property <string> debug-logs: "[NodeChat] Waiting for events...";
    public function do-copy() {
        clipboard-input.focus();
        clipboard-input.select-all();
        clipboard-input.copy();
    }
    clipboard-input := TextInput {
        text: root.clipboard-buffer;
        x: -1000px;
        y: -1000px;
        width: 1px;
        height: 1px;
    }

    // --- Safe Areas ---
    property <length> safe-area-top: root.safe-area-insets.top;
    property <length> safe-area-bottom: root.safe-area-insets.bottom;
    property <length> kb-height: root.virtual-keyboard-size.height;

    // --- Application Root Shell ---
    Rectangle {
        width: 100%;
        height: 100%;

        // 1. SIDEBAR (Desktop & Tablet Rail)
        Rectangle {
            x: 0;
            y: 0;
            width: root.concrete-sidebar-width;
            height: 100%;
            clip: true;
            background: AppTheme.surface-secondary;
            visible: self.width > 0px;

            VerticalLayout {
                width: 100%;
                height: 100%;
                spacing: 0;
                
                // Desktop Mode — NavBar pinned to bottom via absolute positioning
                if root.device == DeviceType.desktop: Rectangle {
                    vertical-stretch: 1;

                    // Chat list fills everything above the nav bar
                    ChatListScreen {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height - 72px;
                        is-desktop: true;
                        chats: root.chats;
                        direct-peers: root.direct-peers;
                        relay-peers: root.relay-peers;
                        is-offline: root.is-offline;
                        active-id: root.active-conversation.id;
                        open-chat(chat) => {
                            root.open-chat(chat);
                        }
                        add-contact => {
                            root.open-contacts();
                        }
                        open-contacts => {
                            root.open-contacts();
                        }
                        open-settings => {
                            root.open-settings();
                        }
                    }

                    // NavBar always pinned to the very bottom
                    NavBar {
                        x: 0;
                        y: parent.height - 72px;
                        width: parent.width;
                        height: 72px;
                        active-screen: root.current-screen;
                        nav-to(id) => {
                            root.current-screen = id;
                        }
                    }
                }

                // Tablet Mode
                if root.device == DeviceType.tablet: HorizontalLayout {
                    width: 100%;
                    height: 100%;
                    spacing: 0;
                    NavBar {
                        width: 90px;
                        active-screen: root.current-screen;
                        is-vertical: true;
                        nav-to(id) => {
                            root.current-screen = id;
                        }
                        add-contact-clicked => {
                            root.add-contact();
                        }
                    }

                    ChatListScreen {
                        horizontal-stretch: 1;
                        is-desktop: true;
                        compact: true;
                        chats: root.chats;
                        direct-peers: root.direct-peers;
                        relay-peers: root.relay-peers;
                        is-offline: root.is-offline;
                        active-id: root.active-conversation.id;
                        open-chat(chat) => {
                            root.open-chat(chat);
                        }
                        add-contact => {
                            root.add-contact();
                        }
                        open-contacts => {
                            root.open-contacts();
                        }
                        open-settings => {
                            root.open-settings();
                        }
                    }
                }
            }

            // Divider
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                background: AppTheme.divider;
                visible: parent.width > 0.5px;
            }
        }

        // 2. PRIMARY CONTENT AREA
        Rectangle {
            x: root.concrete-sidebar-width;
            y: 0;
            width: parent.width - root.concrete-sidebar-width;
            height: 100%;
            background: AppTheme.surface-primary;
            clip: true;

            VerticalLayout {
                spacing: 0;

                // Safe area spacer (Mobile only)
                Rectangle {
                    height: root.device == DeviceType.mobile ? root.safe-area-top : 0px;
                    background: AppTheme.surface-secondary;
                    vertical-stretch: 0;
                }

                // Screen Content
                Rectangle {
                    vertical-stretch: 1;
                    clip: true;

                    if root.device == DeviceType.mobile && root.current-screen == 0: ChatListScreen {
                        width: 100%;
                        height: 100%;
                        is-desktop: false;
                        chats: root.chats;
                        direct-peers: root.direct-peers;
                        relay-peers: root.relay-peers;
                        is-offline: root.is-offline;
                        active-id: root.active-conversation.id;
                        open-chat(chat) => {
                            root.open-chat(chat);
                        }
                        add-contact => {
                            root.open-contacts();
                        }
                        open-contacts => {
                            root.open-contacts();
                        }
                        open-settings => {
                            root.open-settings();
                        }
                    }

                    if root.is-desktop && root.current-screen == 0: VerticalLayout {
                        width: 100%;
                        height: 100%;
                        alignment: center;
                        spacing: AppTheme.sp-lg;
                        padding: AppTheme.sp-xl;
                        Text {
                            text: "💬";
                            font-size: 56px;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Select a conversation";
                            font-size: 20px;
                            font-weight: 700;
                            color: AppTheme.text-primary;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Choose a chat from the left panel to begin.";
                            font-size: 14px;
                            color: AppTheme.text-secondary;
                            horizontal-alignment: center;
                        }
                    }

                    if root.current-screen == 1 || root.current-screen == 2: ChatViewScreen {
                        width: 100%;
                        height: 100%;
                        is-desktop: root.is-desktop;
                        peer-name: root.active-conversation.title;
                        peer-initials: root.active-conversation.initials;
                        peer-node-id: root.active-conversation.id;
                        connection-mode: root.active-conversation.kind;
                        is-online: root.active-conversation.is-online || root.active-conversation.kind == "group";
                        is-relay: root.active-conversation.is-relay;
                        is-verified: root.active-conversation.is-verified || root.active-conversation.kind == "group";
                        connection-stage: root.active-conversation.connection-stage;
                        messages: root.active-messages;
                        virtual-keyboard-height: root.kb-height;
                        safe-area-bottom: root.safe-area-bottom;
                        go-back => {
                            root.back();
                        }
                        send-message(msg) => {
                            if root.active-conversation.kind == "group" {
                                root.send-group-message(msg);
                            } else {
                                root.send-message(msg);
                            }
                        }
                        open-contact-info => {
                            root.push-screen(9);
                        }
                        open-invite(topic, name, key, joined) => {
                            if (!joined) {
                                root.accept-group-invite(root.active-conversation.id, topic, key);
                            } else {
                                root.load-conversation(topic, true);
                                root.current-screen = 2;
                            }
                        }
                        add-contact(ticket) => {
                            root.add-peer(ticket);
                        }
                        retry-queued => {
                            root.retry-queued();
                        }
                        request-delete-conversation => {
                            root.pending-action-id = root.active-conversation.id;
                            root.request-delete-conversation();
                        }
                        request-unfocus => {
                            focus-scope.focus();
                        }
                    }

                    if root.current-screen == 3: SettingsScreen {
                        is-desktop: root.is-desktop;
                        display-name: root.display-name;
                        initials: root.initials;
                        node-id: "node_" + root.endpoint-ticket + "...";
                        endpoint-ticket: root.endpoint-ticket;
                        has-password: root.has-password;
                        app-info: root.app-info;
                        show-copied: root.global-copied-active;
                        back-clicked => {
                            root.back();
                        }
                        edit-display-name => {
                            root.push-screen(6);
                        }
                        copy-node-id => {
                            root.copy-to-clipboard(root.endpoint-ticket);
                            root.global-copied-active = true;
                        }
                        change-password => {
                            root.push-screen(8);
                        }
                        open-about => {
                            root.push-screen(7);
                        }
                        request-clear-history => {
                            root.confirm-modal-slug = "clear-history";
                            root.confirm-modal-title = "Clear History";
                            root.confirm-modal-subtitle = "Wipe all messages locally. This cannot be undone.";
                            root.confirm-modal-show = true;
                        }
                        request-reset-identity => {
                            root.confirm-modal-slug = "delete-identity";
                            root.confirm-modal-title = "Nuke Identity";
                            root.confirm-modal-subtitle = "WARNING: You will lose your Peer ID and Contacts forever.";
                            root.confirm-modal-show = true;
                        }
                    }

                    if root.current-screen == 4: ContactsScreen {
                        width: 100%;
                        height: 100%;
                        is-desktop: root.is-desktop;
                        contacts: root.contacts;
                        groups: root.groups;
                        back-clicked => {
                            root.back();
                        }
                        add-contact => {
                            root.push-screen(5);
                        }
                        new-group => {
                            root.push-screen(10);
                        }
                        open-contact(contact) => {
                            root.active-conversation = {
                                kind: "direct",
                                id: contact.id,
                                title: contact.name,
                                initials: contact.initials,
                                node-id: contact.node-id,
                                ticket: contact.ticket,
                                is-online: contact.is-online,
                                is-relay: contact.is-relay,
                                is-verified: contact.is-verified,
                                is-session-ready: contact.is-session-ready,
                                connection-stage: "Direct connection ready",
                                return-screen: 4,
                            };
                            root.push-screen(9);
                        }
                        open-group(group) => {
                            root.active-group = group;
                            root.active-conversation = {
                                kind: "group",
                                id: group.id,
                                title: group.name,
                                initials: group.initials,
                                node-id: group.topic,
                                ticket: group.id,
                                is-online: true,
                                is-relay: false,
                                is-verified: true,
                                is-session-ready: true,
                                connection-stage: "",
                                return-screen: 4,
                            };
                            root.push-screen(9);
                        }
                    }

                    if root.current-screen == 5: AddScreen {
                        is-desktop: root.is-desktop;
                        endpoint-ticket: root.endpoint-ticket;
                        show-copied: root.global-copied-active;
                        back-clicked => {
                            root.back();
                        }
                        add-ticket(t) => {
                            root.add-peer(t);
                            root.back();
                        }
                        copy-ticket(t) => {
                            root.copy-to-clipboard(t);
                            root.global-copied-active = true;
                        }
                    }

                    if root.current-screen == 7: AboutScreen {
                        is-desktop: root.is-desktop;
                        app-info: root.app-info;
                        show-copied: root.global-copied-active;
                        debug-logs: root.debug-logs;
                        back-clicked => {
                            root.back();
                        }
                        open-url(url) => {
                            root.open-url(url);
                        }
                        copy-logs(logs) => {
                            root.copy-to-clipboard(logs);
                            root.global-copied-active = true;
                        }
                        refresh-debug => {
                            root.refresh();
                        }
                        request-unfocus => {
                            focus-scope.focus();
                        }
                    }

                    if root.current-screen == 6: EditNameScreen {
                        is-desktop: root.is-desktop;
                        display-name: root.display-name;
                        back-clicked => {
                            root.back();
                        }
                        confirm-name(name) => {
                            root.confirm-name-change(name);
                            root.back();
                        }
                        request-unfocus => { focus-scope.focus(); }
                    }

                    if root.current-screen == 8: PasswordScreen {
                        is-desktop: root.is-desktop;
                        has-password: root.has-password;
                        back-clicked => {
                            root.back();
                        }
                        confirm-password(cur, new) => {
                            root.submit-password(cur, new);
                        }
                        remove-password(cur) => {
                            root.submit-password(cur, "");
                        }
                        request-unfocus => { focus-scope.focus(); }
                    }

                    if root.current-screen == 9: InfoScreen {
                        is-desktop: root.is-desktop;
                        is-group: root.active-conversation.kind == "group";
                        contact: {
                            id: root.active-conversation.id,
                            name: root.active-conversation.title,
                            initials: root.active-conversation.initials,
                            node-id: root.active-conversation.node-id,
                            ticket: root.active-conversation.ticket,
                            is-online: root.active-conversation.is-online,
                            is-relay: root.active-conversation.is-relay,
                            is-verified: root.active-conversation.is-verified,
                        };
                        group: root.active-group;
                        show-copied: root.global-copied-active;
                        back-clicked => {
                            root.back();
                        }
                        chat-clicked => {
                            root.push-screen(1);
                        }
                        copy-text(t) => {
                            root.copy-to-clipboard(t);
                            root.global-copied-active = true;
                        }
                        request-clear-history => {
                            root.confirm-modal-title = "Clear Chat History";
                            root.confirm-modal-subtitle = "Wipe messages for this peer locally.";
                            root.confirm-modal-slug = "clear-chat";
                            root.confirm-modal-show = true;
                        }
                        request-delete => {
                            root.pending-action-id = root.active-conversation.id;
                            root.confirm-modal-title = root.active-conversation.kind == "group" ? "Leave Swarm" : "Remove Contact";
                            root.confirm-modal-subtitle = root.active-conversation.kind == "group" ? "Exit this P2P conversation topic." : "Disconnect from peer and delete history.";
                            root.confirm-modal-slug = root.active-conversation.kind == "group" ? "leave-group" : "delete-chat";
                            root.confirm-modal-show = true;
                        }
                        add-members => {
                            root.sharing-contact-id = "";
                            root.inviting-group-id = root.active-conversation.id;
                            root.push-screen(11);
                        }
                        share-clicked => {
                            root.sharing-contact-id = root.active-conversation.id;
                            root.push-screen(11);
                        }
                        toggle-verify(v) => {
                            root.toggle-verify(root.active-conversation.id, v);
                        }
                        request-unfocus => {
                            focus-scope.focus();
                        }
                    }

                    if root.current-screen == 10: CreateGroupScreen {
                        is-desktop: root.is-desktop;
                        app-info: root.app-info;
                        back-clicked => {
                            root.back();
                        }
                        create-group(name, desc) => {
                            root.temp-group-name = name;
                            root.temp-group-desc = desc;
                            root.push-screen(11);
                        }
                    }

                    if root.current-screen == 11: SelectContactsScreen {
                        is-desktop: root.is-desktop;
                        contacts: root.group-candidates;
                        selected-count: root.group-candidates-selected;
                        active-intent: root.sharing-contact-id != "" ? "share" : (root.inviting-group-id != "" ? "invite" : "create");
                        group-name: root.sharing-contact-id != "" ? "Share Contact" : (root.inviting-group-id != "" ? root.active-conversation.title : root.temp-group-name);
                        back-clicked => {
                            root.sharing-contact-id = "";
                            root.back();
                        }
                        toggled(id) => {
                            root.toggle-group-candidate(id);
                        }
                        create-clicked => {
                            if (root.inviting-group-id != "") {
                                root.invite-to-group(root.inviting-group-id);
                                root.back();
                                root.inviting-group-id = "";
                            } else if (root.sharing-contact-id != "") {
                                 // Collecting selected contacts is handled by Rust side usually 
                                 // via the group-candidates list states. 
                                 // We'll call a dedicated command.
                                 root.share-contact(root.sharing-contact-id, []);
                                root.back();
                                root.sharing-contact-id = "";
                            } else {
                                root.create-group(root.temp-group-name, root.temp-group-desc);
                                root.temp-group-name = "";
                                root.temp-group-desc = "";
                                 // Open the new group chat directly
                                 root.current-screen = 2;
                                root.last-screen = 0;
                            }
                        }
                    }
                }

                // Keyboard Spacer (Mobile only)
                if root.device == DeviceType.mobile : Rectangle {
                    height: root.kb-height;
                    vertical-stretch: 0;
                    animate height { duration: AppTheme.dur-short; easing: ease-out; }
                }

                // Mobile Navigation Bar
                if root.device == DeviceType.mobile && root.kb-height < 20px && (root.current-screen == 0 || root.current-screen == 3 || root.current-screen == 4): NavBar {
                    height: 72px + root.safe-area-bottom;
                    vertical-stretch: 0;
                    active-screen: root.current-screen;
                    nav-to(id) => {
                        root.current-screen = id;
                    }
                }
            } // Ends Content Area
        } // Ends Shell Rectangle
    }

    // --- ONBOARDING & LOCK OVERLAYS ---
    if !root.show-splash && !root.has-identity && !root.show-setup: WelcomeScreen {
        is-desktop: root.is-desktop;
        safe-area-bottom: root.safe-area-bottom;
        is-locked: false; // Get Started mode
        get-started => {
            root.show-setup = true;
        }
    }

    if !root.show-splash && !root.has-identity && root.show-setup: SetupNameScreen {
        is-desktop: root.is-desktop;
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom;
        virtual-keyboard-height: root.kb-height;
        go-back => {
            root.show-setup = false;
        }
        confirm-name(name, pin) => { 
            // The screen itself will flip to generating: true internally when clicked
            root.create-identity(name, pin); 
            // Notice: we DO NOT set show-setup to false here.
            // The backend will populate `has-identity` = true when finished, which natively unmounts this.
        }
    }

    if !root.show-splash && root.has-identity && root.is-locked: WelcomeScreen {
        is-desktop: root.is-desktop;
        safe-area-bottom: root.safe-area-bottom;
        is-locked: true; // Unlock mode
        unlock(pin) => {
            root.unlock-app(pin);
        }
    }

    if root.show-splash: SplashScreen {
        finished => {
            root.show-splash = false;
        }
    }

    // 3. GLOBAL MODALS
    if root.confirm-modal-show: ConfirmModal {
        title: root.confirm-modal-title;
        subtitle: root.confirm-modal-subtitle;
        action-slug: root.confirm-modal-slug;
        error-msg: root.confirm-modal-err;
        requires-pin: root.confirm-modal-requires-pin;
        is-checked <=> root.confirm-modal-checked;
        cancel => {
            root.confirm-modal-show = false;
        }
        confirm(pin) => {
            root.confirm-modal-confirmed(root.confirm-modal-slug, pin);
        }
    }

    request-delete-conversation => {
        root.confirm-modal-title = "Delete Chat";
        root.confirm-modal-subtitle = "All messages will be removed. Peer will remain in contacts.";
        root.confirm-modal-slug = "delete-chat";
        root.pending-action-id = ""; // To be safe
        root.confirm-modal-requires-pin = false;
        root.confirm-modal-show = true;
    }
    request-clear-history => {
        root.confirm-modal-title = "Clear All History";
        root.confirm-modal-subtitle = "Irreversibly delete all local messages from ALL conversations.";
        root.confirm-modal-slug = "clear-history";
        root.confirm-modal-requires-pin = root.has-password;
        root.confirm-modal-show = true;
    }
    request-reset-identity => {
        root.confirm-modal-title = "Nuke Identity";
        root.confirm-modal-subtitle = "This will destroy your Peer keys and all contact links permanently.";
        root.confirm-modal-slug = "reset-identity";
        root.confirm-modal-requires-pin = root.has-password;
        root.confirm-modal-show = true;
    }
}

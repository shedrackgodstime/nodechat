import { AppTheme } from "../theme.slint";

export component SplashScreen inherits Rectangle {
    background: AppTheme.surface-primary;
    
    // Emitted when the splash sequence is complete.
    callback finished();

    // Animated background accents.
    Rectangle {
        width: 100%; height: 100%;
        background: @radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, transparent 60%);
        x: self.width * -0.2; y: self.height * -0.2;
        
        animate x, y {
            duration: 8000ms;
            easing: ease-in-out;
            iteration-count: -1;
        }
    }

    Rectangle {
        width: 100%; height: 100%;
        background: @radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 60%);
        x: self.width * 0.4; y: self.height * 0.4;
        
        animate x, y {
            duration: 12000ms;
            easing: ease-in-out;
            iteration-count: -1;
        }
    }

    VerticalLayout {
        width: 100%;
        height: 100%;
        alignment: center;
        spacing: AppTheme.sp-xl;

        // Logo presentation.
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 200px; height: 200px;
            
            // Soft glow behind the logo.
            Rectangle {
                width: 140%; height: 140%;
                background: @radial-gradient(circle, rgba(0, 122, 255, 0.15) 0%, transparent 70%);
            }

            VerticalLayout {
                alignment: center;
                Image {
                    source: @image-url("../../assets/images/app_logo_with_name_transparent_bg.png");
                    width: 160px;
                    image-fit: contain;
                }
            }
            }
        }

        HorizontalLayout {
            alignment: center;
            VerticalLayout {
                spacing: AppTheme.sp-md;
                Text { text: "NodeChat"; font-size: 32px; font-weight: 900; color: #FFFFFF; horizontal-alignment: center; letter-spacing: -1px; }
                Text { text: "Decentralized. Peer-to-Peer."; font-size: 14px; font-weight: 700; color: AppTheme.text-tertiary; horizontal-alignment: center; letter-spacing: 1px; }
            }
        }

        // --- Minimal Loading Bar ---
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 120px; height: 4px;
                background: AppTheme.surface-secondary;
                border-radius: 2px;
                clip: true;

                Rectangle {
                    x: 0; width: 40px; height: 100%;
                    background: AppTheme.accent;
                    border-radius: 2px;
                    
                    animate x {
                        duration: 1000ms;
                        easing: ease-in-out;
                        iteration-count: -1;
                    }
                }
            }
        }
    }
}

import { AppTheme } from "../theme.slint";

export component WelcomeScreen inherits Rectangle {
    background: AppTheme.surface-primary;
    in property <bool> is-locked: false;

    callback get-started();
    callback unlock();

    property <bool> wrong-password: false;

    // --- Background Aesthetic ---
    Rectangle {
        background: @radial-gradient(circle, rgba(10, 132, 255, 0.08) 0%, transparent 70%);
        width: 100%; height: 100%;
    }

    VerticalLayout {
        alignment: center;
        spacing: AppTheme.sp-xl;
        padding: AppTheme.sp-xl;

        // --- App Branding ---
        VerticalLayout {
            spacing: AppTheme.sp-md;
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 140px; height: 140px;
                    border-radius: 36px;
                    background: @linear-gradient(135deg, AppTheme.accent 0%, #0056b3 100%);
                    Image {
                        source: @image-url("../../assets/icons/app_logo_with_name_transparent_bg.png");
                        width: 100%; height: 100%;
                        image-fit: contain;
                    }
                }
            }
            Text {
                text: "NodeChat";
                font-size: 36px; font-weight: 900; color: #FFFFFF;
                horizontal-alignment: center;
                letter-spacing: -0.5px;
            }
        }

        VerticalLayout {
            spacing: AppTheme.sp-sm;
            Text {
                text: is-locked ? "Identity Locked" : "Privacy by Design";
                font-size: 20px; font-weight: 700; color: AppTheme.text-primary;
                horizontal-alignment: center;
            }
            Text {
                text: is-locked ? "Authenticate to access your P2P messages" : "Decentralized. Peer-to-Peer. Encrypted.";
                font-size: 15px; color: AppTheme.text-tertiary;
                horizontal-alignment: center;
            }
        }

        // ── Main Action ──────────────────────────────────────────────────────
        VerticalLayout {
            spacing: AppTheme.sp-md;
            alignment: center;

            HorizontalLayout {
                alignment: center;
                Rectangle {
                    horizontal-stretch: 1;
                    height: 60px;
                    background: @linear-gradient(90deg, AppTheme.accent 0%, #0056B3 100%);
                    border-radius: 30px;
                    
                    touch := TouchArea {
                        clicked => { is-locked ? root.unlock() : root.get-started(); }
                    }

                    Rectangle {
                        width: 100%; height: 100%;
                        background: touch.has-hover ? rgba(255, 255, 255, 0.1) : transparent;
                        border-radius: 30px;
                        animate background { duration: AppTheme.dur-short; }
                    }

                    Text {
                        text: is-locked ? "Unlock Vault" : "Get Started";
                        font-size: 18px; font-weight: 800; color: #FFFFFF;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }
            }

            if !is-locked: Text {
                text: "No central servers. Ever.";
                font-size: 12px; color: AppTheme.text-tertiary; horizontal-alignment: center;
                opacity: 0.6;
            }

            if is-locked && wrong-password: Text {
                text: "Incorrect key. Please try again.";
                font-size: 13px; color: AppTheme.accent-danger; horizontal-alignment: center;
            }
        }
    }
}


import { AppTheme } from "../theme.slint";

export component SetupNameScreen inherits Rectangle {
    in-out property <bool>   generating: false;
    in-out property <string> display-name: "";
    in property <bool>       is-desktop: false;
    in property <length>     safe-area-top: 0px;
    in property <length>     safe-area-bottom: 0px;
    in property <length>     virtual-keyboard-height: 0px;

    callback confirm-name(string, string);
    callback request-unfocus();

    // Background Unfocus Catcher
    TouchArea {
        width: 100%; height: 100%;
        clicked => { root.request-unfocus(); }
    }
    callback go-back();

    property <bool> valid: display-name.character-count >= 1 && display-name.character-count <= 32;

    background: AppTheme.surface-primary;

    VerticalLayout {
        padding-top: root.safe-area-top;
        padding-bottom: root.safe-area-bottom;

        // --- Header (Full Width) ---
        Rectangle {
            height: 64px;
            background: AppTheme.surface-primary;
            
            Rectangle {
                y: parent.height - 1px;
                width: 100%; height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-lg;
                padding-right: AppTheme.sp-lg;
                spacing: AppTheme.sp-md;
                alignment: start;

                VerticalLayout {
                    alignment: center;
                    TouchArea {
                        width: 40px; height: 40px;
                        clicked => { if (!root.generating) { root.go-back(); } }
                        Rectangle {
                            background: AppTheme.surface-secondary;
                            border-radius: 20px;
                            Text { text: "←"; font-size: 20px; color: AppTheme.accent; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    Text { text: "Create Identity"; font-size: 18px; font-weight: 800; color: AppTheme.text-primary; }
                }
            }
        }

        // --- Content Area (Centered) ---
        Rectangle {
            vertical-stretch: 1;
            
            HorizontalLayout {
                alignment: center;
                padding-left: AppTheme.sp-lg;
                padding-right: AppTheme.sp-lg;
                
                VerticalLayout {
                    max-width: 520px;
                    alignment: center;

                    if !generating: VerticalLayout {
                        spacing: AppTheme.sp-xl;
                        padding-top: AppTheme.sp-lg;
                        alignment: center;
                        
                        // Push layout up when soft keyboard appears (Mobile)
                        padding-bottom: Math.max(AppTheme.sp-xl, root.virtual-keyboard-height + 20px);
                        animate padding-bottom { duration: AppTheme.dur-short; }

                        VerticalLayout {
                            spacing: AppTheme.sp-sm;
                            Text { text: "What's your name?"; font-size: 32px; font-weight: 900; color: #FFFFFF; letter-spacing: -0.5px; horizontal-alignment: center; }
                            Text { text: "This is your display name. It stays on your device and is only shared with peers you choose to talk to."; font-size: 15px; color: AppTheme.text-tertiary; wrap: word-wrap; horizontal-alignment: center; }
                        }

                        // --- Input Fields ---
                        HorizontalLayout {
                            alignment: center;
                            VerticalLayout {
                                width: 100%;
                                spacing: AppTheme.sp-xl; 
                                
                                // --- Name Field ---
                                VerticalLayout {
                                    spacing: AppTheme.sp-md;
                                    Text { text: "DISPLAY NAME"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; horizontal-alignment: center; }
                                    
                                    Rectangle {
                                        height: 60px;
                                        border-radius: AppTheme.radius-lg;
                                        background: AppTheme.surface-secondary;
                                        border-width: 1px;
                                        border-color: name-input.has-focus ? AppTheme.accent : transparent;
                                        animate border-color { duration: AppTheme.dur-short; }

                                        TouchArea { width: 100%; height: 100%; clicked => { name-input.focus(); } }

                                        HorizontalLayout {
                                            alignment: center;
                                            name-input := TextInput {
                                                width: 100%;
                                                text <=> root.display-name;
                                                font-size: 18px; font-weight: 600; color: AppTheme.text-primary;
                                                vertical-alignment: center; single-line: true;
                                                horizontal-alignment: center;
                                                accepted => { if (root.valid) { root.confirm-name(root.display-name, ""); } } 
                                            }
                                        }

                                        if name-input.text == "": Text {
                                            width: 100%; height: 100%;
                                            text: "e.g. Satoshi Nakamoto"; font-size: 20px;
                                            color: AppTheme.text-tertiary; vertical-alignment: center; horizontal-alignment: center; opacity: 0.3;
                                        }
                                    }
                                }
                            }
                        }

                        // --- Action Button ---
                        HorizontalLayout {
                            alignment: center;
                            Rectangle {
                                height: 60px;
                                width: 100%; 
                                max-width: 400px;
                                background: valid ? @linear-gradient(90deg, AppTheme.accent 0%, #0056B3 100%) : AppTheme.surface-tertiary;
                                border-radius: 30px;
                                animate background { duration: AppTheme.dur-short; }

                                TouchArea {
                                    enabled: root.valid && !root.generating;
                                    clicked => { 
                                        root.generating = true;
                                        root.confirm-name(root.display-name, ""); 
                                    }
                                    Text {
                                        text: "Create Identity & Start";
                                        font-size: 17px; font-weight: 800;
                                        color: root.valid ? #FFFFFF : AppTheme.text-tertiary;
                                        horizontal-alignment: center; vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    if generating: VerticalLayout {
                        alignment: center;
                        spacing: AppTheme.sp-xl;
                        padding: AppTheme.sp-xl;

                        HorizontalLayout {
                            alignment: center;
                            Image {
                                source: @image-url("../../assets/images/app_logo_with_name_transparent_bg.png");
                                height: 140px;
                                image-fit: contain;
                                opacity: 0.8;
                                animate opacity { duration: AppTheme.dur-short; }
                            }
                        }

                        VerticalLayout {
                            spacing: AppTheme.sp-sm;
                            Text { text: "Generating Identity..."; font-size: 24px; font-weight: 900; color: #FFFFFF; horizontal-alignment: center; }
                            Text { text: "We're creating unique Ed25519 and X25519 keypairs for your decentralized E2EE communication."; font-size: 14px; color: AppTheme.text-tertiary; horizontal-alignment: center; wrap: word-wrap; }
                        }
                    }
                }
            }
        }
    }
}

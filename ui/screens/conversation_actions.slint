import { AppTheme } from "../theme.slint";
import { BaseScreen } from "../components/base_screen.slint";

export component ConversationActionsScreen inherits Rectangle {
    in property <bool> is-group: false;
    in property <string> title: "";
    in property <string> subtitle: "";
    in property <string> primary-id: "";
    in property <string> secondary-id: "";
    in property <string> initials: "";
    in property <string> connection-note: "";
    in property <bool> is-online: false;
    in property <bool> is-verified: false;
    in property <string> member-count: "";
    in property <bool> is-desktop: false;
    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback go-back();
    callback open-chat();
    callback retry-queued();
    callback request-clear-history();
    callback request-delete-conversation();

    BaseScreen {
        title: is-group ? "Group Info" : "Peer Info";
        is-desktop: root.is-desktop;
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom;
        go-back => { root.go-back(); }

        // --- Profile Hero ---
        VerticalLayout {
            spacing: AppTheme.sp-lg;
            alignment: center;

            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 100px; height: 100px;
                    border-radius: 50px;
                    background: is-group ? @linear-gradient(135deg, #FF9500 0%, #FFCC00 100%) : @linear-gradient(135deg, AppTheme.accent 0%, #0056b3 100%);
                    Text {
                        text: initials != "" ? initials : (is-group ? "👥" : "?");
                        font-size: 32px; font-weight: 800; color: #FFFFFF;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }
            }

            VerticalLayout {
                spacing: AppTheme.sp-xs;
                Text { text: title; font-size: 24px; font-weight: 900; color: #FFFFFF; horizontal-alignment: center; }
                Text { text: subtitle; font-size: 14px; font-weight: 600; color: AppTheme.text-tertiary; horizontal-alignment: center; }
            }
        }

        // --- Context Info ---
        Rectangle {
            background: AppTheme.surface-secondary;
            border-radius: AppTheme.radius-lg;

            VerticalLayout {
                padding: AppTheme.sp-md;
                spacing: AppTheme.sp-sm;
                Text { text: is-group ? "SECURE GROUP CHANNEL" : "P2P DIRECT ENCRYPTION"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                Text { text: connection-note; font-size: 14px; color: AppTheme.text-secondary; horizontal-alignment: center; }
            }
        }

        // --- Identity Tray ---
        VerticalLayout {
            spacing: AppTheme.sp-md;
            Text { text: is-group ? "GROUP IDENTIFIER" : "PEER IDENTIFIERS"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }

            Rectangle {
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;

                VerticalLayout {
                    padding: AppTheme.sp-md;
                    spacing: AppTheme.sp-lg;

                    VerticalLayout {
                        spacing: 4px;
                        Text { text: is-group ? "Group ID" : "Node ID"; font-size: 10px; font-weight: 700; color: AppTheme.text-tertiary; }
                        Text { text: primary-id; font-size: 12px; font-family: "monospace"; color: AppTheme.text-primary; wrap: word-wrap; }
                    }

                    if secondary-id != "": Rectangle { height: 1px; background: AppTheme.divider; }

                    if secondary-id != "": VerticalLayout {
                        spacing: 4px;
                        Text { text: "Secondary Handle"; font-size: 10px; font-weight: 700; color: AppTheme.text-tertiary; }
                        Text { text: secondary-id; font-size: 12px; font-family: "monospace"; color: AppTheme.text-primary; wrap: word-wrap; }
                    }
                }
            }
        }

        // --- Actions ---
        VerticalLayout {
            spacing: AppTheme.sp-md;
            Text { text: "MANAGEMENT"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }

            VerticalLayout {
                spacing: AppTheme.sp-md;

                Rectangle {
                    height: 56px; border-radius: 28px;
                    background: AppTheme.accent;
                    TouchArea {
                        clicked => { root.open-chat(); }
                        Text { text: "Return to Conversation"; font-size: 16px; font-weight: 800; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                Rectangle {
                    height: 56px; border-radius: 28px;
                    background: AppTheme.surface-secondary;
                    border-width: 1px; border-color: AppTheme.divider;
                    TouchArea {
                        clicked => { root.request-clear-history(); }
                        Text { text: "Clear Local History"; font-size: 16px; font-weight: 800; color: AppTheme.text-primary; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                Rectangle {
                    height: 56px; border-radius: 28px;
                    background: rgba(255, 69, 58, 0.1);
                    border-width: 1px; border-color: AppTheme.accent-danger;
                    TouchArea {
                        clicked => { root.request-delete-conversation(); }
                        Text { text: "Delete Stream Forever"; font-size: 16px; font-weight: 800; color: AppTheme.accent-danger; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }
    }
}

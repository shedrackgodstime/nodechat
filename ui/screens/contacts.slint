import { AppTheme } from "../theme.slint";
import { BaseScreen } from "../components/base_screen.slint";
import { ContactRow } from "../components/contact_row.slint";

export struct ContactData {
    id: string,
    name: string,
    initials: string,
    node-id: string,
    is-online: bool,
    is-relay: bool,
    is-verified: bool,
}

export component ContactsScreen inherits Rectangle {
    in property <[ContactData]> contacts: [];
    in property <bool>   is-desktop: false;
    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback go-back();
    callback open-contact(string, string, string, bool, bool, bool, bool);
    callback add-contact();
    callback new-group();

    BaseScreen {
        title: "Contacts";
        is-desktop: root.is-desktop;
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom;
        go-back => { root.go-back(); }

        // --- Quick Actions ---
        VerticalLayout {
            spacing: AppTheme.sp-md;
            Text {
                text: "QUICK ACTIONS";
                font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px;
            }

            Rectangle {
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;
                clip: true;

                VerticalLayout {
                    TouchArea {
                        height: 72px;
                        clicked => { root.add-contact(); }
                        HorizontalLayout {
                            padding: AppTheme.sp-md; spacing: AppTheme.sp-md; alignment: center;
                            Rectangle {
                                width: 44px; height: 44px; border-radius: 22px;
                                background: AppTheme.accent-soft;
                                Text { text: "+👤"; font-size: 18px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            Text { text: "Add Peer by Ticket"; font-size: 16px; font-weight: 600; color: AppTheme.accent; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: "›"; font-size: 24px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                        }
                    }

                    HorizontalLayout {
                        padding-left: 68px;
                        Rectangle { height: 1px; background: AppTheme.divider; }
                    }

                    TouchArea {
                        height: 72px;
                        clicked => { root.new-group(); }
                        HorizontalLayout {
                            padding: AppTheme.sp-md; spacing: AppTheme.sp-md; alignment: center;
                            Rectangle {
                                width: 44px; height: 44px; border-radius: 22px;
                                background: rgba(255, 149, 0, 0.15);
                                Text { text: "👥"; font-size: 18px; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            Text { text: "Start New Group"; font-size: 16px; font-weight: 600; color: #FF9500; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: "›"; font-size: 24px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                        }
                    }
                }
            }
        }

        // --- Directory ---
        VerticalLayout {
            spacing: AppTheme.sp-md;
            Text {
                text: "PEER DIRECTORY";
                font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px;
            }

            VerticalLayout {
                spacing: AppTheme.sp-xs;
                
                for contact[i] in contacts: ContactRow {
                    name:        contact.name;
                    initials:    contact.initials;
                    last-message: contact.node-id;
                    timestamp:   "";
                    is-online:   contact.is-online;
                    is-relay:    contact.is-relay;
                    is-verified: contact.is-verified;
                    clicked => {
                        root.open-contact(
                            contact.id,
                            contact.name,
                            contact.initials,
                            false,
                            contact.is-online,
                            contact.is-relay,
                            contact.is-verified,
                        );
                    }
                }

                if contacts.length == 0: Rectangle {
                    height: 200px;
                    border-radius: AppTheme.radius-lg;
                    background: AppTheme.surface-secondary;
                    
                    VerticalLayout {
                        alignment: center; spacing: AppTheme.sp-sm;
                        Text { text: "👤"; font-size: 32px; horizontal-alignment: center; }
                        Text { text: "No contacts found"; font-size: 16px; font-weight: 700; color: AppTheme.text-primary; horizontal-alignment: center; }
                        Text { text: "Your peer book is currently empty."; font-size: 13px; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                    }
                }
            }
        }
    }
}


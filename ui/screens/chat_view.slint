// Main messaging surface for direct and group conversations.


import { AppTheme, VertScroll } from "../theme.slint";
import { MessageBubble, MessageData } from "../components/message_bubble.slint";
import { Composer } from "../components/composer.slint";

export { MessageData }

export component ChatViewScreen inherits Rectangle {
    in property <bool> is-desktop: false;
    in property <string> peer-name: "Chat";
    in property <string> peer-initials: "?";
    in property <string> peer-node-id: "";
    in property <string> connection-mode: "direct"; // "direct" | "group"
    in property <bool> is-online: false;
    in property <bool> is-verified: false;
    in property <bool> is-relay: false;
    in property <string> connection-stage: "";
    in property <[MessageData]> messages: [];
    in property <length> virtual-keyboard-height: 0px;
    in property <length> safe-area-bottom: 0px;
    in property <bool> show-copied: false;

    callback go-back();
    callback send-message(string);
    callback open-contact-info();
    callback open-invite(string, string, string, bool);
    callback add-contact(string);
    callback retry-queued();
    callback request-delete-conversation();
    callback request-unfocus();
    callback copy-message(string);
    callback delete-message(string);

    background: AppTheme.surface-primary;

    // Keep the latest message visible whenever the viewport has overflow content.
    public function scroll-to-bottom() {
        if (msg-scroll.viewport-height > msg-scroll.height) {
            msg-scroll.viewport-y = msg-scroll.height - msg-scroll.viewport-height;
        }
    }

    changed messages => {
        root.scroll-to-bottom();
    }

    // Run one delayed scroll after entry so layout-dependent sizes are available.
    property <bool> entry-scroll-pending: true;
    Timer {
        interval: 50ms;
        running: root.entry-scroll-pending;
        triggered => {
            root.scroll-to-bottom();
            root.entry-scroll-pending = false;
        }
    }

    VerticalLayout {
        spacing: 0;

        Rectangle {
            height: 60px;
            background: AppTheme.surface-secondary;
            border-color: AppTheme.divider;

            HorizontalLayout {
                padding-left: AppTheme.sp-sm;
                padding-right: 2px; // Absolute far right
                spacing: AppTheme.sp-sm;
                alignment: stretch;

                TouchArea {
                    width: 44px;
                    clicked => {
                        root.go-back();
                    }

                    Text {
                        text: "←";
                        font-size: 22px;
                        color: AppTheme.text-primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 38px;
                    height: 38px;
                    y: (parent.height - self.height) / 2;

                    Rectangle {
                        width: 100%;
                        height: 100%;
                        border-radius: 19px;
                        background: AppTheme.accent-soft;

                        Text {
                            text: root.peer-initials;
                            font-size: 13px;
                            font-weight: 700;
                            color: AppTheme.accent;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        // Group conversations do not expose a single peer presence indicator.
                        if connection-mode != "group" && (is-online || is-relay): Rectangle {
                            width: 12px;
                            height: 12px;
                            border-radius: 6px;
                            background: is-relay ? AppTheme.accent-warning : AppTheme.accent-success;
                            border-color: AppTheme.surface-secondary;
                            border-width: 2px;
                            x: parent.width - self.width - 1px;
                            y: parent.height - self.height - 1px;
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    spacing: 1px;

                    HorizontalLayout {
                        spacing: AppTheme.sp-xs;

                        Text {
                            text: peer-name;
                            font-size: 16px;
                            font-weight: 700;
                            color: AppTheme.text-primary;
                            overflow: elide;
                        }
                    }

                    Text {
                        text: connection-mode == "group" ? "Group Conversation" : connection-stage != "" ? connection-stage : is-online ? (is-relay ? "via relay" : "direct") : "offline";
                        font-size: 12px;
                        color: connection-mode == "group" ? AppTheme.accent : is-online ? (is-relay ? AppTheme.accent-warning : AppTheme.accent-success) : AppTheme.text-tertiary;
                    }
                }

                TouchArea {
                    width: 44px;
                    clicked => {
                        root.open-contact-info();
                    }

                    Image {
                        source: @image-url("../../assets/icons/dots-vertical.svg");
                        width: 24px;
                        height: 24px;
                        colorize: AppTheme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: AppTheme.divider;
        }

        msg-scroll := VertScroll {
            vertical-stretch: 1;
            viewport-height: msg-list.preferred-height;

            // Tapping empty space should dismiss transient focus state in the composer.
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    root.request-unfocus();
                }
            }

            msg-list := VerticalLayout {
                width: parent.width;
                preferred-width: 100%;
                padding: AppTheme.sp-sm;
                spacing: AppTheme.sp-sm;
                
                // A flexible spacer bottom-aligns the thread without the cost of `alignment: end`.
                Rectangle {
                    vertical-stretch: 1;
                }

                if messages.length == 0: VerticalLayout {
                    alignment: center;
                    spacing: AppTheme.sp-md;
                    padding: AppTheme.sp-xl;

                    Text {
                        text: (connection-mode == "group") ? "👥" : "🔒";
                        font-size: 40px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: (connection-mode == "group") ? "Swarm Established" : "End-to-end encrypted";
                        font-size: 15px;
                        font-weight: 600;
                        color: AppTheme.text-primary;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: (connection-mode == "group") ? "This p2p group is ready. Tap the header to share the invite ticket with others!" : "Messages are encrypted in transit.\nSay hello!";
                        font-size: 13px;
                        color: AppTheme.text-secondary;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }

                for msg in root.messages: MessageBubble {
                    data: msg;
                    is-desktop: root.is-desktop;
                    is-group: root.connection-mode == "group";
                    open-invite(topic, name, key, joined) => {
                        root.open-invite(topic, name, key, joined);
                    }
                    add-contact(name, ticket) => {
                        root.add-contact(ticket);
                    }
                    copy-clicked(txt) => {
                        root.copy-message(txt);
                    }
                    delete-clicked(id) => {
                        root.delete-message(id);
                    }
                }

                // Preserve comfortable spacing above the composer and safe area inset.
                Rectangle {
                    height: 50px;
                }
            }
        }

        Composer {
            is-disabled: false;
            is-mobile: !root.is-desktop;
            safe-area-bottom: root.safe-area-bottom;
            placeholder: "Message...";
            send-message(msg) => {
                root.send-message(msg);
                // Follow the newly sent message immediately after the draft clears.
                root.scroll-to-bottom();
            }
        }
    }

    if root.show-copied: Rectangle {
        background: AppTheme.accent-success;
        y: 80px;
        width: 140px;
        height: 32px;
        border-radius: 16px;
        x: (parent.width - self.width) / 2;
        Text {
            text: "Copied ✅";
            color: #FFFFFF;
            font-size: 13px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

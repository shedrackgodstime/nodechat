import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { MessageBubble, MessageData } from "../components/message_bubble.slint";
export { MessageData }
import { ChatInput } from "../components/chat_input.slint";

export component ChatViewScreen inherits Rectangle {
    in property <string> peer-name: "";
    in property <string> peer-initials: "";
    in property <string> peer-node-id: "";
    in property <string> connection-mode: "direct";
    in property <bool> is-verified: false;
    in property <bool> is-online: false;
    in property <bool> is-desktop: false;
    in property <string> connection-stage: "";
    in property <[MessageData]> messages: [];

    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;
    in property <length> virtual-keyboard-height: 0px;

    callback go-back();
    callback send-message(string);
    callback open-contact-info();
    callback open-group(string, string, string, bool);
    callback request-delete-conversation();
    callback retry-queued();

    background: AppTheme.surface-primary; 

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // --- Premium Chat Header ---
        Rectangle {
            height: (is-desktop ? 72px : 86px) + root.safe-area-top;
            background: AppTheme.surface-primary;
            
            HorizontalLayout {
                padding-top: root.safe-area-top;
                padding-left: AppTheme.sp-lg;
                padding-right: AppTheme.sp-lg;
                spacing: AppTheme.sp-md;

                if !is-desktop: VerticalLayout {
                    alignment: center;
                    TouchArea {
                        width: 40px; height: 40px;
                        clicked => { root.go-back(); }
                        Text { text: "←"; font-size: 24px; color: AppTheme.accent; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    TouchArea {
                        width: 48px; height: 48px;
                        clicked => { root.open-contact-info(); }
                        Rectangle {
                            width: 48px; height: 48px;
                            border-radius: 24px;
                            background: @linear-gradient(135deg, AppTheme.accent 0%, #0056b3 100%);
                            Text {
                                text: peer-initials != "" ? peer-initials : "?";
                                font-size: 16px; font-weight: 800; color: #FFFFFF;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 2px;
                    HorizontalLayout {
                        spacing: AppTheme.sp-xs;
                        alignment: start;
                        Text {
                            text: peer-name;
                            font-size: 18px; font-weight: 700;
                            color: AppTheme.text-primary;
                            overflow: elide;
                        }
                        if is-verified: Text { text: "✅"; font-size: 12px; vertical-alignment: center; }
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 8px; height: 8px;
                                border-radius: 4px;
                                background: is-online ? AppTheme.accent-success : AppTheme.text-tertiary;
                            }
                        }
                        Text {
                            text: is-online ? "Connected via " + connection-mode : "Offline";
                            font-size: 12px;
                            color: AppTheme.text-tertiary;
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;
                    TouchArea {
                        width: 44px; height: 44px;
                        clicked => { root.open-contact-info(); }
                        Text { text: "⋮"; font-size: 24px; color: AppTheme.text-tertiary; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }

            Rectangle {
                y: parent.height - 1px;
                width: 100%; height: 1px;
                background: AppTheme.divider; 
            }
        }

        // --- Connection Status Bar ---
        if !is-verified || connection-mode == "relay": Rectangle {
            height: 32px;
            background: connection-mode == "relay" ? AppTheme.accent-warning : AppTheme.accent-soft;
            Text {
                text: connection-mode == "relay" ? "⚠️ Relay path: Messages are encrypted but slow." : "🔒 Identity verification pending.";
                font-size: 11px; font-weight: 700; color: connection-mode == "relay" ? #1B1B1B : AppTheme.accent;
                horizontal-alignment: center; vertical-alignment: center;
            }
        }

        // --- Messages Scroll Area ---
        Rectangle {
            vertical-stretch: 1;
            clip: true;

            ScrollView {
                VerticalLayout {
                    padding-top: AppTheme.sp-lg;
                    padding-bottom: AppTheme.sp-lg;
                    
                    HorizontalLayout {
                        VerticalLayout {
                            horizontal-stretch: 1;
                            padding: AppTheme.sp-md;
                            spacing: AppTheme.sp-md;
                            alignment: start;

                            for msg[i] in messages: MessageBubble {
                                text:         msg.text;
                                timestamp:    msg.timestamp;
                                is-mine:      msg.is-mine;
                                status:       msg.status;
                                is-ephemeral: msg.is-ephemeral;
                                ttl-seconds:  msg.ttl-seconds;
                                is-group-invite: msg.is-group-invite;
                                invite-group-name: msg.invite-group-name;
                                invite-topic-id: msg.invite-topic-id;
                                invite-key: msg.invite-key;
                                invite-is-joined: msg.invite-is-joined;
                                open-group(topic, name, key, joined) => { root.open-group(topic, name, key, joined); }
                            }
                        }
                    }
                }
            }
        }

        // --- Composer / Input Bar ---
        Rectangle {
            background: AppTheme.surface-primary;
            
            VerticalLayout {
                padding-bottom: Math.max(root.safe-area-bottom, virtual-keyboard-height);
                animate padding-bottom { duration: AppTheme.dur-short; }
                
                Rectangle {
                    height: 1px;
                    background: AppTheme.divider;
                }

                HorizontalLayout {
                    VerticalLayout {
                        horizontal-stretch: 1;
                        padding: AppTheme.sp-md;
                        ChatInput {
                            is-mobile: !is-desktop;
                            send-message(msg) => { root.send-message(msg); }
                        }
                    }
                }
            }
        }
    }
}

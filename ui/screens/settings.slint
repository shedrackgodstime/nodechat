import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { AppHeader } from "../components/app_header.slint";

export component SettingsScreen inherits Rectangle {
    in property <string> display-name: "Shedrack G.";
    in property <string> node-id: "nBq3p6X…Kx7R";
    in property <string> endpoint-ticket: "";
    in property <int>    direct-peers: 8;
    in property <int>    relay-peers: 1;
    in property <bool>   is-desktop: false;

    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback go-back();
    callback edit-display-name();
    callback copy-node-id();
    callback show-node-id-qr();
    callback change-password();
    callback clear-messages();
    callback delete-identity();

    background: AppTheme.surface-primary;

    VerticalLayout {
        padding: 0;
        spacing: 0;

        AppHeader {
            is-desktop: root.is-desktop;
            safe-area-top: root.safe-area-top;
            show-back: true;
            title: "Settings";
            go-back => { root.go-back(); }
        }

        ScrollView {
            vertical-stretch: 1;
            mouse-drag-pan-enabled: true;

            HorizontalLayout {
                alignment: start;
                padding-left: is-desktop ? 0px : 16px;
                padding-right: is-desktop ? 0px : 16px;

                VerticalLayout {
                    width: is-desktop ? 760px : root.width - 32px;
                    horizontal-stretch: 1;
                    padding-top: 24px;
                    padding-bottom: 24px;
                    spacing: 16px;
                    alignment: start;

                    copy-input := TextInput { width: 0px; height: 0px; opacity: 0; }

                    HorizontalLayout {
                        spacing: 16px;
                        alignment: start;

                        Rectangle {
                            width: 58px;
                            height: 58px;
                            border-radius: 29px;
                            background: AppTheme.accent;
                            Text {
                                text: "SG";
                                font-size: 20px;
                                font-weight: 800;
                                color: #FFFFFF;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: display-name;
                                font-size: 18px;
                                font-weight: 700;
                                color: AppTheme.text-primary;
                            }
                            Text {
                                text: "Public Decentralized Profile";
                                font-size: 12px;
                                color: AppTheme.text-tertiary;
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "MESSAGING & PRIVACY";
                            font-size: 11px;
                            font-weight: 800;
                            color: AppTheme.text-tertiary;
                            letter-spacing: 0.8px;
                        }

                        TouchArea {
                            height: 60px;
                            clicked => { root.edit-display-name(); }
                            HorizontalLayout {
                                padding-left: 0px;
                                padding-right: 0px;
                                alignment: center;
                                spacing: 14px;
                                Text { text: "👤"; font-size: 18px; vertical-alignment: center; }
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    alignment: center;
                                    Text {
                                        text: "Profile Display Name";
                                        font-size: 15px;
                                        font-weight: 600;
                                        color: AppTheme.text-primary;
                                    }
                                    Text {
                                        text: "Update how you appear to others";
                                        font-size: 11px;
                                        color: AppTheme.text-tertiary;
                                    }
                                }
                                Text {
                                    text: "›";
                                    font-size: 20px;
                                    color: AppTheme.text-tertiary;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle { height: 1px; background: AppTheme.divider; opacity: 0.4; }

                        node-id-touch := TouchArea {
                            min-height: 60px;
                            property <bool> copied: false;
                            clicked => {
                                copy-input.text = endpoint-ticket;
                                copy-input.select-all();
                                copy-input.copy();
                                copy-input.clear-selection();
                                self.copied = true;
                                root.copy-node-id();
                            }

                            Timer {
                                interval: 2s;
                                running: node-id-touch.copied;
                                triggered => { node-id-touch.copied = false; }
                            }

                            HorizontalLayout {
                                padding-left: 0px;
                                padding-right: 0px;
                                alignment: center;
                                spacing: 14px;
                                Text { text: "🔑"; font-size: 18px; vertical-alignment: center; }
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    alignment: center;
                                    Text {
                                        text: "Shareable Endpoint Ticket";
                                        font-size: 15px;
                                        font-weight: 600;
                                        color: AppTheme.text-primary;
                                    }
                                    Text {
                                        text: endpoint-ticket;
                                        font-size: 11px;
                                        color: AppTheme.text-tertiary;
                                        font-family: "monospace";
                                        wrap: word-wrap;
                                    }
                                }
                                Text {
                                    text: node-id-touch.copied ? "✅" : "📋";
                                    font-size: 16px;
                                    color: node-id-touch.copied ? #25D366 : AppTheme.accent;
                                    vertical-alignment: center;
                                    animate color { duration: 150ms; }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "DANGER ZONE";
                            font-size: 11px;
                            font-weight: 800;
                            color: AppTheme.accent-danger;
                            letter-spacing: 0.8px;
                        }

                        TouchArea {
                            height: 60px;
                            clicked => { root.clear-messages(); }
                            HorizontalLayout {
                                padding-left: 0px;
                                padding-right: 0px;
                                alignment: center;
                                spacing: 14px;
                                Text { text: "♻️"; font-size: 18px; vertical-alignment: center; }
                                Text {
                                    text: "Clear Local Message Store";
                                    font-size: 15px;
                                    font-weight: 600;
                                    color: AppTheme.accent-danger;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text { text: "›"; font-size: 20px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                            }
                        }

                        Rectangle { height: 1px; background: AppTheme.divider; opacity: 0.4; }

                        TouchArea {
                            height: 60px;
                            clicked => { root.delete-identity(); }
                            HorizontalLayout {
                                padding-left: 0px;
                                padding-right: 0px;
                                alignment: center;
                                spacing: 14px;
                                Text { text: "⚠️"; font-size: 18px; vertical-alignment: center; }
                                Text {
                                    text: "Reset Local Identity";
                                    font-size: 15px;
                                    font-weight: 600;
                                    color: AppTheme.accent-danger;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text { text: "›"; font-size: 20px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                            }
                        }
                    }

                    VerticalLayout {
                        padding-top: 12px;
                        padding-bottom: 32px;
                        spacing: 4px;
                        alignment: center;
                        Text {
                            text: "NodeChat v1.2.0-beta";
                            font-size: 11px;
                            font-weight: 800;
                            color: AppTheme.text-tertiary;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Secured by Iroh & Pkarr Protocols";
                            font-size: 10px;
                            font-weight: 600;
                            color: #555555;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

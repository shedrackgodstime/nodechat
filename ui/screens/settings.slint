import { AppTheme } from "../theme.slint";
import { BaseScreen } from "../components/base_screen.slint";

export component SettingsScreen inherits Rectangle {
    in property <string> display-name: "Shedrack G.";
    in property <string> node-id: "nBq3p6X…Kx7R";
    in property <string> endpoint-ticket: "";
    in property <int>    direct-peers: 8;
    in property <int>    relay-peers: 1;
    in property <bool>   is-desktop: false;

    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback go-back();
    callback edit-display-name();
    callback copy-node-id();
    callback show-node-id-qr();
    callback change-password();
    callback clear-messages();
    callback delete-identity();

    BaseScreen {
        title: "Settings";
        is-desktop: root.is-desktop;
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom;
        go-back => { root.go-back(); }

        // --- Profile Section ---
        Rectangle {
            background: AppTheme.surface-secondary;
            border-radius: AppTheme.radius-lg;
            
            HorizontalLayout {
                padding: AppTheme.sp-lg;
                spacing: AppTheme.sp-lg;
                alignment: start;

                Rectangle {
                    width: 72px; height: 72px;
                    border-radius: 36px;
                    background: @linear-gradient(135deg, AppTheme.accent 0%, #0056b3 100%);
                    Text {
                        text: "SG";
                        font-size: 24px; font-weight: 800; color: #FFFFFF;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    spacing: AppTheme.sp-xs;
                    Text {
                        text: display-name;
                        font-size: 20px; font-weight: 700; color: AppTheme.text-primary;
                    }
                    Text {
                        text: "Decentralized Node Identity";
                        font-size: 13px; color: AppTheme.text-tertiary;
                    }
                }
            }
        }

        // --- Messaging & Privacy ---
        VerticalLayout {
            spacing: AppTheme.sp-md;
            Text {
                text: "MESSAGING & PRIVACY";
                font-size: 12px; font-weight: 800; color: AppTheme.text-tertiary;
                letter-spacing: 1px;
            }

            Rectangle {
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;
                clip: true;

                VerticalLayout {
                    TouchArea {
                        height: 72px;
                        clicked => { root.edit-display-name(); }
                        HorizontalLayout {
                            padding: AppTheme.sp-md; spacing: AppTheme.sp-md; alignment: center;
                            Text { text: "👤"; font-size: 20px; vertical-alignment: center; }
                            VerticalLayout {
                                horizontal-stretch: 1; alignment: center;
                                Text { text: "Profile Name"; font-size: 16px; font-weight: 600; color: AppTheme.text-primary; }
                                Text { text: "Change how you appear to others"; font-size: 12px; color: AppTheme.text-tertiary; }
                            }
                            Text { text: "›"; font-size: 24px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                        }
                    }

                    HorizontalLayout {
                        padding-left: 56px;
                        Rectangle { height: 1px; background: AppTheme.divider; }
                    }

                    node-id-touch := TouchArea {
                        min-height: 72px;
                        property <bool> copied: false;
                        clicked => {
                            root.copy-node-id();
                            self.copied = true;
                        }
                        Timer {
                            interval: 2s;
                            running: node-id-touch.copied;
                            triggered => { node-id-touch.copied = false; }
                        }
                        HorizontalLayout {
                            padding: AppTheme.sp-md; spacing: AppTheme.sp-md; alignment: center;
                            Text { text: "🔑"; font-size: 20px; vertical-alignment: center; }
                            VerticalLayout {
                                horizontal-stretch: 1; alignment: center;
                                Text { text: "Node ID / Ticket"; font-size: 16px; font-weight: 600; color: AppTheme.text-primary; }
                                Text {
                                    text: endpoint-ticket;
                                    font-size: 11px; color: AppTheme.text-tertiary;
                                    font-family: "monospace"; wrap: word-wrap;
                                }
                            }
                            Text {
                                text: node-id-touch.copied ? "✅" : "📋";
                                font-size: 18px; color: node-id-touch.copied ? AppTheme.accent-success : AppTheme.accent;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // --- Danger Zone ---
        VerticalLayout {
            spacing: AppTheme.sp-md;
            Text {
                text: "DANGER ZONE";
                font-size: 12px; font-weight: 800; color: AppTheme.accent-danger;
                letter-spacing: 1px;
            }

            Rectangle {
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;
                clip: true;

                VerticalLayout {
                    TouchArea {
                        height: 64px;
                        clicked => { root.clear-messages(); }
                        HorizontalLayout {
                            padding: AppTheme.sp-md; spacing: AppTheme.sp-md; alignment: center;
                            Text { text: "♻️"; font-size: 18px; vertical-alignment: center; }
                            Text { text: "Clear Message History"; font-size: 15px; font-weight: 600; color: AppTheme.accent-danger; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: "›"; font-size: 20px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                        }
                    }

                    HorizontalLayout {
                        padding-left: 56px;
                        Rectangle { height: 1px; background: AppTheme.divider; }
                    }

                    TouchArea {
                        height: 64px;
                        clicked => { root.delete-identity(); }
                        HorizontalLayout {
                            padding: AppTheme.sp-md; spacing: AppTheme.sp-md; alignment: center;
                            Text { text: "⚠️"; font-size: 18px; vertical-alignment: center; }
                            Text { text: "Reset Application Data"; font-size: 15px; font-weight: 600; color: AppTheme.accent-danger; horizontal-stretch: 1; vertical-alignment: center; }
                            Text { text: "›"; font-size: 20px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                        }
                    }
                }
            }
        }
    }
}


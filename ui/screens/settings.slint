import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";

// SettingsScreen — Pro Immersive Settings UI (Desktop-Adaptive)
// Stabilized with root.width bindings to prevent viewport-width loops.

export component SettingsScreen inherits Rectangle {
    in property <string> display-name: "Shedrack G.";
    in property <string> node-id: "nBq3p6X…Kx7R";
    in property <int>    direct-peers: 8;
    in property <int>    relay-peers: 1;
    in property <bool>   is-desktop: false;

    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback go-back();
    callback edit-display-name();
    callback copy-node-id();
    callback show-node-id-qr();
    callback change-password();
    callback clear-messages();
    callback delete-identity();

    background: AppTheme.surface-primary;

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // --- Pro Immersive Header (Adaptive Height) ────────────────
        Rectangle {
            height: (is-desktop ? 64px : 72px) + root.safe-area-top;
            background: AppTheme.surface-secondary;
            border-width: 0;
            
            Rectangle {
                y: parent.height - 1px;
                width: 100%; height: 1px;
                background: AppTheme.divider; 
            }

            HorizontalLayout {
                y: root.safe-area-top;
                height: is-desktop ? 64px : 72px;
                padding-left: 12px;
                padding-right: 16px;
                alignment: space-between;

                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;

                    if !is-desktop: VerticalLayout {
                        alignment: center;
                        TouchArea {
                            width: 32px; height: 32px;
                            clicked => { root.go-back(); }
                            Text { text: "←"; font-size: 22px; color: AppTheme.accent; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "Settings";
                            font-size: 18px; font-weight: 700;
                            color: AppTheme.text-primary;
                            vertical-alignment: center;
                        }
                    }
                }

                if is-desktop: VerticalLayout {
                    alignment: center;
                    TouchArea {
                        width: 44px; height: 44px;
                        clicked => { root.go-back(); }
                        Text { text: "✕"; font-size: 20px; color: AppTheme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }

        // --- Scrollable Content (Adaptive Stability Fix) ─────────────────────────
        ScrollView {
            vertical-stretch: 1;
            mouse-drag-pan-enabled: true;

            HorizontalLayout {
                alignment: center; // Match the ChatView's centered alignment pattern
                
                VerticalLayout {
                    max-width: 1200px;
                    horizontal-stretch: 1;
                    padding: 16px;
                    padding-left: is-desktop ? 32px : 16px;
                    padding-right: is-desktop ? 32px : 16px;
                    padding-top: 24px;
                    spacing: 14px;
                    alignment: start;

                    // Hidden input for native clipboard operations
                    copy-input := TextInput { width: 0px; height: 0px; opacity: 0; }

                    // --- PROFILE SPOTLIGHT CARD ---
                    Rectangle {
                        height: 90px;
                        background: AppTheme.surface-secondary;
                        border-radius: 18px;
                        
                        HorizontalLayout {
                            padding: 16px;
                            spacing: 16px;
                            alignment: start;

                            Rectangle {
                                width: 58px; height: 58px;
                                border-radius: 29px;
                                background: AppTheme.accent;
                                Text { text: "SG"; font-size: 20px; font-weight: 800; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                Text { text: display-name; font-size: 18px; font-weight: 700; color: AppTheme.text-primary; }
                                Text { text: "Public Decentralized Profile"; font-size: 12px; color: AppTheme.text-tertiary; }
                            }
                        }
                    }

                    // --- SECTION: MESSAGING & PRIVACY ---
                    VerticalLayout {
                        spacing: 12px;
                        VerticalLayout {
                            padding-left: 8px;
                            Text { text: "MESSAGING & PRIVACY"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 0.8px; }
                        }
                        
                        Rectangle {
                            border-radius: 18px;
                            background: AppTheme.surface-secondary;
                            clip: true;
                            
                            VerticalLayout {
                                TouchArea {
                                    height: 60px;
                                    clicked => { root.edit-display-name(); }
                                    HorizontalLayout {
                                        padding-left: 16px; padding-right: 16px; alignment: center; spacing: 14px;
                                        Text { text: "👤"; font-size: 18px; vertical-alignment: center; }
                                        VerticalLayout {
                                            horizontal-stretch: 1; alignment: center;
                                            Text { text: "Profile Display Name"; font-size: 15px; font-weight: 600; color: AppTheme.text-primary; }
                                            Text { text: "Update how you appear to others"; font-size: 11px; color: AppTheme.text-tertiary; }
                                        }
                                        Text { text: "›"; font-size: 20px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                                    }
                                }

                                Rectangle { height: 1px; background: AppTheme.divider; opacity: 0.4; }

                                node-id-touch := TouchArea {
                                    min-height: 60px;
                                    property <bool> copied: false;
                                    clicked => { 
                                        // Use native Slint copy mechanism (official doc approach)
                                        copy-input.text = node-id;
                                        copy-input.select-all();
                                        copy-input.copy();
                                        copy-input.clear-selection();
                                        
                                        // Visual feedback
                                        self.copied = true;
                                        root.copy-node-id(); // notify Rust
                                    }
                                    
                                    Timer {
                                        interval: 2s;
                                        running: node-id-touch.copied;
                                        triggered => { node-id-touch.copied = false; }
                                    }

                                    HorizontalLayout {
                                        padding-left: 16px; padding-right: 16px; alignment: center; spacing: 14px;
                                        Text { text: "🔑"; font-size: 18px; vertical-alignment: center; }
                                        VerticalLayout {
                                            horizontal-stretch: 1; alignment: center;
                                            Text { text: "Private Node Identifier"; font-size: 15px; font-weight: 600; color: AppTheme.text-primary; }
                                            Text { 
                                                text: node-id; 
                                                font-size: 11px; 
                                                color: AppTheme.text-tertiary; 
                                                font-family: "monospace"; 
                                                wrap: word-wrap;
                                            }
                                        }
                                        Text { 
                                            text: node-id-touch.copied ? "✅" : "📋"; 
                                            font-size: 16px; 
                                            color: node-id-touch.copied ? #25D366 : AppTheme.accent; 
                                            vertical-alignment: center; 
                                            animate color { duration: 150ms; }
                                        }
                                    }
                                }

                                Rectangle { height: 1px; background: AppTheme.divider; opacity: 0.4; }

                                TouchArea {
                                    height: 60px;
                                    clicked => { root.change-password(); }
                                    HorizontalLayout {
                                        padding-left: 16px; padding-right: 16px; alignment: center; spacing: 14px;
                                        Text { text: "🔒"; font-size: 18px; vertical-alignment: center; }
                                        VerticalLayout {
                                            horizontal-stretch: 1; alignment: center;
                                            Text { text: "App Lock Password"; font-size: 15px; font-weight: 600; color: AppTheme.text-primary; }
                                            Text { text: "Secure access to your local store"; font-size: 11px; color: AppTheme.text-tertiary; }
                                        }
                                        Text { text: "›"; font-size: 20px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                                    }
                                }
                            }
                        }
                    }

                    // --- SECTION: DANGER ZONE ---
                    VerticalLayout {
                        spacing: 12px;
                        VerticalLayout {
                            padding-left: 8px;
                            Text { text: "DANGER ZONE"; font-size: 11px; font-weight: 800; color: AppTheme.accent-danger; letter-spacing: 0.8px; }
                        }
                        
                        Rectangle {
                            border-radius: 18px;
                            background: AppTheme.surface-secondary;
                            clip: true;

                            VerticalLayout {
                                TouchArea {
                                    height: 60px;
                                    clicked => { root.clear-messages(); }
                                    HorizontalLayout {
                                        padding-left: 16px; padding-right: 16px; alignment: center; spacing: 14px;
                                        Text { text: "♻️"; font-size: 18px; vertical-alignment: center; }
                                        Text { text: "Clear Local Message Store"; font-size: 15px; font-weight: 600; color: AppTheme.accent-danger; horizontal-stretch: 1; vertical-alignment: center; }
                                        Text { text: "›"; font-size: 20px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                                    }
                                }

                                Rectangle { height: 1px; background: AppTheme.divider; opacity: 0.4; }

                                TouchArea {
                                    height: 60px;
                                    clicked => { root.delete-identity(); }
                                    HorizontalLayout {
                                        padding-left: 16px; padding-right: 16px; alignment: center; spacing: 14px;
                                        Text { text: "⚠️"; font-size: 18px; vertical-alignment: center; }
                                        Text { text: "Erase P2P Node Identity"; font-size: 15px; font-weight: 600; color: AppTheme.accent-danger; horizontal-stretch: 1; vertical-alignment: center; }
                                        Text { text: "›"; font-size: 20px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                                    }
                                }
                            }
                        }
                    }
                    
                    VerticalLayout {
                        padding-top: 12px; padding-bottom: 32px; spacing: 4px; alignment: center;
                        Text {
                            text: "NodeChat v1.2.0-beta";
                            font-size: 11px; font-weight: 800;
                            color: AppTheme.text-tertiary; horizontal-alignment: center;
                        }
                        Text {
                            text: "Secured by Iroh & Pkarr Protocols";
                            font-size: 10px; font-weight: 600;
                            color: #555555; horizontal-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

import { AppTheme } from "../theme.slint";
import { BaseScreen } from "../components/base_screen.slint";
import { ScrollView } from "std-widgets.slint";

export struct LogEntry {
    level: string,
    timestamp: string,
    message: string,
}

export component DiagnosticsScreen inherits Rectangle {
    in property <string> node-id: "";
    in property <string> relay-url: "";
    in property <int>    direct-peers: 0;
    in property <int>    relay-peers: 0;
    in property <[LogEntry]> logs: [];
    in property <bool>   is-desktop: false;
    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback go-back();
    callback clear-logs();

    BaseScreen {
        title: "Debug Console";
        is-desktop: root.is-desktop;
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom;
        go-back => { root.go-back(); }

        VerticalLayout {
            spacing: AppTheme.sp-lg;
            padding-top: AppTheme.sp-md;

            // --- Network Stats Card ---
            Rectangle {
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;
                height: 140px;
                VerticalLayout {
                    padding: AppTheme.sp-md; spacing: 8px;
                    alignment: center;
                    
                    HorizontalLayout {
                        alignment: space-between;
                        Text { text: "Node ID"; font-size: 11px; font-weight: 700; color: AppTheme.text-tertiary; }
                        Text { text: node-id; font-size: 11px; font-family: "monospace"; color: AppTheme.accent; wrap: char-wrap; horizontal-stretch: 1; horizontal-alignment: right; }
                    }
                    Rectangle { height: 1px; background: AppTheme.divider; }
                    HorizontalLayout {
                        alignment: space-between;
                        Text { text: "Relay URL"; font-size: 11px; font-weight: 700; color: AppTheme.text-tertiary; }
                        Text { text: relay-url == "" ? "Not connected" : relay-url; font-size: 11px; color: AppTheme.text-primary; }
                    }
                    Rectangle { height: 1px; background: AppTheme.divider; }
                    HorizontalLayout {
                        spacing: 20px;
                        HorizontalLayout { spacing: 6px; Text { text: "Direct:"; font-size: 11px; color: AppTheme.text-tertiary; } Text { text: direct-peers; font-size: 11px; font-weight: 700; color: AppTheme.accent-success; } }
                        HorizontalLayout { spacing: 6px; Text { text: "Relay:"; font-size: 11px; color: AppTheme.text-tertiary; } Text { text: relay-peers; font-size: 11px; font-weight: 700; color: AppTheme.accent-warning; } }
                    }
                }
            }

            // --- Log Viewer ---
            HorizontalLayout {
                alignment: space-between;
                Text { text: "EVENT LOG (Last 50)"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                TouchArea {
                    clicked => { root.clear-logs(); }
                    Text { text: "CLEAR"; font-size: 11px; font-weight: 900; color: AppTheme.accent-danger; }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                background: #000000;
                border-radius: AppTheme.radius-md;
                border-width: 1px; border-color: AppTheme.divider;
                clip: true;

                ScrollView {
                    VerticalLayout {
                        padding: 8px; spacing: 4px;
                        for entry in logs: HorizontalLayout {
                            padding: 2px;
                            spacing: 8px;
                            Text { text: entry.timestamp; font-size: 9px; font-family: "monospace"; color: #555; vertical-alignment: center; }
                            Text {
                                text: entry.level;
                                font-size: 9px; font-weight: 900;
                                color: entry.level == "ERROR" ? #FF453A : (entry.level == "WARN" ? #FF9F0A : #30D158);
                                vertical-alignment: center;
                            }
                            Text {
                                text: entry.message;
                                font-size: 11px; font-family: "monospace";
                                color: #DDD; wrap: word-wrap; horizontal-stretch: 1;
                            }
                        }
                    }
                }
            }
        }
    }
}

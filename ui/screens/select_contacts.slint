// Contact-selection screen used for group creation, invites, and sharing flows.

import { AppTheme, VertScroll } from "../theme.slint";
import { ActionRow } from "../components/action_row.slint";
import { GroupCandidateItem } from "../components/row_data.slint";

export component SelectContactsScreen inherits Rectangle {
    in property <[GroupCandidateItem]> contacts: [];
    in property <bool> is-desktop: false;
    in property <string> group-name: "";
    in property <int> return-screen: 10;
    
    in property <int> selected-count: 0;
    in property <string> active-intent: "create"; // "create", "invite", "share"

    callback back-clicked();
    callback toggled(string); 
    callback create-clicked(); 

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // Header
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;
            
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { text: "←"; font-size: 24px; color: AppTheme.text-primary; vertical-alignment: center; }
                }

                VerticalLayout {
                    alignment: center;
                    Text { 
                        text: root.active-intent == "share" ? "Share Contact" : "Select Members"; 
                        font-size: is-desktop ? 24px : 18px; 
                        font-weight: 700; 
                        color: AppTheme.text-primary; 
                    }
                    Text { 
                        text: root.selected-count + " selected" + (root.active-intent == "create" ? "" : " • " + group-name); 
                        font-size: 13px; 
                        color: AppTheme.text-secondary; 
                    }
                }
            }
        }

        // List
        VertScroll {
            vertical-stretch: 1;
            viewport-height: list.preferred-height;

            list := VerticalLayout {
                width: parent.width;
                padding: AppTheme.sp-md;
                padding-top: AppTheme.sp-xl;
                spacing: AppTheme.sp-sm;
                alignment: start;

                Text { text: "CONTACTS"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1.5px; }

                VerticalLayout {
                    spacing: 4px;
                    for contact in root.contacts : ActionRow {
                        title: contact.display-name;
                        subtitle: contact.contact-id;
                        initials: contact.initials;
                        is-online: contact.is-online;
                        
                        accessory: "checkbox";
                        is-toggle-on: contact.is-selected;
                        
                        toggled(on) => {
                            root.toggled(contact.contact-id);
                        }
                    }
                }
                
                // Bottom spacing for FAB
                Rectangle { height: 100px; }
            }
        }
    }

    // 2. Floating Action Button (FAB)
    // We'll show the FAB always if we have a way to validate completion, 
    // or drive visibility from a "has-selection" property.
    Rectangle {
        x: parent.width - self.width - 24px;
        y: parent.height - self.height - 24px;
        width: 160px;
        height: 56px;
        border-radius: 28px;
        background: AppTheme.accent;
        visible: root.active-intent == "create" || root.selected-count > 0;
        
        // Shadow (Simulated)
        Rectangle {
            z: -1;
            x: 4px; y: 4px;
            width: 100%; height: 100%;
            border-radius: 28px;
            background: rgba(0, 122, 255, 0.3);
        }

        HorizontalLayout {
            alignment: center;
            spacing: AppTheme.sp-sm;
            
            Text {
                text: root.active-intent == "share" ? "Send (" + root.selected-count + ")" :
                      root.active-intent == "invite" ? "Invite (" + root.selected-count + ")" :
                      root.selected-count > 0 ? "Create & Invite (" + root.selected-count + ")" : "Create Group";
                font-size: 15px; font-weight: 700;
                color: #FFFFFF;
                vertical-alignment: center;
            }

            Image {
                source: @image-url("../../assets/icons/check.svg");
                width: 20px;
                height: 20px;
                colorize: #FFFFFF;
                vertical-alignment: center;
            }
        }

        TouchArea {
            clicked => { root.create-clicked(); }
        }

        // Animating entrance
        animate opacity { duration: 150ms; }
        animate y { duration: 250ms; easing: ease-out; }
    }
}

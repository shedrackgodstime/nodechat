// Settings screen for profile, security, diagnostics, and destructive actions.

import { AppTheme, VertScroll } from "../theme.slint";
import { ActionRow } from "../components/action_row.slint";
import { AppInfo } from "../components/row_data.slint";

export component SettingsScreen inherits Rectangle {
    in property <AppInfo> app-info;

    in property <string> display-name: "User";
    in property <string> initials: "U";
    in property <string> node-id: "";
    in property <string> endpoint-ticket: "";
    in property <bool> is-desktop: false;
    in property <bool> has-password: false;

    callback back-clicked();
    callback edit-display-name();
    callback copy-node-id();
    callback change-password();
    callback open-about();
    callback request-clear-history();
    callback request-reset-identity();

    background: AppTheme.surface-primary;
    
    in property <bool> show-copied: false;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // Header
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;
            
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { text: "←"; font-size: 24px; color: AppTheme.text-primary; vertical-alignment: center; }
                }

                VerticalLayout {
                    alignment: center;
                    Text { text: "Settings"; font-size: is-desktop ? 28px : 18px; font-weight: 700; color: AppTheme.text-primary; }
                    Text { text: "Manage your local identity and app security"; font-size: 13px; color: AppTheme.text-secondary; }
                }
            }
        }

        // Body
        VertScroll {
            vertical-stretch: 1;
            viewport-height: settings-body.preferred-height;

            settings-body := VerticalLayout {
                width: parent.width;
                padding: AppTheme.sp-md;
                padding-top: AppTheme.sp-md;
                spacing: AppTheme.sp-lg;
                alignment: start;

                // Profile summary
                Rectangle {
                    background: AppTheme.surface-secondary;
                    border-radius: AppTheme.radius-lg;
                    border-width: 1px;
                    border-color: AppTheme.divider;
                    
                    HorizontalLayout {
                        padding: AppTheme.sp-lg;
                        spacing: AppTheme.sp-lg;
                        alignment: start;

                        Rectangle {
                            width: 64px;
                            height: 64px;
                            border-radius: 32px;
                            background: AppTheme.accent;
                            Text { text: initials; font-size: 24px; font-weight: 800; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            Text { text: display-name; font-size: 20px; font-weight: 700; color: AppTheme.text-primary; }
                            Text { text: "Local identity configured"; font-size: 13px; color: AppTheme.text-secondary; }
                        }
                    }
                }

                // Identity and security actions
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "IDENTITY & SECURITY"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        clip: true;

                        VerticalLayout {
                            ActionRow {
                                icon: "👤";
                                title: "Display Name";
                                subtitle: "How others see you in chats";
                                clicked => { root.edit-display-name(); }
                            }
                            HorizontalLayout { padding-left: 56px; Rectangle { height: 1px; background: AppTheme.divider; } }
                            ActionRow {
                                icon: "🔑";
                                title: "My Connection Ticket";
                                subtitle: endpoint-ticket != "" ? endpoint-ticket : "Copy the ticket another peer can use to add you";
                                accessory: "copy";
                                show-copied: root.show-copied;
                                clicked => { 
                                    root.copy-node-id(); 
                                }
                            }
                            HorizontalLayout { padding-left: 56px; Rectangle { height: 1px; background: AppTheme.divider; } }
                            ActionRow {
                                icon: "🔐";
                                title: root.has-password ? "Change Password or PIN" : "Set Password or PIN";
                                subtitle: root.has-password ? "Update the local app lock" : "Enable an optional local app lock";
                                clicked => { root.change-password(); }
                            }
                        }
                    }
                }

                // About and diagnostics
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "INFO & SUPPORT"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        clip: true;

                        VerticalLayout {
                            ActionRow {
                                icon: "💬";
                                title: "About " + root.app-info.name;
                                subtitle: "Version, Diagnostics & Credits";
                                accessory: "arrow";
                                clicked => { root.open-about(); }
                            }
                        }
                    }
                }

                // Destructive actions
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "DANGER ZONE"; font-size: 11px; font-weight: 800; color: AppTheme.accent-danger; letter-spacing: 1px; }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        clip: true;

                        VerticalLayout {
                            ActionRow {
                                icon: "♻️";
                                title: "Clear Message History";
                                subtitle: "Delete all messages from this device";
                                is-danger: true;
                                clicked => { root.request-clear-history(); }
                            }
                            HorizontalLayout { padding-left: 56px; Rectangle { height: 1px; background: AppTheme.divider; } }
                            ActionRow {
                                icon: "⚠️";
                                title: "Reset Identity";
                                subtitle: "Permanently delete your identity & keys";
                                is-danger: true;
                                clicked => { root.request-reset-identity(); }
                            }
                        }
                    }
                }

                // Footer
                VerticalLayout {
                    padding-top: AppTheme.sp-lg;
                    Text {
                        text: root.app-info.name + " " + root.app-info.version;
                        font-size: 11px;
                        color: AppTheme.text-tertiary;
                        horizontal-alignment: center;
                        opacity: 0.5;
                    }
                }
            }
        }
    }
}

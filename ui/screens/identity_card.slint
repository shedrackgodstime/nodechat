import { AppTheme } from "../theme.slint";
import { BaseScreen } from "../components/base_screen.slint";

export component IdentityCardScreen inherits Rectangle {
    in property <string> display-name: "";
    in property <string> node-id: "";
    in property <string> endpoint-ticket: "";
    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback go-to-chats();
    callback copy-node-id();

    BaseScreen {
        title: "Your Identity";
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom;
        show-back-button: false;

        VerticalLayout {
            spacing: AppTheme.sp-xl;
            padding-top: AppTheme.sp-lg;

            // --- Success Message ---
            VerticalLayout {
                spacing: AppTheme.sp-sm;
                Text { text: "Welcome, " + display-name + "!"; font-size: 32px; font-weight: 900; color: #FFFFFF; horizontal-alignment: center; letter-spacing: -0.5px; }
                Text { text: "Your decentralized P2P vault is ready."; font-size: 16px; color: AppTheme.text-tertiary; horizontal-alignment: center; }
            }

            // --- The Identity Card ---
            Rectangle {
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;
                border-width: 1px;
                border-color: AppTheme.divider;
                
                VerticalLayout {
                    padding: AppTheme.sp-xl;
                    spacing: AppTheme.sp-xl;
                    alignment: center;

                    // Mock QR Area
                    Rectangle {
                        width: 180px; height: 180px;
                        background: #FFFFFF;
                        border-radius: AppTheme.radius-md;
                        
                        Text { text: "QR"; font-size: 48px; font-weight: 900; color: #000000; horizontal-alignment: center; vertical-alignment: center; }
                        
                        // Corner Accents
                        Rectangle { x: 0; y: 0; width: 40px; height: 4px; background: AppTheme.accent; border-radius: 2px; }
                        Rectangle { x: 0; y: 0; width: 4px; height: 40px; background: AppTheme.accent; border-radius: 2px; }
                    }

                    // Ticket Area
                    VerticalLayout {
                        spacing: AppTheme.sp-sm;
                        Text { text: "SHAREABLE PEER TICKET"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; horizontal-alignment: center; }
                        
                        Rectangle {
                            height: 52px;
                            background: AppTheme.surface-tertiary;
                            border-radius: AppTheme.radius-md;
                            
                            HorizontalLayout {
                                padding-left: AppTheme.sp-md; padding-right: AppTheme.sp-md; spacing: AppTheme.sp-md;
                                Text {
                                    text: endpoint-ticket;
                                    font-size: 13px; font-family: "monospace"; color: AppTheme.text-secondary;
                                    vertical-alignment: center; horizontal-stretch: 1; overflow: elide;
                                }

                                copy-area := TouchArea {
                                    width: 44px; height: 32px;
                                    clicked => { root.copy-node-id(); }
                                    Rectangle {
                                        background: copy-area.has-hover ? AppTheme.accent : AppTheme.surface-hover;
                                        border-radius: AppTheme.radius-sm;
                                        animate background { duration: AppTheme.dur-short; }
                                        Text { text: "📄"; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }

            // --- Final Action ---
            Rectangle {
                height: 60px;
                background: @linear-gradient(90deg, AppTheme.accent 0%, #0056B3 100%);
                border-radius: 30px;
                
                TouchArea {
                    clicked => { root.go-to-chats(); }
                    Text {
                        text: "Launch Conversations";
                        font-size: 18px; font-weight: 800;
                        color: #FFFFFF;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }
            }
        }
    }
}


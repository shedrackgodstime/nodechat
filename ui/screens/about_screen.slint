// About screen with project information and diagnostics access.

import { AppTheme, VertScroll } from "../theme.slint";
import { ActionRow } from "../components/action_row.slint";
import { AppInfo } from "../components/row_data.slint";
import { DebugView } from "../components/debug_view.slint";

export component AboutScreen inherits Rectangle {
    in property <AppInfo> app-info;
    in property <bool> is-desktop: false;
    
    // Toggles the diagnostics overlay.
    property <bool> show-debug: false;
    in property <bool> show-copied: false;
    in property <string> debug-logs: "[NodeChat] Waiting for events...";

    callback back-clicked();
    callback open-url(string);
    callback copy-logs(string);
    callback refresh-debug();
    callback request-unfocus();

    // Capture taps outside focused controls.
    TouchArea {
        width: 100%; height: 100%;
        clicked => { root.request-unfocus(); }
    }

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;
        opacity: root.show-debug ? 0 : 1;
        visible: self.opacity > 0;

        // Header
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => {
                        root.back-clicked();
                    }
                    Text {
                        text: "←";
                        font-size: 24px;
                        color: AppTheme.text-primary;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "About " + root.app-info.name;
                        font-size: is-desktop ? 28px : 18px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                    }

                    if is-desktop: Text {
                        text: "Project Information & Diagnostics";
                        font-size: 13px;
                        color: AppTheme.text-secondary;
                    }
                }
            }
        }

        // Body
        VertScroll {
            vertical-stretch: 1;
            viewport-height: about-body.preferred-height;

            about-body := VerticalLayout {
                width: parent.width;
                padding: AppTheme.sp-md;
                spacing: AppTheme.sp-lg;
                alignment: start;

                // App summary
                VerticalLayout {
                    spacing: AppTheme.sp-md;
                    padding-top: AppTheme.sp-lg;
                    padding-bottom: AppTheme.sp-lg;
                    Rectangle {
                        width: 280px;
                        height: 120px;
                        x: (parent.width - self.width) / 2;
                        Image {
                            source: @image-url("../../assets/images/app_logo_with_name_transparent_bg.png");
                            width: 100%;
                            height: 100%;
                            image-fit: contain;
                        }
                    }

                    VerticalLayout {
                        spacing: AppTheme.sp-xs;
                        Text {
                            text: root.app-info.version-type + " " + root.app-info.version;
                            font-size: 13px;
                            font-weight: 700;
                            color: AppTheme.accent;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: root.app-info.description;
                            font-size: 13px;
                            color: AppTheme.text-tertiary;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                }

                // Project context
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text {
                        text: "PROJECT";
                        font-size: 11px;
                        font-weight: 800;
                        color: AppTheme.text-tertiary;
                        letter-spacing: 1px;
                    }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        VerticalLayout {
                            padding: AppTheme.sp-lg;
                            spacing: AppTheme.sp-sm;
                            Text {
                                text: "Final Year Project";
                                font-size: 16px;
                                font-weight: 700;
                                color: AppTheme.text-primary;
                            }

                            Text {
                                text: "NodeChat is a final year software project focused on peer-to-peer messaging, local identity, encrypted transport, and a responsive native interface.";
                                font-size: 14px;
                                color: AppTheme.text-secondary;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // Links
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text {
                        text: "LINKS";
                        font-size: 11px;
                        font-weight: 800;
                        color: AppTheme.text-tertiary;
                        letter-spacing: 1px;
                    }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        VerticalLayout {
                            padding: AppTheme.sp-lg;
                            spacing: AppTheme.sp-md;

                            Text {
                                text: "Use these links to view the repository, project site, or report issues.";
                                font-size: 14px;
                                color: AppTheme.text-secondary;
                                wrap: word-wrap;
                            }

                            VerticalLayout {
                                spacing: 0;
                                ActionRow {
                                    icon-svg: @image-url("../../assets/icons/globe.svg");
                                    title: "Project Website";
                                    subtitle: "Open the public project site";
                                    accessory: "arrow";
                                    clicked => {
                                        root.open-url(root.app-info.website);
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: AppTheme.divider;
                                }

                                ActionRow {
                                    icon-svg: @image-url("../../assets/icons/github.svg");
                                    title: "Source Code";
                                    subtitle: "Open the project repository";
                                    accessory: "arrow";
                                    clicked => {
                                        root.open-url(root.app-info.repo);
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: AppTheme.divider;
                                }

                                ActionRow {
                                    icon-svg: @image-url("../../assets/icons/bug.svg");
                                    title: "Report an Issue";
                                    subtitle: "Open the repository issue tracker";
                                    accessory: "arrow";
                                    clicked => {
                                        root.open-url(root.app-info.repo + "/issues");
                                    }
                                }
                            }
                        }
                    }
                }

                // Technology summary
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text {
                        text: "TECHNOLOGY";
                        font-size: 11px;
                        font-weight: 800;
                        color: AppTheme.text-tertiary;
                        letter-spacing: 1px;
                    }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        VerticalLayout {
                            padding: AppTheme.sp-lg;
                            spacing: AppTheme.sp-md;

                            Text {
                                text: "The app combines a native Slint interface with Rust backend services for storage, networking, and encryption.";
                                font-size: 13px;
                                color: AppTheme.text-tertiary;
                                wrap: word-wrap;
                            }

                            VerticalLayout {
                                spacing: AppTheme.sp-sm;
                                VerticalLayout {
                                    spacing: AppTheme.sp-xs;
                                    HorizontalLayout {
                                        spacing: AppTheme.sp-sm;
                                        alignment: start;
                                        Text { text: "•"; font-size: 14px; color: AppTheme.accent; }
                                        Text { text: "Rust:"; font-size: 14px; font-weight: 700; color: AppTheme.text-primary; }
                                    }
                                    HorizontalLayout {
                                        padding-left: 18px;
                                        Text {
                                            text: "Core application language and runtime foundation.";
                                            font-size: 13px;
                                            color: AppTheme.text-secondary;
                                            wrap: word-wrap;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    spacing: AppTheme.sp-xs;
                                    HorizontalLayout {
                                        spacing: AppTheme.sp-sm;
                                        alignment: start;
                                        Text { text: "•"; font-size: 14px; color: AppTheme.accent; }
                                        Text { text: "Slint:"; font-size: 14px; font-weight: 700; color: AppTheme.text-primary; }
                                    }
                                    HorizontalLayout {
                                        padding-left: 18px;
                                        Text {
                                            text: "Native UI framework used for the desktop and mobile interface.";
                                            font-size: 13px;
                                            color: AppTheme.text-secondary;
                                            wrap: word-wrap;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    spacing: AppTheme.sp-xs;
                                    HorizontalLayout {
                                        spacing: AppTheme.sp-sm;
                                        alignment: start;
                                        Text { text: "•"; font-size: 14px; color: AppTheme.accent; }
                                        Text { text: "Iroh:"; font-size: 14px; font-weight: 700; color: AppTheme.text-primary; }
                                    }
                                    HorizontalLayout {
                                        padding-left: 18px;
                                        Text {
                                            text: "Peer-to-peer transport used for direct connectivity and group messaging.";
                                            font-size: 13px;
                                            color: AppTheme.text-secondary;
                                            wrap: word-wrap;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    spacing: AppTheme.sp-xs;
                                    HorizontalLayout {
                                        spacing: AppTheme.sp-sm;
                                        alignment: start;
                                        Text { text: "•"; font-size: 14px; color: AppTheme.accent; }
                                        Text { text: "SQLite (Rusqlite):"; font-size: 14px; font-weight: 700; color: AppTheme.text-primary; }
                                    }
                                    HorizontalLayout {
                                        padding-left: 18px;
                                        Text {
                                            text: "Local embedded storage for identity, contacts, and messages.";
                                            font-size: 13px;
                                            color: AppTheme.text-secondary;
                                            wrap: word-wrap;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    spacing: AppTheme.sp-xs;
                                    HorizontalLayout {
                                        spacing: AppTheme.sp-sm;
                                        alignment: start;
                                        Text { text: "•"; font-size: 14px; color: AppTheme.accent; }
                                        Text { text: "Tokio:"; font-size: 14px; font-weight: 700; color: AppTheme.text-primary; }
                                    }
                                    HorizontalLayout {
                                        padding-left: 18px;
                                        Text {
                                            text: "Asynchronous runtime used for background tasks and transport orchestration.";
                                            font-size: 13px;
                                            color: AppTheme.text-secondary;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Diagnostics
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text {
                        text: "DIAGNOSTICS";
                        font-size: 11px;
                        font-weight: 800;
                        color: AppTheme.text-tertiary;
                        letter-spacing: 1px;
                    }

                    VerticalLayout {
                        spacing: AppTheme.sp-md;
                        ActionRow {
                            icon-svg: @image-url("../../assets/icons/chart.svg");
                            title: "Debug Console";
                            subtitle: "View runtime logs and diagnostics";
                            accessory: "toggle";
                            is-toggle-on: root.show-debug;
                            toggled(on) => {
                                root.show-debug = on;
                            }
                        }
                    }
                }

                // Footer
                VerticalLayout {
                    padding-top: AppTheme.sp-xl;
                    padding-bottom: AppTheme.sp-xl;
                    spacing: AppTheme.sp-xs;
                    Text {
                        text: "© 2026 " + root.app-info.name + " Project";
                        font-size: 12px;
                        color: AppTheme.text-tertiary;
                        horizontal-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.open-url(root.app-info.repo);
                        }
                        mouse-cursor: pointer;
                        Text {
                            text: "View project repository";
                            font-size: 11px;
                            font-weight: 700;
                            color: AppTheme.accent; 
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // Full-screen debug overlay
    if root.show-debug : Rectangle {
        background: AppTheme.surface-primary;
        
        VerticalLayout {
            padding: AppTheme.sp-md;
            spacing: AppTheme.sp-md;

            HorizontalLayout {
                height: 44px;
                alignment: space-between;
                Text { 
                    text: "DIAGNOSTIC CONSOLE"; 
                    font-size: 14px; 
                    font-weight: 800; 
                    color: AppTheme.accent; 
                    vertical-alignment: center; 
                }
                TouchArea {
                    width: 44px; height: 44px;
                    clicked => { root.show-debug = false; }
                    Text { 
                        text: "✕"; 
                        font-size: 20px; 
                        color: AppTheme.text-secondary; 
                        horizontal-alignment: center; 
                        vertical-alignment: center; 
                    }
                }
            }

            DebugView {
                is-desktop: root.is-desktop;
                debug-logs: root.debug-logs;
                show-copied: root.show-copied;
                copy-clicked(logs) => { root.copy-logs(logs); }
                refresh-clicked => { root.refresh-debug(); }
            }

            Rectangle { height: 10px; }
        }
    }
}

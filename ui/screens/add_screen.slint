// Screen for adding a new peer by ticket or identifier.

import { AppTheme } from "../theme.slint";
import { Button } from "../components/button.slint";
import { FormInput } from "../components/form_input.slint";

export component AddScreen inherits Rectangle {
    in property <bool> is-desktop: false;
    
    in property <string> endpoint-ticket: "";
    
    callback back-clicked();
    callback add-ticket(string);
    callback copy-ticket(string);

    in property <bool> show-copied: false;
    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // Header
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;

            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { text: "←"; font-size: 24px; color: AppTheme.text-primary; vertical-alignment: center; }
                }

                VerticalLayout {
                    alignment: center;
                    Text { text: "Add Peer"; font-size: is-desktop ? 24px : 18px; font-weight: 700; color: AppTheme.text-primary; }
                    Text { text: "Add a peer by sharing a connection ticket"; font-size: 13px; color: AppTheme.text-secondary; }
                }
            }
        }

        // 2. Content
        VerticalLayout {
            padding: AppTheme.sp-lg;
            padding-top: AppTheme.sp-xl;
            spacing: AppTheme.sp-lg;

            VerticalLayout {
                spacing: AppTheme.sp-sm;
                Text { text: "PEER TICKET OR NODE ID"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1.5px; }
                input := FormInput {
                    placeholder: "Paste a peer ticket or node ID...";
                }
                Text { 
                    text: "Tickets are generated by your peer in their profile screen."; 
                    font-size: 11px; 
                    color: AppTheme.text-tertiary; 
                }
            }

            Button {
                text: "Add Peer to Contacts";
                kind: "primary";
                enabled: input.text != "";
                clicked => { root.add-ticket(input.text); }
            }

            HorizontalLayout {
                alignment: center;
                spacing: 4px;
                padding-top: AppTheme.sp-md;
                Text { text: "Want to be added instead?"; font-size: 13px; color: AppTheme.text-secondary; }
                TouchArea {
                    clicked => { 
                        root.copy-ticket(root.endpoint-ticket); 
                    }
                    Text { 
                        text: root.show-copied ? "COPIED ✅" : "Copy My Ticket"; 
                        font-size: 13px; 
                        font-weight: 700; 
                        color: root.show-copied ? AppTheme.accent-success : AppTheme.accent; 
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }
        }
    }
}

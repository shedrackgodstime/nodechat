import { AppTheme } from "../theme.slint";
import { ScrollView } from "std-widgets.slint";

// CreateGroupScreen — Group Creation Phase 2
// Final onboarding step for decentralized Gossip groups.

export component CreateGroupScreen inherits Rectangle {
    in-out property <string> group-name-input: "";
    in property <int> member-count: 0;
    in property <bool> is-desktop: false;
    in property <length> safe-area-top: 0px;

    callback go-back();
    callback launch-group(string); // group-name

    background: AppTheme.surface-primary;

    property <bool> can-launch: group-name-input.character-count >= 2;

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // --- Pro Immersive Header ──────────────────────────────────
        Rectangle {
            height: (is-desktop ? 64px : 72px) + root.safe-area-top;
            background: AppTheme.surface-secondary;
            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                y: root.safe-area-top;
                height: is-desktop ? 64px : 72px;
                padding-left: 12px;
                padding-right: 16px;
                alignment: space-between;

                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;

                    VerticalLayout {
                        alignment: center;
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => {
                                root.go-back();
                            }
                            Text {
                                text: "✕";
                                font-size: 22px;
                                color: AppTheme.text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "New Group Info";
                            font-size: 18px;
                            font-weight: 700;
                            color: AppTheme.text-primary;
                        }

                        Text {
                            text: member-count + " members selected";
                            font-size: 12px;
                            color: AppTheme.accent;
                            font-weight: 700;
                        }
                    }
                }
            }
        }

        // --- Desktop-Adaptive Content ───────────────────────────────────────
        ScrollView {
            vertical-stretch: 1;
            mouse-drag-pan-enabled: true;

            HorizontalLayout {
                alignment: center;
                VerticalLayout {
                    width: is-desktop ? 640px : root.width;
                    padding: 16px;
                    padding-top: 32px;
                    alignment: start;
                    spacing: 24px;

                    // --- Group Avatar Spot ---
                    Rectangle {
                        width: 100%;
                        HorizontalLayout {
                            alignment: center;
                            Rectangle {
                                width: 100px;
                                height: 100px;
                                border-radius: 50px;
                                background: AppTheme.surface-tertiary;
                                border-width: 1px;
                                border-color: AppTheme.divider;
                                Text {
                                    text: "📷";
                                    font-size: 32px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // --- SECTION: BASIC INFO ---
                    VerticalLayout {
                        spacing: 12px;
                        VerticalLayout {
                            padding-left: 8px;
                            Text {
                                text: "GROUP DETAILS";
                                font-size: 11px;
                                font-weight: 800;
                                color: AppTheme.text-tertiary;
                                letter-spacing: 0.8px;
                            }
                        }

                        Rectangle {
                            border-radius: 18px;
                            background: AppTheme.surface-secondary;
                            VerticalLayout {
                                padding: 18px;
                                spacing: 14px;
                                Text {
                                    text: "GROUP NAME";
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: AppTheme.text-secondary;
                                }

                                Rectangle {
                                    height: 52px;
                                    border-radius: 12px;
                                    background: AppTheme.surface-tertiary;
                                    border-width: 1px;
                                    border-color: name-input.has-focus ? AppTheme.accent : transparent;

                                    HorizontalLayout {
                                        padding-left: 14px;
                                        padding-right: 14px;
                                        name-input := TextInput {
                                            text <=> root.group-name-input;
                                            font-size: 16px;
                                            color: AppTheme.text-primary;
                                            vertical-alignment: center;
                                            single-line: true;
                                        }
                                    }

                                    if name-input.text == "": Text {
                                        padding-left: 14px;
                                        height: parent.height;
                                        text: "Enter group name...";
                                        font-size: 15px;
                                        color: AppTheme.text-tertiary;
                                        vertical-alignment: center;
                                        opacity: 0.4;
                                    }
                                }

                                Text {
                                    text: "This will be the topic for the Gossip swarm.";
                                    font-size: 10px;
                                    color: AppTheme.text-tertiary;
                                }
                            }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }

                    // --- FINAL ACTION: LAUNCH GOSSIP ---
                    Rectangle {
                        height: 60px;
                        border-radius: 20px;
                        background: can-launch ? AppTheme.accent : AppTheme.surface-tertiary;
                        animate background { duration: 150ms; }

                        TouchArea {
                            enabled: root.can-launch;
                            clicked => {
                                root.launch-group(root.group-name-input);
                            }
                            Text {
                                text: "Build Peer Group & Invite Members";
                                font-size: 16px;
                                font-weight: 800;
                                color: root.can-launch ? #FFFFFF : AppTheme.text-tertiary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Text {
                        text: "Once built, invites will be sent via secure E2EE direct messages.";
                        font-size: 11px;
                        color: AppTheme.text-tertiary;
                        horizontal-alignment: center;
                        padding-top: 12px;
                    }

                    Rectangle {
                        height: 32px;
                    }
                }
            }
        }
    }
}

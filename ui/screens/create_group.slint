// Screen for creating a new group conversation.

import { AppTheme } from "../theme.slint";
import { Button } from "../components/button.slint";
import { FormInput } from "../components/form_input.slint";
import { AppInfo } from "../components/row_data.slint";

export component CreateGroupScreen inherits Rectangle {
    in property <bool> is-desktop: false;
    in property <AppInfo> app-info;
    
    callback back-clicked();
    callback create-group(string, string); // name, topic

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // Header
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { text: "←"; font-size: 24px; color: AppTheme.text-primary; vertical-alignment: center; }
                }

                VerticalLayout {
                    alignment: center;
                    Text { text: "New Group"; font-size: is-desktop ? 24px : 18px; font-weight: 700; color: AppTheme.text-primary; }
                    Text { text: "Create a shared group conversation"; font-size: 13px; color: AppTheme.text-secondary; }
                }
            }
        }

        // Body
        VerticalLayout {
            padding: AppTheme.sp-lg;
            padding-top: AppTheme.sp-xl;
            spacing: AppTheme.sp-lg;
            alignment: start;

            // Introductory note
            Rectangle {
                background: AppTheme.accent-soft;
                border-radius: AppTheme.radius-md;
                border-width: 1px;
                border-color: AppTheme.accent;
                
                VerticalLayout {
                    padding: AppTheme.sp-md;
                    Text {
                        text: "Groups in " + root.app-info.name + " use peer-to-peer group transport. After creation, selected members receive invitations through direct messages.";
                        font-size: 13px;
                        color: AppTheme.text-secondary;
                        wrap: word-wrap;
                    }
                }
            }

            // Group fields
            VerticalLayout {
                spacing: AppTheme.sp-sm;
                Text { text: "GROUP NAME"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1.5px; }
                name-input := FormInput {
                    placeholder: "e.g. Family Chat or Project Team";
                }
            }

            VerticalLayout {
                spacing: AppTheme.sp-sm;
                Text { text: "GROUP DESCRIPTION"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1.5px; }
                desc-input := FormInput {
                    placeholder: "What is this group about?";
                }
                Text { 
                    text: "This helps invited members recognize the group."; 
                    font-size: 11px; 
                    color: AppTheme.text-tertiary; 
                }
            }

            // Continue to member selection
            Button {
                text: "Next: Select Members";
                kind: "primary";
                enabled: name-input.text != "";
                clicked => { root.create-group(name-input.text, desc-input.text); }
            }

            Rectangle { vertical-stretch: 1; }
        }
    }
}

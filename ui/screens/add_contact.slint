import { AppTheme } from "../theme.slint";
import { BaseScreen } from "../components/base_screen.slint";

export component AddContactScreen inherits Rectangle {
    in-out property <string> node-id-input: "";
    in property <bool> is-desktop: false;
    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback add-contact(string);
    callback go-back();
    callback scan-qr();

    property <bool> can-add: node-id-input.character-count > 8;

    BaseScreen {
        title: "Add Contact";
        is-desktop: root.is-desktop;
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom;
        go-back => { root.go-back(); }

        // --- Instructions ---
        VerticalLayout {
            spacing: AppTheme.sp-sm;
            Text {
                text: "PEER DISCOVERY";
                font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px;
            }
            Text {
                text: "To connect, you need your friend's Peer Ticket. Tickets help decentralized nodes find each other.";
                font-size: 14px; color: AppTheme.text-secondary; wrap: word-wrap;
            }
        }

        // --- QR Scanner Section ---
        Rectangle {
            background: AppTheme.surface-secondary;
            border-radius: AppTheme.radius-lg;

            VerticalLayout {
                padding: AppTheme.sp-lg;
                spacing: AppTheme.sp-lg;
                alignment: center;

                Text { text: "📸"; font-size: 40px; horizontal-alignment: center; }
                
                qr-touch := TouchArea {
                    height: 52px;
                    clicked => { root.scan-qr(); }
                    Rectangle {
                        background: qr-touch.has-hover ? AppTheme.surface-hover : AppTheme.surface-tertiary;
                        border-radius: AppTheme.radius-md;
                        animate background { duration: AppTheme.dur-short; }
                        Text {
                            text: is-desktop ? "Open Camera Scanner" : "Scan QR Code";
                            font-size: 16px; font-weight: 700; color: AppTheme.accent;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // --- Manual Input ---
        VerticalLayout {
            spacing: AppTheme.sp-md;
            Text {
                text: "OR PASTE TICKET MANUALLY";
                font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px;
            }

            Rectangle {
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;
                height: 120px;

                HorizontalLayout {
                    padding: AppTheme.sp-md;
                    id-input := TextInput {
                        text <=> root.node-id-input;
                        font-size: 14px; color: AppTheme.text-primary;
                        font-family: "monospace"; wrap: word-wrap;
                    }
                }

                if id-input.text == "": Text {
                    x: AppTheme.sp-lg; y: AppTheme.sp-lg;
                    text: "iroh://..."; font-size: 14px;
                    color: AppTheme.text-tertiary; opacity: 0.4;
                }
            }
        }

        // --- Action ---
        VerticalLayout {
            spacing: AppTheme.sp-lg;
            padding-top: AppTheme.sp-md;

            Rectangle {
                height: 60px;
                background: can-add ? @linear-gradient(90deg, AppTheme.accent 0%, #0056B3 100%) : AppTheme.surface-tertiary;
                border-radius: 30px;
                
                TouchArea {
                    enabled: root.can-add;
                    clicked => { root.add-contact(root.node-id-input); }
                    Text {
                        text: "Add Contact";
                        font-size: 17px; font-weight: 800;
                        color: root.can-add ? #FFFFFF : AppTheme.text-tertiary;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }
            }

            Text {
                text: "Secure P2P handshake will initiate immediately.";
                font-size: 12px; color: AppTheme.text-tertiary; horizontal-alignment: center;
                opacity: 0.5;
            }
        }
    }
}


import { AppTheme } from "../theme.slint";
import { ScrollView } from "std-widgets.slint";
import { AppHeader } from "../components/app_header.slint";

// AddContactScreen — Clean Discovery UI
// Simplified for better focus and vertically centered QR actions.

export component AddContactScreen inherits Rectangle {
    in-out property <string> node-id-input: "";
    in property <bool> is-desktop: false;
    in property <length> safe-area-top: 0px;

    callback add-contact(string);
    callback go-back();
    callback scan-qr();

    background: AppTheme.surface-primary;

    property <bool> can-add: node-id-input.character-count > 8;

    VerticalLayout {
        padding: 0;
        spacing: 0;

        AppHeader {
            is-desktop: root.is-desktop;
            safe-area-top: root.safe-area-top;
            show-back: true;
            title: "Add Contact";
            go-back => { root.go-back(); }
        }

        // --- Simplified Body ──────────────────────────────────────────
        ScrollView {
            vertical-stretch: 1;
            mouse-drag-pan-enabled: true;

            HorizontalLayout {
                alignment: start;
                padding-left: is-desktop ? 0px : 16px;
                padding-right: is-desktop ? 0px : 16px;
                
                VerticalLayout {
                    width: is-desktop ? 640px : root.width - 32px;
                    horizontal-stretch: 1;
                    padding-top: 24px;
                    spacing: 16px; 
                    alignment: start;

                    // --- SECTION: IDENTITY SCAN ---
                    VerticalLayout {
                        spacing: 10px;
                        Text { text: "PEER DISCOVERY"; font-size: 11px; font-weight: 700; color: AppTheme.text-tertiary; letter-spacing: 0.5px; }
                        Text {
                            text: "Paste a peer ticket. Tickets carry the endpoint address iroh needs to discover the peer.";
                            font-size: 12px;
                            color: AppTheme.text-secondary;
                            wrap: word-wrap;
                        }
                        
                        Rectangle {
                            border-radius: 18px;
                            background: AppTheme.surface-secondary;
                            
                            VerticalLayout {
                                padding: 16px;
                                spacing: 16px;

                                // QR Scanner CTA
                                TouchArea {
                                    height: 56px;
                                    clicked => { root.scan-qr(); }
                                    Rectangle {
                                        border-radius: 14px;
                                        background: AppTheme.surface-tertiary;
                                        HorizontalLayout {
                                            alignment: center;
                                            spacing: 12px;
                                            Text { text: "📸"; font-size: 18px; vertical-alignment: center; }
                                            Text {
                                                text: is-desktop ? "Open Webcam Scanner" : "Scan QR Code";
                                                font-size: 16px; font-weight: 700; color: AppTheme.accent;
                                                vertical-alignment: center; // FIXED: Centered text
                                            }
                                        }
                                    }
                                }

                                Text { text: "OR PASTE PEER TICKET"; font-size: 10px; font-weight: 800; color: AppTheme.text-tertiary; horizontal-alignment: center; }

                                // Ticket input
                                Rectangle {
                                    height: 52px;
                                    border-radius: 12px;
                                    background: AppTheme.surface-tertiary;
                                    border-width: 1px;
                                    border-color: id-input.has-focus ? AppTheme.accent : transparent;

                                    HorizontalLayout {
                                        padding-left: 14px; padding-right: 14px;
                                        id-input := TextInput {
                                            text <=> root.node-id-input;
                                            font-size: 14px; color: AppTheme.text-primary;
                                            vertical-alignment: center; single-line: true; font-family: "monospace";
                                        }
                                    }

                                    if id-input.text == "": Text {
                                        padding-left: 14px; height: parent.height;
                                        text: "docaa...ticket"; font-size: 14px;
                                        color: AppTheme.text-tertiary; vertical-alignment: center; opacity: 0.4;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }

                    // --- FINAL ACTION ---
                    Rectangle {
                        height: 60px;
                        border-radius: 20px;
                        background: can-add ? AppTheme.accent : AppTheme.surface-tertiary;

                        TouchArea {
                            enabled: root.can-add;
                            clicked => { root.add-contact(root.node-id-input); }
                            Text {
                                text: "Add Peer";
                                font-size: 17px; font-weight: 700;
                                color: root.can-add ? #FFFFFF : AppTheme.text-tertiary;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }
                    
                    Text {
                        text: "Once added, open the chat list and start chatting.";
                        font-size: 11px; color: AppTheme.text-tertiary; horizontal-alignment: center;
                    }
                    
                    Rectangle { height: 16px; }
                }
            }
        }
    }
}

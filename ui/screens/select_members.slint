import { AppTheme } from "../theme.slint";
import { BaseScreen } from "../components/base_screen.slint";

export struct SelectionData {
    id: string,
    name: string,
    initials: string,
    is-selected: bool,
    is-online: bool,
}

export component SelectMembersScreen inherits Rectangle {
    in property <[SelectionData]> contacts: [
        { id: "1", name: "Eric O.",   initials: "EO", is-selected: false, is-online: true },
        { id: "2", name: "Mama",      initials: "MA", is-selected: false, is-online: false },
        { id: "3", name: "Shedrack",  initials: "SG", is-selected: false, is-online: true },
        { id: "4", name: "Anon 4f7c", initials: "AN", is-selected: false, is-online: false },
    ];
    in property <bool>   is-desktop: false;
    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;
    in property <int>    selected-count: 0;

    callback go-back();
    callback toggle-selection(string); // id
    callback next-step(); // Move to Group Name Screen

    BaseScreen {
        title: "Select Members";
        subtitle: selected-count + " peers selected";
        is-desktop: root.is-desktop;
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom;
        go-back => { root.go-back(); }

        VerticalLayout {
            spacing: AppTheme.sp-lg;

            // --- Selection List ---
            VerticalLayout {
                spacing: AppTheme.sp-sm;
                
                for contact[i] in contacts: Rectangle {
                    height: 72px;
                    background: contact.is-selected ? AppTheme.surface-secondary : transparent;
                    border-radius: AppTheme.radius-lg;
                    border-width: 1px;
                    border-color: contact.is-selected ? AppTheme.accent : transparent;
                    animate background { duration: AppTheme.dur-short; }
                    animate border-color { duration: AppTheme.dur-short; }

                    TouchArea {
                        clicked => { root.toggle-selection(contact.id); }
                    }

                    HorizontalLayout {
                        padding-left: AppTheme.sp-md; padding-right: AppTheme.sp-md; spacing: AppTheme.sp-md;
                        alignment: start;

                        // Avatar
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 48px; height: 48px; border-radius: 24px;
                                background: contact.is-selected ? AppTheme.accent : AppTheme.surface-tertiary;
                                animate background { duration: AppTheme.dur-short; }
                                Text { text: contact.initials; font-size: 16px; font-weight: 800; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }

                        // Info
                        VerticalLayout {
                            alignment: center; horizontal-stretch: 1;
                            Text { text: contact.name; font-size: 16px; font-weight: 700; color: #FFFFFF; }
                            Text { text: contact.is-online ? "Online" : "Offline"; font-size: 12px; color: contact.is-online ? AppTheme.accent-success : AppTheme.text-tertiary; }
                        }

                        // Checkbox-style indicator
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 24px; height: 24px; border-radius: 12px;
                                border-width: 2px; border-color: contact.is-selected ? AppTheme.accent : AppTheme.divider;
                                background: contact.is-selected ? AppTheme.accent : transparent;
                                animate background { duration: AppTheme.dur-short; }
                                animate border-color { duration: AppTheme.dur-short; }
                                
                                if contact.is-selected: Text { text: "✓"; font-size: 14px; font-weight: 900; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }

            if contacts.length == 0: Rectangle {
                height: 200px;
                Text { text: "No contacts found to select."; font-size: 16px; color: AppTheme.text-tertiary; horizontal-alignment: center; vertical-alignment: center; }
            }
        }

        // --- Sticky Action Bar ---
        VerticalLayout {
            padding-top: AppTheme.sp-lg;
            Rectangle {
                height: 60px;
                background: selected-count > 0 ? @linear-gradient(90deg, AppTheme.accent 0%, #0056B3 100%) : AppTheme.surface-tertiary;
                border-radius: 30px;
                animate background { duration: AppTheme.dur-short; }

                TouchArea {
                    enabled: selected-count > 0;
                    clicked => { root.next-step(); }
                    Text {
                        text: "Continue with " + selected-count + " members";
                        font-size: 16px; font-weight: 800;
                        color: selected-count > 0 ? #FFFFFF : AppTheme.text-tertiary;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }
            }
        }
    }
}


import { AppTheme } from "../theme.slint";
import { BaseScreen } from "../components/base_screen.slint";

export component ChangePasswordScreen inherits Rectangle {
    in property <bool>   is-desktop: false;
    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;
    in property <length> virtual-keyboard-height: 0px;

    // Emitted with (current_pin, new_pin)
    callback confirm-change(string, string);
    callback go-back();

    // Local state
    in-out property <string> current-pin: "";
    in-out property <string> new-pin: "";
    in-out property <string> confirm-pin: "";
    in-out property <string> error-msg: "";

    property <bool> pins-match: new-pin.character-count >= 4 && new-pin == confirm-pin;
    property <bool> valid: current-pin.character-count >= 1 && pins-match;

    BaseScreen {
        title: "Change Password";
        is-desktop: root.is-desktop;
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom + root.virtual-keyboard-height;
        go-back => { root.go-back(); }

        VerticalLayout {
            spacing: AppTheme.sp-xl;
            padding-top: AppTheme.sp-lg;

            // --- Header ---
            VerticalLayout {
                spacing: AppTheme.sp-sm;
                Text {
                    text: "Update Access PIN";
                    font-size: 26px; font-weight: 900; color: AppTheme.text-primary;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Enter your current PIN, then choose a new one (min. 4 characters).";
                    font-size: 14px; color: AppTheme.text-tertiary;
                    horizontal-alignment: center; wrap: word-wrap;
                }
            }

            // --- Input Fields ---
            HorizontalLayout {
                alignment: center;
                VerticalLayout {
                    width: root.is-desktop ? 400px : parent.width;
                    spacing: AppTheme.sp-lg;

                    // Current PIN
                    VerticalLayout {
                        spacing: AppTheme.sp-sm;
                        Text { text: "CURRENT PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; horizontal-alignment: center; }
                        Rectangle {
                            height: 64px;
                            border-radius: AppTheme.radius-lg;
                            background: AppTheme.surface-secondary;
                            border-width: 1px;
                            border-color: cur-input.has-focus ? AppTheme.accent : transparent;
                            animate border-color { duration: AppTheme.dur-short; }
                            TouchArea { width: 100%; height: 100%; clicked => { cur-input.focus(); } }
                            HorizontalLayout {
                                alignment: center;
                                cur-input := TextInput {
                                    width: self.text == "" ? 2px : parent.width;
                                    text <=> root.current-pin;
                                    font-size: 24px; font-weight: 800; color: #FFFFFF;
                                    vertical-alignment: center; single-line: true;
                                    horizontal-alignment: center; input-type: password;
                                    accepted => { new-input.focus(); }
                                }
                            }
                            if cur-input.text == "": Text {
                                width: 100%; height: 100%;
                                text: "••••"; font-size: 24px;
                                color: AppTheme.text-tertiary; vertical-alignment: center; horizontal-alignment: center; opacity: 0.3;
                            }
                        }
                    }

                    // New PIN
                    VerticalLayout {
                        spacing: AppTheme.sp-sm;
                        Text { text: "NEW PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; horizontal-alignment: center; }
                        Rectangle {
                            height: 64px;
                            border-radius: AppTheme.radius-lg;
                            background: AppTheme.surface-secondary;
                            border-width: 1px;
                            border-color: new-input.has-focus ? AppTheme.accent : transparent;
                            animate border-color { duration: AppTheme.dur-short; }
                            TouchArea { width: 100%; height: 100%; clicked => { new-input.focus(); } }
                            HorizontalLayout {
                                alignment: center;
                                new-input := TextInput {
                                    width: self.text == "" ? 2px : parent.width;
                                    text <=> root.new-pin;
                                    font-size: 24px; font-weight: 800; color: #FFFFFF;
                                    vertical-alignment: center; single-line: true;
                                    horizontal-alignment: center; input-type: password;
                                    accepted => { conf-input.focus(); }
                                }
                            }
                            if new-input.text == "": Text {
                                width: 100%; height: 100%;
                                text: "At least 4 characters"; font-size: 16px;
                                color: AppTheme.text-tertiary; vertical-alignment: center; horizontal-alignment: center; opacity: 0.3;
                            }
                        }
                    }

                    // Confirm PIN
                    VerticalLayout {
                        spacing: AppTheme.sp-sm;
                        Text { text: "CONFIRM NEW PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; horizontal-alignment: center; }
                        Rectangle {
                            height: 64px;
                            border-radius: AppTheme.radius-lg;
                            background: AppTheme.surface-secondary;
                            border-width: 1px;
                            border-color: conf-input.has-focus
                                ? (root.confirm-pin.character-count > 0 && !root.pins-match ? AppTheme.accent-danger : AppTheme.accent)
                                : transparent;
                            animate border-color { duration: AppTheme.dur-short; }
                            TouchArea { width: 100%; height: 100%; clicked => { conf-input.focus(); } }
                            HorizontalLayout {
                                alignment: center;
                                conf-input := TextInput {
                                    width: self.text == "" ? 2px : parent.width;
                                    text <=> root.confirm-pin;
                                    font-size: 24px; font-weight: 800; color: #FFFFFF;
                                    vertical-alignment: center; single-line: true;
                                    horizontal-alignment: center; input-type: password;
                                    accepted => { if (root.valid) { root.confirm-change(root.current-pin, root.new-pin); } }
                                }
                            }
                            if conf-input.text == "": Text {
                                width: 100%; height: 100%;
                                text: "••••"; font-size: 24px;
                                color: AppTheme.text-tertiary; vertical-alignment: center; horizontal-alignment: center; opacity: 0.3;
                            }
                        }
                        // Inline mismatch hint
                        if root.confirm-pin.character-count > 0 && !root.pins-match: Text {
                            text: "Passwords do not match";
                            font-size: 12px; font-weight: 600;
                            color: AppTheme.accent-danger;
                            horizontal-alignment: center;
                        }
                    }

                    // Error from backend (wrong current PIN)
                    if root.error-msg != "": Text {
                        text: root.error-msg;
                        font-size: 13px; font-weight: 600;
                        color: AppTheme.accent-danger;
                        horizontal-alignment: center;
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }

            // --- Action Button ---
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    height: 60px;
                    width: root.is-desktop ? 400px : parent.width;
                    background: root.valid
                        ? @linear-gradient(90deg, AppTheme.accent 0%, #0056B3 100%)
                        : AppTheme.surface-tertiary;
                    border-radius: 30px;
                    animate background { duration: AppTheme.dur-md; }
                    TouchArea {
                        enabled: root.valid;
                        clicked => { root.confirm-change(root.current-pin, root.new-pin); }
                        Text {
                            text: "Update Password";
                            font-size: 17px; font-weight: 800;
                            color: root.valid ? #FFFFFF : AppTheme.text-tertiary;
                            horizontal-alignment: center; vertical-alignment: center;
                            animate color { duration: AppTheme.dur-md; }
                        }
                    }
                }
            }
        }
    }
}

import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { ContactRow } from "../components/contact_row.slint";
import { StatusDot } from "../components/status_dot.slint";

export struct ChatPreview {
    id: string,
    name: string,
    initials: string,
    last-message: string,
    timestamp: string,
    unread: int,
    is-group: bool,
    is-online: bool,
    is-relay: bool,
    is-queued: bool,
    is-verified: bool,
}

export component ChatListScreen inherits Rectangle {
    in property <[ChatPreview]> chats: [
        { id: "1", name: "Eric O.", initials: "EO", last-message: "Sent the ref doc ✓", timestamp: "12:41", unread: 0, is-online: true, is-verified: true, is-group: false, is-relay: false, is-queued: false },
        { id: "2", name: "Mama", initials: "MA", last-message: "", timestamp: "09:12", unread: 2, is-online: false, is-verified: true, is-group: false, is-relay: false, is-queued: true },
        { id: "3", name: "Project Group", initials: "PG", last-message: "You: Let's ship it", timestamp: "Tue", unread: 0, is-online: false, is-verified: true, is-group: true, is-relay: false, is-queued: false },
        { id: "4", name: "Anon 4f7c…", initials: "AN", last-message: "", timestamp: "Mon", unread: 1, is-online: true, is-verified: false, is-group: false, is-relay: true, is-queued: false },
    ];
    in property <int>  direct-peers: 8;
    in property <int>  relay-peers: 1;
    in property <int>  queued-messages: 2;
    in property <bool> is-offline: false;
    in property <bool> is-desktop: false; 

    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback open-chat(string);
    callback add-contact();
    callback open-contacts();
    callback open-settings();

    background: AppTheme.surface-primary;

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // --- Immersive Precision Header (Adaptive) ──────────────────────────────────
        Rectangle {
            height: (is-desktop ? 64px : 72px) + root.safe-area-top;
            background: AppTheme.surface-secondary;
            border-width: 0;
            
            // Divider
            Rectangle {
                y: parent.height - 1px;
                width: 100%; height: 1px;
                background: AppTheme.divider; 
            }

            HorizontalLayout {
                y: root.safe-area-top;
                height: 72px;
                padding-left: 16px;  
                padding-right: 16px;
                alignment: space-between;

                VerticalLayout {
                    alignment: center;
                    Image {
                        source: @image-url("../../assets/icons/app_logo_with_name_transparent_bg.png");
                        height: 52px; 
                        image-fit: contain;
                        horizontal-alignment: left; 
                    }
                }

                VerticalLayout {
                    alignment: center;
                    TouchArea {
                        width: 44px; height: 44px;
                        clicked => { root.add-contact(); }
                        Rectangle {
                            width: 100%; height: 100%;
                            border-radius: 12px;
                            background: AppTheme.accent;
                            Text {
                                text: "+";
                                font-size: 26px;
                                font-weight: 800;
                                color: #FFFFFF;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // --- Search/Peers Section ──────────────────────────────────────────
        Rectangle {
            height: 64px;
            background: AppTheme.surface-secondary;
            
            VerticalLayout {
                padding-left: 16px;
                padding-right: 16px;
                padding-bottom: 14px;
                alignment: center;

                Rectangle {
                    border-radius: 16px;
                    background: AppTheme.surface-tertiary;
                    height: 48px;

                    HorizontalLayout {
                        padding-left: 18px;
                        alignment: start;
                        spacing: 12px;

                        Text { text: "⚲"; font-size: 18px; color: AppTheme.text-tertiary; vertical-alignment: center; }

                        search := TextInput {
                            font-size: 17px;
                            color: AppTheme.text-primary;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            single-line: true;
                        }
                    }

                    if search.text == "": Text {
                        x: 48px;
                        height: parent.height;
                        text: "Search for peers...";
                        font-size: 17px;
                        color: AppTheme.text-tertiary;
                        vertical-alignment: center;
                        opacity: 0.5;
                    }
                }
            }
        }

        // --- Message Stream ───────────────────────────────────────────────
        ScrollView {
            vertical-stretch: 1;
            mouse-drag-pan-enabled: true;

            VerticalLayout {
                alignment: start;

                for chat[i] in chats: ContactRow {
                    name:         chat.name;
                    initials:     chat.initials;
                    last-message: chat.last-message;
                    timestamp:    chat.timestamp;
                    unread:       chat.unread;
                    is-group:     chat.is-group;
                    is-online:    chat.is-online;
                    is-relay:     chat.is-relay;
                    is-queued:    chat.is-queued;
                    is-verified:  chat.is-verified;
                    clicked => { root.open-chat(chat.id); }
                }
            }
        }

        // --- Bottom Navigation Navigation (Always on Sidebar) ────────────────────────────────
        Rectangle {
            height: (is-desktop ? 80px : 76px) + root.safe-area-bottom;
            background: AppTheme.surface-secondary;
            
            // Divider
            Rectangle {
                y: 0; width: 100%; height: 1px;
                background: AppTheme.divider; 
            }

            HorizontalLayout {
                padding-bottom: is-desktop ? 14px : root.safe-area-bottom;
                alignment: space-around;
                padding-top: 10px;

                TouchArea {
                    width: 90px;
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "●"; font-size: 26px; color: AppTheme.accent; horizontal-alignment: center; }
                        Text { text: "Chats"; font-size: 11px; font-weight: 800; color: AppTheme.accent; horizontal-alignment: center; }
                    }
                }

                TouchArea {
                    width: 90px;
                    clicked => { root.open-contacts(); }
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "○"; font-size: 26px; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                        Text { text: "Contacts"; font-size: 11px; font-weight: 600; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                    }
                }

                TouchArea {
                    width: 90px;
                    clicked => { root.open-settings(); }
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "⊕"; font-size: 26px; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                        Text { text: "Settings"; font-size: 11px; font-weight: 600; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                    }
                }
            }
        }
    }
}

import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { AppHeader } from "../components/app_header.slint";
import { ContactRow, ChatPreview } from "../components/contact_row.slint";
export { ChatPreview }

export component ChatListScreen inherits Rectangle {
    in property <[ChatPreview]> chats: [];
    in property <int>  direct-peers: 8;
    in property <int>  relay-peers: 1;
    in property <int>  queued-messages: 2;
    in property <bool> is-offline: false;
    in property <bool> is-desktop: false; 

    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback open-chat(string, string, string, bool, bool, bool, bool);
    callback add-contact();
    callback open-contacts();
    callback open-settings();

    background: AppTheme.surface-primary;

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // --- Standard Sidebar Header ---
        Rectangle {
            height: 72px + root.safe-area-top;
            background: AppTheme.surface-primary;
            
            HorizontalLayout {
                padding-top: root.safe-area-top;
                padding-left: AppTheme.sp-lg;
                padding-right: AppTheme.sp-lg;
                alignment: space-between;

                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "Messages";
                        font-size: 24px;
                        font-weight: 800;
                        color: AppTheme.text-primary;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    TouchArea {
                        width: 40px; height: 40px;
                        clicked => { root.add-contact(); }
                        Rectangle {
                            background: AppTheme.surface-secondary;
                            border-radius: 20px;
                            Text {
                                text: "+";
                                font-size: 24px;
                                color: AppTheme.accent;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // --- Chat Stream ───────────────────────────────────────────────
        ScrollView {
            vertical-stretch: 1;
            mouse-drag-pan-enabled: true;

            VerticalLayout {
                padding: AppTheme.sp-sm;
                alignment: start;

                for chat[i] in chats: ContactRow {
                    name:         chat.name;
                    initials:     chat.initials;
                    last-message: chat.last-message;
                    timestamp:    chat.timestamp;
                    unread:       chat.unread;
                    is-group:     chat.is-group;
                    is-online:    chat.is-online;
                    is-relay:     chat.is-relay;
                    is-queued:    chat.is-queued;
                    is-verified:  chat.is-verified;
                    clicked => {
                        root.open-chat(
                            chat.id,
                            chat.name,
                            chat.initials,
                            chat.is-group,
                            chat.is-online,
                            chat.is-relay,
                            chat.is-verified,
                        );
                    }
                }

                if chats.length == 0: Rectangle {
                    height: 300px;
                    VerticalLayout {
                        alignment: center;
                        spacing: AppTheme.sp-md;
                        Text { text: "💬"; font-size: 48px; horizontal-alignment: center; }
                        Text {
                            text: "No chats yet. Connect with a Node ID.";
                            font-size: 14px; color: AppTheme.text-tertiary;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        // --- Bottom Navigation Navigation (Always on Sidebar) ────────────────────────────────
        Rectangle {
            height: 80px + root.safe-area-bottom;
            background: AppTheme.surface-secondary;
            
            Rectangle {
                y: 0; width: 100%; height: 1px;
                background: AppTheme.divider; 
            }

            HorizontalLayout {
                padding-bottom: root.safe-area-bottom;
                alignment: space-around;
                padding-top: 10px;

                TouchArea {
                    width: 70px;
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "●"; font-size: 24px; color: AppTheme.accent; horizontal-alignment: center; }
                        Text { text: "Chats"; font-size: 11px; font-weight: 800; color: AppTheme.accent; horizontal-alignment: center; }
                    }
                }

                TouchArea {
                    width: 70px;
                    clicked => { root.open-contacts(); }
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "○"; font-size: 24px; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                        Text { text: "Contacts"; font-size: 11px; font-weight: 600; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                    }
                }

                TouchArea {
                    width: 70px;
                    clicked => { root.open-settings(); }
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "⚙"; font-size: 24px; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                        Text { text: "Settings"; font-size: 11px; font-weight: 600; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                    }
                }
            }
        }
    }
}


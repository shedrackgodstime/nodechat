// Contacts screen for direct peers and saved groups.

import { AppTheme, VertScroll } from "../theme.slint";
import { ActionRow } from "../components/action_row.slint";
import { ContactData, GroupData } from "../components/row_data.slint";

export component ContactsScreen inherits Rectangle {
    in property <[ContactData]> contacts: [];
    in property <[GroupData]> groups: [];
    in property <bool> is-desktop: false;

    callback back-clicked();
    callback add-contact();
    callback new-group();
    callback open-contact(ContactData);
    callback open-group(GroupData);

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // Header
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { text: "←"; font-size: 24px; color: AppTheme.text-primary; vertical-alignment: center; }
                }

                VerticalLayout {
                    alignment: center;
                    Text { text: "Contacts"; font-size: is-desktop ? 24px : 18px; font-weight: 700; color: AppTheme.text-primary; }
                    Text { text: "Your saved peers and groups"; font-size: 13px; color: AppTheme.text-secondary; }
                }
            }
        }

        // Body
        VertScroll {
            vertical-stretch: 1;
            viewport-height: contacts-body.preferred-height;

            contacts-body := VerticalLayout {
                width: parent.width;
                padding: AppTheme.sp-md;
                padding-top: AppTheme.sp-xl;
                spacing: AppTheme.sp-lg;
                alignment: start;

                // Quick actions
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "QUICK ACTIONS"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1.5px; }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        clip: true;

                        VerticalLayout {
                            ActionRow {
                                icon-svg: @image-url("../../assets/icons/add.svg");
                                icon-color: AppTheme.accent;
                                title: "Add Peer by Ticket";
                                subtitle: "Paste a join code to connect";
                                clicked => { root.add-contact(); }
                            }
                            HorizontalLayout { padding-left: 56px; Rectangle { height: 1px; background: AppTheme.divider; } }
                            ActionRow {
                                icon-svg: @image-url("../../assets/icons/chats.svg");
                                icon-color: AppTheme.accent;
                                title: "Create New Group Chat";
                                subtitle: "Broadcast to multiple peers";
                                clicked => { root.new-group(); }
                            }
                        }
                    }
                }

                // Groups
                if root.groups.length > 0 : VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "GROUPS"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1.5px; }

                    VerticalLayout {
                        spacing: 4px;
                        for group in root.groups : ActionRow {
                            title: group.name;
                            subtitle: group.member-count + " members";
                            initials: group.initials;
                            is-online: true;
                            accessory: "arrow";
                            clicked => { root.open-group(group); }
                        }
                    }
                }

                // Direct contacts
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "DIRECT CONTACTS"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1.5px; }

                    if root.contacts.length == 0 : Rectangle {
                        height: 100px;
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        Text { text: "No peers linked yet."; color: AppTheme.text-tertiary; horizontal-alignment: center; vertical-alignment: center; }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        for contact in root.contacts : ActionRow {
                            title: contact.name;
                            subtitle: contact.node-id;
                            initials: contact.initials;
                            is-online: contact.is-online;
                            is-session-ready: contact.is-session-ready;
                            is-relay: contact.is-relay;
                            is-verified: contact.is-verified;
                            accessory: "arrow";
                            clicked => { root.open-contact(contact); }
                        }
                    }
                }

                Rectangle { height: 40px; }
            }
        }
    }
}

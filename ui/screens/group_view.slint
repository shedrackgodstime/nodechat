import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { MessageBubble } from "../components/message_bubble.slint";
import { ChatInput } from "../components/chat_input.slint";

// GroupViewScreen — Pro Decentralized Gossip Chat
// Synchronized with ChatView for a premium, consistent UX across all conversation types.

export struct GroupMessageData {
    id: string,
    text: string,
    timestamp: string,
    is-mine: bool,
    sender-name: string,   // Shown above incoming bubbles
    status: string,        // "sent" or ""
}

export component GroupViewScreen inherits Rectangle {
    in property <string>             group-name: "Project Swarm";
    in property <string>             member-count: "3";
    in property <[GroupMessageData]> messages: [];
    in property <bool>   is-desktop: false;
    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;
    in property <length> virtual-keyboard-height: 0px;

    callback go-back();
    callback send-message(string);

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%; height: 100%;
        padding: 0;
        spacing: 0;

        // --- Pro Immersive Header ──────────────────────────────────
        Rectangle {
            height: (is-desktop ? 64px : 72px) + root.safe-area-top;
            background: AppTheme.surface-secondary;
            
            Rectangle {
                y: parent.height - 1px;
                width: 100%; height: 1px;
                background: AppTheme.divider; 
            }

            HorizontalLayout {
                y: root.safe-area-top;
                height: is-desktop ? 64px : 72px;
                padding-left: 12px;
                padding-right: 16px;
                alignment: space-between;

                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;

                    VerticalLayout {
                        alignment: center;
                        TouchArea {
                            width: 32px; height: 32px;
                            clicked => { root.go-back(); }
                            Text { text: "←"; font-size: 22px; color: AppTheme.accent; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }

                    // Group Avatar
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 38px; height: 38px; border-radius: 19px;
                            background: AppTheme.surface-tertiary;
                            Text { text: "👥"; font-size: 16px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        Text {
                            text: group-name;
                            font-size: 16px; font-weight: 700; color: AppTheme.text-primary;
                        }
                        Text {
                            text: member-count + " members · gossip swarm";
                            font-size: 11px; color: AppTheme.accent; font-weight: 600;
                        }
                    }
                }

            }
        }

        Rectangle {
            height: 42px;
            background: AppTheme.surface-primary;
            border-width: 1px;
            border-color: AppTheme.divider;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 10px;
                alignment: space-between;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    Rectangle {
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        background: AppTheme.accent-success;
                    }

                    Text {
                        text: "Gossip swarm · " + member-count + " members";
                        font-size: 12px;
                        font-weight: 700;
                        color: AppTheme.accent;
                        vertical-alignment: center;
                    }
                }

                Text {
                    text: "group session active";
                    font-size: 11px;
                    color: AppTheme.text-secondary;
                    vertical-alignment: center;
                }
            }
        }

        // --- Message Stream (Desktop-Adaptive) ─────────────────────
        Rectangle {
            vertical-stretch: 1;
            clip: true;
            
            ScrollView {
                mouse-drag-pan-enabled: true;
                
                HorizontalLayout {
                    alignment: center;
                    
                    VerticalLayout {
                        max-width: 800px;
                        horizontal-stretch: 1;
                        padding: 16px;
                        padding-top: 24px;
                        spacing: 14px;
                        alignment: start;

                        // Security Badge
                        Rectangle {
                            height: 38px; width: 100%; border-radius: 12px; background: AppTheme.surface-secondary;
                            HorizontalLayout {
                                alignment: center; spacing: 8px;
                                Text { text: "🛡️"; font-size: 12px; vertical-alignment: center; }
                                Text { text: "Group is secured with Gossip-AEAD encryption"; font-size: 11px; font-weight: 700; color: AppTheme.text-tertiary; vertical-alignment: center; }
                            }
                        }

                        if messages.length == 0: VerticalLayout {
                            width: 100%;
                            padding-top: 40px;
                            spacing: 10px;
                            alignment: center;
                            Text {
                                text: "No group messages yet";
                                font-size: 18px;
                                font-weight: 700;
                                color: AppTheme.text-primary;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "Start the first update for this group.";
                                font-size: 13px;
                                color: AppTheme.text-secondary;
                                horizontal-alignment: center;
                            }
                        }

                        for msg[i] in messages: MessageBubble {
                            text:         msg.text;
                            timestamp:    msg.timestamp;
                            is-mine:      msg.is-mine;
                            status:       msg.status;
                            sender-name:  msg.is-mine ? "" : msg.sender-name;
                        }
                    }
                }
            }
        }

        // --- Adaptive Immersive Footer ─────────────────────────────
        Rectangle {
            background: AppTheme.surface-secondary;
            
            Rectangle {
                y: 0; width: 100%; height: 1px;
                background: AppTheme.divider; 
            }
            
            HorizontalLayout {
                alignment: center;
                VerticalLayout {
                    max-width: 800px;
                    horizontal-stretch: 1;
                    padding: 10px;
                    padding-left: 10px; padding-right: 10px;
                    alignment: center;
                    
                    ChatInput {
                        send-message(msg) => { root.send-message(msg); }
                    }
                }
            }
        }

        // --- Immersive Keyboard/Safe-Area Spacer ──────────────────
        Rectangle {
            height: Math.max(root.safe-area-bottom, virtual-keyboard-height) + 12px;
            background: AppTheme.surface-secondary;
            animate height { duration: 150ms; easing: ease-out; }
        }
    }
}

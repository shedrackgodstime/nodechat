// NodeChat New — Password / App Lock Screen
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";
import { Button } from "../components/button.slint";
import { FormInput } from "../components/form_input.slint";

export component PasswordScreen inherits Rectangle {
    in property <bool> is-desktop: false;
    in-out property <bool> has-password: false;

    callback back-clicked();
    callback confirm-password(string, string); // (current, new) — set/change
    callback remove-password(string);           // (current) — disable
    callback request-unfocus();

    // Background Unfocus Catcher
    TouchArea {
        width: 100%; height: 100%;
        clicked => { root.request-unfocus(); }
    }

    background: AppTheme.surface-primary;

    // Local UI state
    property <bool> wants-enable: false;   // toggle flipped ON (no password yet)
    property <bool> wants-disable: false;  // toggle flipped OFF (has password)
    property <bool> wants-change: false;   // "Change Password" row tapped

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // 1. Header
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { text: "←"; font-size: 24px; color: AppTheme.text-primary; vertical-alignment: center; }
                }

                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "App Password";
                        font-size: is-desktop ? 28px : 18px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                    }
                    Text {
                        text: root.has-password ? "Password protection is active" : "Lock your vault on every open";
                        font-size: 13px;
                        color: AppTheme.text-secondary;
                    }
                }
            }
        }

        // 2. Content
        VerticalLayout {
            padding: AppTheme.sp-lg;
            padding-top: AppTheme.sp-xl;
            spacing: AppTheme.sp-lg;

            // --- Enable / Disable Toggle Row ---
            Text { text: "APP LOCK"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }

            Rectangle {
                height: 64px;
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-md;
                border-width: 1px;
                border-color: AppTheme.divider;

                HorizontalLayout {
                    padding-left: AppTheme.sp-md;
                    padding-right: AppTheme.sp-md;
                    alignment: space-between;

                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        Text {
                            text: "Require Password on Open";
                            font-size: 15px; font-weight: 600;
                            color: AppTheme.text-primary;
                        }
                        Text {
                            text: root.has-password ? "Active" : "Disabled";
                            font-size: 12px;
                            color: root.has-password ? AppTheme.accent-success : AppTheme.text-tertiary;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        TouchArea {
                            width: 52px; height: 32px;
                            clicked => {
                                if root.has-password {
                                    root.wants-disable = !root.wants-disable;
                                    root.wants-enable = false;
                                    root.wants-change = false;
                                } else {
                                    root.wants-enable = !root.wants-enable;
                                    root.wants-disable = false;
                                }
                            }
                            Rectangle {
                                border-radius: 16px;
                                background: (root.has-password || root.wants-enable) ? AppTheme.accent : AppTheme.surface-tertiary;
                                animate background { duration: 200ms; }

                                Rectangle {
                                    x: (root.has-password || root.wants-enable) ? 24px : 4px;
                                    y: 4px;
                                    width: 24px; height: 24px;
                                    border-radius: 12px;
                                    background: #FFFFFF;
                                    animate x { duration: 200ms; easing: ease-in-out; }
                                }
                            }
                        }
                    }
                }
            }

            // --- Enable: New password form ---
            if root.wants-enable && !root.has-password: VerticalLayout {
                spacing: AppTheme.sp-md;

                Text { text: "NEW PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                new-input := FormInput {
                    placeholder: "Enter a password…";
                    input-type: InputType.password;
                }

                Text { text: "CONFIRM PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                confirm-input := FormInput {
                    placeholder: "Re-enter password…";
                    input-type: InputType.password;
                }

                if new-input.text != "" && new-input.text != confirm-input.text: Text {
                    text: "Passwords do not match.";
                    color: AppTheme.accent-danger;
                    font-size: 12px;
                }

                Rectangle { height: 4px; }

                Button {
                    text: "Enable Password";
                    kind: "primary";
                    enabled: new-input.text != "" && new-input.text == confirm-input.text;
                    clicked => { root.confirm-password("", new-input.text); }
                }
            }

            // --- Disable: Verify then clear ---
            if root.wants-disable && root.has-password: VerticalLayout {
                spacing: AppTheme.sp-md;

                Text { text: "VERIFY CURRENT PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                verify-input := FormInput {
                    placeholder: "Enter current password to disable…";
                    input-type: InputType.password;
                }

                Rectangle { height: 4px; }

                Button {
                    text: "Disable Password";
                    kind: "danger";
                    enabled: verify-input.text != "";
                    clicked => { root.remove-password(verify-input.text); }
                }
            }

            // --- Change password (visible when password is active and not disabling) ---
            if root.has-password && !root.wants-disable: VerticalLayout {
                spacing: AppTheme.sp-md;

                Text { text: "CHANGE PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }

                Rectangle {
                    height: 48px;
                    background: root.wants-change ? AppTheme.surface-tertiary : AppTheme.surface-secondary;
                    border-radius: AppTheme.radius-md;
                    border-width: 1px;
                    border-color: AppTheme.divider;
                    animate background { duration: AppTheme.dur-short; }

                    TouchArea {
                        clicked => { root.wants-change = !root.wants-change; }
                        HorizontalLayout {
                            padding-left: AppTheme.sp-md;
                            padding-right: AppTheme.sp-md;
                            alignment: space-between;
                            Text {
                                text: "Change your password";
                                font-size: 14px; font-weight: 600;
                                color: AppTheme.text-primary;
                                vertical-alignment: center;
                            }
                            Text { text: root.wants-change ? "▲" : "▼"; font-size: 12px; color: AppTheme.text-tertiary; vertical-alignment: center; }
                        }
                    }
                }

                if root.wants-change: VerticalLayout {
                    spacing: AppTheme.sp-md;

                    Text { text: "CURRENT PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                    cur-input := FormInput {
                        placeholder: "Enter current password…";
                        input-type: InputType.password;
                    }

                    Text { text: "NEW PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                    new2-input := FormInput {
                        placeholder: "Enter new password…";
                        input-type: InputType.password;
                    }

                    Text { text: "CONFIRM PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                    confirm2-input := FormInput {
                        placeholder: "Re-enter new password…";
                        input-type: InputType.password;
                    }

                    if new2-input.text != "" && new2-input.text != confirm2-input.text: Text {
                        text: "Passwords do not match.";
                        color: AppTheme.accent-danger;
                        font-size: 12px;
                    }

                    Rectangle { height: 4px; }

                    Button {
                        text: "Save New Password";
                        kind: "primary";
                        enabled: cur-input.text != "" && new2-input.text != "" && new2-input.text == confirm2-input.text;
                        clicked => { root.confirm-password(cur-input.text, new2-input.text); }
                    }
                }
            }

            // Warning note
            if !root.has-password: Rectangle {
                border-radius: AppTheme.radius-md;
                background: AppTheme.surface-secondary;
                border-width: 1px;
                border-color: AppTheme.divider;
                height: 64px;
                VerticalLayout {
                    padding: AppTheme.sp-md;
                    Text {
                        text: "⚠ There is no password recovery.\nIf you forget your password your vault cannot be unlocked.";
                        font-size: 12px;
                        color: AppTheme.text-secondary;
                        wrap: word-wrap;
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }
        }
    }
}

import { AppTheme } from "../theme.slint";
import { ScrollView } from "std-widgets.slint";
import { AppHeader } from "../components/app_header.slint";

export component ContactDetailsScreen inherits Rectangle {
    in property <string> peer-name: "";
    in property <string> peer-initials: "";
    in property <string> peer-node-id: "";
    in property <string> endpoint-ticket: "";
    in property <string> connection-mode: "direct";
    in property <string> connection-stage: "";
    in property <bool> is-online: false;
    in property <bool> is-verified: false;
    in property <bool> is-desktop: false;
    in property <length> safe-area-top: 0px;

    callback go-back();
    callback chat-now();
    callback mark-verified();
    callback clear-conversation(string, bool);
    callback remove-contact();

    background: AppTheme.surface-primary;

    VerticalLayout {
        padding: 0;
        spacing: 0;

        AppHeader {
            is-desktop: root.is-desktop;
            safe-area-top: root.safe-area-top;
            show-back: true;
            title: "Contact Settings";
            subtitle: peer-name;
            go-back => { root.go-back(); }
        }

        ScrollView {
            vertical-stretch: 1;
            mouse-drag-pan-enabled: true;

            HorizontalLayout {
                alignment: start;
                padding-left: is-desktop ? 0px : 16px;
                padding-right: is-desktop ? 0px : 16px;

                    VerticalLayout {
                        width: is-desktop ? 760px : root.width - 32px;
                        horizontal-stretch: 1;
                        padding-top: 24px;
                        padding-bottom: 24px;
                        spacing: 18px;

                    HorizontalLayout {
                        spacing: 14px;
                        alignment: start;

                        Rectangle {
                            width: 56px;
                            height: 56px;
                            border-radius: 28px;
                            background: AppTheme.accent;
                            Text {
                                text: peer-initials != "" ? peer-initials : "?";
                                font-size: 18px;
                                font-weight: 800;
                                color: #FFFFFF;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 4px;
                            Text {
                                text: peer-name;
                                font-size: 20px;
                                font-weight: 800;
                                color: AppTheme.text-primary;
                            }
                            Text {
                                text: is-online ? "Online" : "Offline";
                                font-size: 12px;
                                font-weight: 700;
                                color: is-online ? AppTheme.accent-success : AppTheme.accent-danger;
                            }
                            Text {
                                text: (is-verified ? "Verified peer" : "Verification pending") + " · " + connection-mode;
                                font-size: 11px;
                                color: AppTheme.text-secondary;
                            }
                            Text {
                                text: connection-stage == "" ? "No active handshake state." : connection-stage;
                                font-size: 11px;
                                color: AppTheme.text-tertiary;
                                wrap: word-wrap;
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 10px;
                        Text {
                            text: "PEER DETAILS";
                            font-size: 11px;
                            font-weight: 800;
                            color: AppTheme.text-tertiary;
                            letter-spacing: 0.8px;
                        }

                        VerticalLayout {
                            spacing: 12px;

                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Node ID";
                                    font-size: 10px;
                                    color: AppTheme.text-tertiary;
                                    font-weight: 700;
                                }
                                Text {
                                    text: peer-node-id;
                                    font-size: 12px;
                                    color: AppTheme.text-primary;
                                    font-family: "monospace";
                                    wrap: word-wrap;
                                }
                            }

                            Rectangle { height: 1px; background: AppTheme.divider; opacity: 0.4; }

                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Endpoint Ticket";
                                    font-size: 10px;
                                    color: AppTheme.text-tertiary;
                                    font-weight: 700;
                                }
                                Text {
                                    text: endpoint-ticket == "" ? "Not stored yet." : endpoint-ticket;
                                    font-size: 11px;
                                    color: AppTheme.text-primary;
                                    font-family: "monospace";
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 10px;
                        Text {
                            text: "ACTIONS";
                            font-size: 11px;
                            font-weight: 800;
                            color: AppTheme.text-tertiary;
                            letter-spacing: 0.8px;
                        }

                        Rectangle {
                            height: 56px;
                            border-radius: 18px;
                            background: AppTheme.accent;
                            TouchArea {
                                clicked => { root.chat-now(); }
                                Text {
                                    text: "Open Chat";
                                    font-size: 16px;
                                    font-weight: 800;
                                    color: #FFFFFF;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle {
                            height: 56px;
                            border-radius: 18px;
                            background: is-verified ? AppTheme.surface-tertiary : AppTheme.accent-success;
                            TouchArea {
                                clicked => { root.mark-verified(); }
                                Text {
                                    text: is-verified ? "Already Verified" : "Mark Verified";
                                    font-size: 15px;
                                    font-weight: 800;
                                    color: is-verified ? AppTheme.text-secondary : #FFFFFF;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle {
                            height: 56px;
                            border-radius: 18px;
                            background: AppTheme.accent-warning;
                            TouchArea {
                                clicked => { root.clear-conversation(peer-node-id, false); }
                                Text {
                                    text: "Clear Chat History";
                                    font-size: 15px;
                                    font-weight: 800;
                                    color: #1B1B1B;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle {
                            height: 56px;
                            border-radius: 18px;
                            background: AppTheme.accent-danger;
                            TouchArea {
                                clicked => { root.remove-contact(); }
                                Text {
                                    text: "Remove Contact";
                                    font-size: 15px;
                                    font-weight: 800;
                                    color: #FFFFFF;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle { height: 24px; }
                }
            }
        }
    }
}

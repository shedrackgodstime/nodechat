import { AppTheme } from "../theme.slint";
import { BaseScreen } from "../components/base_screen.slint";

export component ContactDetailsScreen inherits Rectangle {
    in property <string> peer-name: "";
    in property <string> peer-initials: "";
    in property <string> peer-node-id: "";
    in property <string> endpoint-ticket: "";
    in property <string> connection-mode: "direct";
    in property <string> connection-stage: "";
    in property <bool> is-online: false;
    in property <bool> is-verified: false;
    in property <bool> is-desktop: false;
    in property <length> safe-area-top: 0px;
    in property <length> safe-area-bottom: 0px;

    callback go-back();
    callback chat-now();
    callback request-verification();
    callback request-clear-history();
    callback request-delete-conversation();
    callback copy-text(string);

    BaseScreen {
        title: "Peer Info";
        is-desktop: root.is-desktop;
        safe-area-top: root.safe-area-top;
        safe-area-bottom: root.safe-area-bottom;
        go-back => { root.go-back(); }

        // --- Simplified Profile Hero ---
        VerticalLayout {
            spacing: AppTheme.sp-lg;
            alignment: center;
            padding-bottom: AppTheme.sp-md;

            Rectangle {
                width: 100px; height: 100px;
                border-radius: 50px;
                background: @linear-gradient(135deg, AppTheme.accent 0%, #0056b3 100%);
                Text {
                    text: peer-initials != "" ? peer-initials : "?";
                    font-size: 32px; font-weight: 800; color: #FFFFFF;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }

            VerticalLayout {
                spacing: AppTheme.sp-xs;
                Text { text: peer-name; font-size: 24px; font-weight: 900; color: #FFFFFF; horizontal-alignment: center; }
                Text { text: is-online ? "Online via " + connection-mode : "Offline"; font-size: 13px; font-weight: 700; color: is-online ? AppTheme.accent-success : AppTheme.text-tertiary; horizontal-alignment: center; }
            }
        }

        // --- Core Trust Card ---
        Rectangle {
            background: AppTheme.surface-secondary;
            border-radius: AppTheme.radius-lg;
            VerticalLayout {
                padding: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                HorizontalLayout {
                    alignment: space-between;
                    Text { text: "Identity"; font-size: 14px; color: AppTheme.text-secondary; }
                    Text { text: is-verified ? "Verified ✅" : "Unverified 🔒"; font-size: 14px; font-weight: 700; color: is-verified ? AppTheme.accent-success : AppTheme.accent-warning; }
                }
                Rectangle { height: 1px; background: AppTheme.divider; }
                HorizontalLayout {
                    alignment: space-between;
                    Text { text: "Network"; font-size: 14px; color: AppTheme.text-secondary; }
                    Text { text: connection-mode; font-size: 14px; font-weight: 700; color: AppTheme.accent; }
                }
            }
        }

        // --- Technical Identifiers (Forced Char Wrap for Mobile) ---
        VerticalLayout {
            spacing: AppTheme.sp-md;
            Text { text: "PEER DATA"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }

            Rectangle {
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;
                VerticalLayout {
                    padding: AppTheme.sp-md;
                    spacing: AppTheme.sp-lg;

                    id-touch := TouchArea {
                        property <bool> copied: false;
                        clicked => {
                            root.copy-text(root.peer-node-id);
                            self.copied = true;
                        }
                        Timer {
                            interval: 2s;
                            running: id-touch.copied;
                            triggered => { id-touch.copied = false; }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            HorizontalLayout {
                                alignment: space-between;
                                Text { text: "NODE ID"; font-size: 9px; font-weight: 800; color: AppTheme.text-tertiary; opacity: 0.7; }
                                if id-touch.copied: Text { text: "COPIED!"; font-size: 9px; font-weight: 900; color: AppTheme.accent-success; }
                            }
                            Text { 
                                text: peer-node-id; font-size: 11px; font-family: "monospace"; 
                                color: AppTheme.text-primary; wrap: char-wrap; width: 100%;
                            }
                        }
                    }

                    Rectangle { height: 1px; background: AppTheme.divider; }

                    ticket-touch := TouchArea {
                        property <bool> copied: false;
                        enabled: root.endpoint-ticket != "";
                        clicked => {
                            root.copy-text(root.endpoint-ticket);
                            self.copied = true;
                        }
                        Timer {
                            interval: 2s;
                            running: ticket-touch.copied;
                            triggered => { ticket-touch.copied = false; }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            HorizontalLayout {
                                alignment: space-between;
                                Text { text: "ENDPOINT TICKET"; font-size: 9px; font-weight: 800; color: AppTheme.text-tertiary; opacity: 0.7; }
                                if ticket-touch.copied: Text { text: "COPIED!"; font-size: 9px; font-weight: 900; color: AppTheme.accent-success; }
                            }
                            Text { 
                                text: endpoint-ticket == "" ? "None stored." : endpoint-ticket; 
                                font-size: 11px; font-family: "monospace"; 
                                color: AppTheme.text-primary; wrap: char-wrap; width: 100%;
                            }
                        }
                    }
                }
            }
        }

        // --- Action Area ---
        // Stack on mobile, side-by-side on desktop for "Clear/Remove"
        VerticalLayout {
            spacing: AppTheme.sp-md;
            padding-top: AppTheme.sp-md;

            if !is-verified: Rectangle {
                height: 52px; border-radius: 26px;
                background: AppTheme.accent-success;
                TouchArea {
                    clicked => { root.request-verification(); }
                    Text { text: "Verify Security Numbers"; font-size: 15px; font-weight: 800; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            Rectangle {
                height: 52px; border-radius: 26px;
                background: AppTheme.surface-secondary;
                TouchArea {
                    clicked => { root.request-clear-history(); }
                    Text { text: "Clear Messages"; font-size: 15px; font-weight: 700; color: AppTheme.text-primary; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            Rectangle {
                height: 52px; border-radius: 26px;
                background: rgba(255, 69, 58, 0.1);
                border-width: 1px; border-color: AppTheme.accent-danger;
                TouchArea {
                    clicked => { root.request-delete-conversation(); }
                    Text { text: "Remove Peer"; font-size: 15px; font-weight: 700; color: AppTheme.accent-danger; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }
}

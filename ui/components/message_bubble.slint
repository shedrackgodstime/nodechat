import { AppTheme } from "../theme.slint";

export struct MessageData {
    id: string,
    text: string,
    timestamp: string,
    is-mine: bool,
    status: string,
    is-ephemeral: bool,
    ttl-seconds: int,
}

export component MessageBubble inherits Rectangle {
    in property <string> text: "";
    in property <string> timestamp: "";
    in property <bool> is-mine: false;
    in property <string> status: "sent"; // sent, delivered, read, failed, queued
    in property <bool> is-ephemeral: false;
    in property <int> ttl-seconds: 0;

    background: transparent;

    HorizontalLayout {
        alignment: is-mine ? end : start;
        width: 100%;

        VerticalLayout {
            spacing: 4px;
            alignment: is-mine ? end : start;

            Rectangle {
                background: is-mine 
                    ? @linear-gradient(135deg, AppTheme.accent 0%, #0056b3 100%)
                    : AppTheme.surface-secondary;
                border-radius: AppTheme.radius-md;
                
                VerticalLayout {
                    padding: 12px;
                    padding-left: 16px;
                    padding-right: 16px;
                    spacing: 4px;
                    // Stable width constraint
                    max-width: 600px;

                    Text {
                        text: root.text;
                        color: is-mine ? #FFFFFF : AppTheme.text-primary;
                        font-size: 15px;
                        wrap: word-wrap;
                        horizontal-alignment: is-mine ? right : left;
                    }

                    HorizontalLayout {
                        alignment: is-mine ? end : start;
                        spacing: 6px;

                        if is-ephemeral: Text { text: "⏱"; font-size: 10px; color: is-mine ? rgba(255,255,255,0.7) : AppTheme.text-tertiary; vertical-alignment: center; }

                        Text {
                            text: timestamp;
                            font-size: 11px;
                            color: is-mine ? rgba(255,255,255,0.7) : AppTheme.text-tertiary;
                            vertical-alignment: center;
                        }

                        if is-mine: Text {
                            text: 
                                status == "read" ? "✓✓" :
                                status == "delivered" ? "✓✓" :
                                status == "sent" ? "✓" :
                                status == "failed" ? "!" : "⏳";
                            font-size: 11px;
                            font-weight: 800;
                            color: status == "read" ? #32D74B : (status == "failed" ? AppTheme.accent-danger : rgba(255,255,255,0.7));
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

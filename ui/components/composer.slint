// Message composer with a multiline input and fixed action buttons.

import { AppTheme } from "../theme.slint";

export component Composer inherits Rectangle {
    // Public properties consumed by the chat screen.
    in property <bool> is-disabled: false;
    in property <bool> is-mobile: false;
    in property <length> safe-area-bottom: 0px;
    in property <string> placeholder: "Message...";
    in-out property <string> draft <=> input.text;

    // User actions emitted to the host screen.
    callback send-message(string);
    callback attach-file();

    // Grow with the text input while preserving a compact minimum height.
    height: Math.min(200px, Math.max(60px, input.preferred-height + 16px)) + root.safe-area-bottom;
    background: AppTheme.surface-secondary;
    border-color: AppTheme.divider;
    border-width: 0px; // Seamless look

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px + root.safe-area-bottom;
        spacing: 8px;
        VerticalLayout {
            alignment: end;
            padding-bottom: 8px;
            TouchArea {
                width: 36px;
                height: 36px;
                enabled: !root.is-disabled;
                Rectangle {
                    border-radius: 18px;
                    background: parent.has-hover ? AppTheme.surface-hover : transparent;
                    Image {
                        source: @image-url("../../assets/icons/paperclip.svg");
                        width: 20px;
                        height: 20px;
                        colorize: root.is-disabled ? AppTheme.text-tertiary : AppTheme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                clicked => {
                    input.focus();
                    root.attach-file();
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            background: AppTheme.surface-tertiary;
            border-radius: AppTheme.radius-lg;
            border-width: 1px;
            border-color: input.has-focus ? AppTheme.accent : AppTheme.border;
            clip: true;

            // Allow taps anywhere in the input shell to focus the text field.
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    input.focus();
                }
            }

                scroll := Flickable {
                width: 100%;
                height: 100%;
                interactive: true;
                viewport-width: self.width;
                viewport-height: Math.max(self.height, input.preferred-height + 16px);

                Rectangle {
                    width: 100%;
                    height: Math.max(parent.height, input.preferred-height);
                    
                    // Slint does not provide a multiline placeholder for this layout.
                    if input.text == "": Text {
                        x: 14px;
                        y: 8px;
                        width: parent.width - 28px;
                        text: root.placeholder;
                        font-size: 18px;
                        color: #777777;
                    }

                    input := TextInput {
                        x: 14px;
                        y: 8px;
                        width: parent.width - 28px;
                        font-size: 18px;
                        color: AppTheme.text-primary;
                        vertical-alignment: top;
                        single-line: false;
                        wrap: word-wrap;
                        enabled: !root.is-disabled;

                        // Keep the cursor visible as the draft grows beyond the viewport.
                        cursor-position-changed(cursor-pos) => {
                            if (cursor-pos.y + scroll.viewport-y < 12px) {
                                scroll.viewport-y = - cursor-pos.y + 12px;
                            } else if (cursor-pos.y + scroll.viewport-y > scroll.height - 32px) {
                                scroll.viewport-y = scroll.height - cursor-pos.y - 32px;
                            }
                        }

                        key-pressed(event) => {
                            if (!root.is-mobile && event.text == Key.Return && !event.modifiers.control) {
                                if (self.text != "") {
                                    root.send-message(self.text);
                                    self.text = "";
                                }
                                return EventResult.accept;
                            }
                            return EventResult.reject;
                        }
                    }
                }
            }
        }

        VerticalLayout {
            alignment: end;
            padding-bottom: 8px;
            TouchArea {
                width: 44px;
                height: 38px;
                enabled: input.text != "" && !root.is-disabled;
                Rectangle {
                    border-radius: 19px;
                    background: input.text == "" ? AppTheme.surface-hover : AppTheme.accent;
                    animate background { duration: 150ms; }
                    Image {
                        source: @image-url("../../assets/icons/send.svg");
                        width: 18px;
                        height: 18px;
                        colorize: input.text == "" ? AppTheme.text-tertiary : #ffffff;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                clicked => {
                    if (input.text != "") {
                        root.send-message(input.text);
                        input.text = "";
                    }
                }
            }
        }
    }
}

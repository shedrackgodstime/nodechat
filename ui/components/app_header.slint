import { AppTheme } from "../theme.slint";

export component AppHeader inherits Rectangle {
    in property <bool> is-desktop: false;
    in property <length> safe-area-top: 0px;
    in property <bool> show-brand: false;
    in property <image> brand-source;
    in property <length> brand-height: 52px;
    in property <bool> show-back: false;
    in property <string> title: "";
    in property <string> subtitle: "";

    callback go-back();

    height: (is-desktop ? 64px : 72px) + root.safe-area-top;
    background: AppTheme.surface-secondary;

    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: AppTheme.divider;
    }

    HorizontalLayout {
        y: root.safe-area-top;
        height: is-desktop ? 64px : 72px;
        padding-left: 12px;
        padding-right: 16px;
        alignment: space-between;

        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            if show-back: VerticalLayout {
                alignment: center;
                TouchArea {
                    width: 32px;
                    height: 32px;
                    clicked => { root.go-back(); }
                    Text {
                        text: is-desktop ? "✕" : "←";
                        font-size: 22px;
                        color: is-desktop ? AppTheme.text-secondary : AppTheme.accent;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            if show-brand: VerticalLayout {
                alignment: center;
                Image {
                    source: brand-source;
                    height: brand-height;
                    image-fit: contain;
                    horizontal-alignment: left;
                }
            }

            if title != "": VerticalLayout {
                alignment: center;
                spacing: subtitle == "" ? 0px : 2px;
                Text {
                    text: title;
                    font-size: 18px;
                    font-weight: 700;
                    color: AppTheme.text-primary;
                    vertical-alignment: center;
                }
                if subtitle != "": Text {
                    text: subtitle;
                    font-size: 12px;
                    color: AppTheme.text-secondary;
                }
                }
            }
    }
}

// NodeChat New — Real-time Debug View
// ---------------------------------------------------------
// 2-D scrollable console for diagnostic logs.
// Vertical scroll: see all lines. Horizontal scroll: read long lines fully.
// "Scroll to Bottom" button jumps to the latest entry.

import { AppTheme } from "../theme.slint";

export component DebugView inherits Rectangle {
    in property <string> debug-logs: "Initializing P2P stack...\nWaiting for Iroh connection...";

    callback copy-clicked(string);
    in property <bool> show-copied: false;

    background: #000000;
    border-radius: AppTheme.radius-md;
    border-width: 1px;
    border-color: root.show-copied ? AppTheme.accent-success : AppTheme.accent;

    VerticalLayout {
        padding: AppTheme.sp-md;
        spacing: AppTheme.sp-sm;

        // ── Header bar ──────────────────────────────────────────
        HorizontalLayout {
            spacing: AppTheme.sp-sm;
            alignment: space-between;

            Text {
                text: "REAL-TIME DIAGNOSTICS";
                font-size: 11px;
                font-weight: 800;
                color: AppTheme.accent;
                vertical-alignment: center;
            }

            HorizontalLayout {
                spacing: AppTheme.sp-sm;
                alignment: end;

                // Scroll-to-bottom button
                bottom-touch := TouchArea {
                    width: 80px;
                    height: 26px;
                    clicked => {
                        // Jump viewport-y to its maximum so user sees latest logs
                        scroll-area.viewport-y = -(scroll-area.viewport-height - scroll-area.height);
                    }
                    Rectangle {
                        background: bottom-touch.pressed ? AppTheme.accent : AppTheme.surface-tertiary;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: AppTheme.accent;
                        animate background { duration: 100ms; }
                        Text {
                            text: "↓ LATEST";
                            font-size: 10px;
                            font-weight: 800;
                            color: bottom-touch.pressed ? #000000 : AppTheme.accent;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Copy button
                copy-touch := TouchArea {
                    width: 72px;
                    height: 26px;
                    clicked => { root.copy-clicked(root.debug-logs); }
                    Rectangle {
                        background: root.show-copied
                            ? AppTheme.accent-success
                            : (copy-touch.pressed ? AppTheme.accent : AppTheme.surface-tertiary);
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: root.show-copied ? AppTheme.accent-success : AppTheme.accent;
                        animate background { duration: 100ms; }
                        Text {
                            text: root.show-copied ? "COPIED ✅" : "COPY";
                            font-size: 10px;
                            font-weight: 800;
                            color: root.show-copied
                                ? #FFFFFF
                                : (copy-touch.pressed ? #000000 : AppTheme.accent);
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ── 2-D scroll console ───────────────────────────────────
        // We use a raw Flickable (not VertScroll) because we explicitly
        // need BOTH axes for this diagnostic console.
        // Min height 300px; expands to fill available parent space.
        Rectangle {
            vertical-stretch: 1;
            min-height: 300px;
            background: #09090B;
            border-radius: 4px;
            clip: true;

            scroll-area := Flickable {
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                // Content always wider / taller than the visible area drives scrolling.
                viewport-width: log-text.preferred-width + 32px;
                viewport-height: log-text.preferred-height + 24px;
                interactive: true;

                log-text := Text {
                    x: 8px;
                    y: 8px;
                    text: root.debug-logs;
                    font-size: 11px;
                    font-family: "monospace";
                    color: #A1A1AA;
                    wrap: no-wrap; // No word-wrap → horizontal scrolling reveals full lines
                }
            }
        }

        // ── Scroll hint (shown when there is content to scroll) ─
        HorizontalLayout {
            alignment: center;
            Text {
                text: "← swipe horizontally • swipe up/down to scroll →";
                font-size: 9px;
                color: AppTheme.text-tertiary;
                opacity: 0.5;
                horizontal-alignment: center;
            }
        }
    }
}

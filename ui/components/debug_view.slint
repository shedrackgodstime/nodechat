// NodeChat New — Real-time Debug View
// ---------------------------------------------------------
// 2-D scrollable console for diagnostic logs.
// Vertical scroll: see all lines. Horizontal scroll: read long lines fully.
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";

export component DebugView inherits Rectangle {
    in property <bool> is-desktop: false;
    in property <string> debug-logs: "Initializing P2P stack...\nWaiting for Iroh connection...";
    in property <bool> show-copied: false;

    callback copy-clicked(string);
    callback refresh-clicked();

    background: #000000;
    border-radius: AppTheme.radius-md;
    border-width: 1px;
    border-color: root.show-copied ? AppTheme.accent-success : AppTheme.accent;

    VerticalLayout {
        padding: AppTheme.sp-md;
        spacing: AppTheme.sp-sm;

        // ── Header bar ──────────────────────────────────────────
        HorizontalLayout {
            spacing: AppTheme.sp-sm;
            alignment: space-between;

            Text {
                text: "SYSTEM DIAGNOSTICS";
                font-size: 11px;
                font-weight: 800;
                color: AppTheme.accent;
                vertical-alignment: center;
            }

            HorizontalLayout {
                spacing: AppTheme.sp-sm;
                alignment: end;

                // Refresh Button (Replaces "Latest")
                refresh-touch := TouchArea {
                    width: 72px;
                    height: 26px;
                    clicked => { root.refresh-clicked(); }
                    Rectangle {
                        background: refresh-touch.pressed ? AppTheme.accent-soft : AppTheme.surface-tertiary;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: AppTheme.accent;
                        animate background { duration: 100ms; }
                        Text {
                            text: "REFRESH";
                            font-size: 10px;
                            font-weight: 800;
                            color: AppTheme.accent;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Copy button
                copy-touch := TouchArea {
                    width: 72px;
                    height: 26px;
                    clicked => { root.copy-clicked(root.debug-logs); }
                    Rectangle {
                        background: root.show-copied
                            ? AppTheme.accent-success
                            : (copy-touch.pressed ? AppTheme.accent : AppTheme.surface-tertiary);
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: root.show-copied ? AppTheme.accent-success : AppTheme.accent;
                        animate background { duration: 100ms; }
                        Text {
                            text: root.show-copied ? "COPIED ✅" : "COPY";
                            font-size: 10px;
                            font-weight: 800;
                            color: root.show-copied
                                ? #FFFFFF
                                : (copy-touch.pressed ? #000000 : AppTheme.accent);
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ── Optimized Console Area ──────────────────────────────
        Rectangle {
            vertical-stretch: 1;
            min-height: is-desktop ? 250px : 350px; // Larger touch target on mobile
            background: #09090B;
            border-radius: 4px;
            clip: true;

            scroll-area := Flickable {
                x: 0; y: 0;
                width: 100%;
                height: 100%;
                viewport-width: Math.max(parent.width, log-text.preferred-width + 32px);
                viewport-height: log-text.preferred-height + 24px;
                
                // CRITICAL FOR MOBILE: 
                // We ensure it is interactive and has a background to catch touches
                interactive: true;

                Rectangle {
                    width: scroll-area.viewport-width;
                    height: scroll-area.viewport-height;
                    background: transparent;
                }

                log-text := Text {
                    x: 12px;
                    y: 12px;
                    text: root.debug-logs;
                    font-size: 11px;
                    font-family: "monospace";
                    color: #A1A1AA;
                    wrap: no-wrap; 
                }
            }
        }

        // ── Mobile UX Hint ─────────────────────────────────────
        HorizontalLayout {
            alignment: center;
            opacity: 0.3;
            Text {
                text: "Double-finger swipe for horizontal view";
                font-size: 9px;
                color: AppTheme.text-tertiary;
                horizontal-alignment: center;
            }
        }
    }
}

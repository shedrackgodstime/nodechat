import { Button, ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";

// ChatInput — Precision Capped Input with Auto-Scroll Tracking
// Implements WhatsApp-style expansion with mandatory 'cursor-in-view' logic.

export component ChatInput inherits Rectangle {
    in property <bool> is-mobile: false;
    in property <length> min-input-height: 52px;
    in property <length> max-bar-height: 140px;
    out property <length> bar-height: min(max-bar-height, max(min-input-height, input.preferred-height + 16px));

    in-out property <string> text <=> input.text;
    out property <bool> has-focus: input.has-focus;

    callback send-message(string);
    callback attach-file();
    public function clear-input-focus() {
        input.clear-focus();
    }

    height: bar-height;
    border-radius: 4px;
    background: #1e1e1e;
    border-width: 1px;
    border-color: #3b3b3b;

    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;

        // --- Attach button (Sticky at bottom) ---
        VerticalLayout {
            alignment: end;
            padding-bottom: 8px;
            Rectangle {
                width: 36px;
                height: 36px;
                border-radius: 18px;
                background: attach-area.has-hover ? #2e2e2e : transparent;
                Text {
                    text: "📎";
                    font-size: 19px;
                    color: AppTheme.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                attach-area := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        input.focus();
                        root.attach-file();
                    }
                }
            }
        }

        // --- Smart Scrollable Center Area ---
        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
            clip: true;

            // Background focus catcher (at the back)
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    input.focus();
                }
            }

            scroll := Flickable {
                width: 100%;
                height: 100%;
                interactive: true;
                viewport-width: self.width;
                viewport-height: max(parent.height, input.preferred-height);

                Rectangle {
                    width: 100%;
                    height: input.preferred-height;
                    if input.text == "": Text {
                        x: 0;
                        y: 0;
                        width: 100%;
                        height: 100%;
                        text: "Type a message...";
                        font-size: 16px;
                        color: #666666;
                        vertical-alignment: center;
                    }

                    input := TextInput {
                        width: 100%;
                        font-size: 16px;
                        color: #ffffff;
                        vertical-alignment: center;
                        single-line: false;
                        wrap: word-wrap;

                        // -- IMPORTANT: Fixes cursor-visibility when capped --
                        cursor-position-changed(cursor-pos) => {
                            // Automatically adjust Flickable position to keep cursor visible
                            if (cursor-pos.y + scroll.viewport-y < 8px) {
                                scroll.viewport-y = - cursor-pos.y + 8px;
                            } else if (cursor-pos.y + scroll.viewport-y > scroll.height - 32px) {
                                scroll.viewport-y = scroll.height - cursor-pos.y - 32px;
                            }
                        }

                        key-pressed(event) => {
                            if (!root.is-mobile && event.text == Key.Return && !event.modifiers.control) {
                                if (self.text != "") {
                                    root.send-message(self.text);
                                    self.text = "";
                                }
                                return EventResult.accept;
                            }
                            return EventResult.reject;
                        }
                    }
                }
            }
        }

        // --- Send button (Sticky at bottom) ---
        VerticalLayout {
            alignment: end;
            padding-bottom: 8px;
            Rectangle {
                width: 44px;
                height: 38px;
                border-radius: 19px;
                background: input.text == "" ? #2a2a2a : #0066cc;
                animate background { duration: 150ms; }
                Text {
                    text: "➤";
                    font-size: 18px;
                    color: input.text == "" ? #555555 : #ffffff;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                send-area := TouchArea {
                    enabled: input.text != "";
                    mouse-cursor: pointer;
                    clicked => {
                        if (input.text != "") {
                            root.send-message(input.text);
                            input.text = "";
                        }
                    }
                }
            }
        }
    }
}

import { AppTheme } from "../theme.slint";

export struct ChatPreview {
    id: string,
    name: string,
    initials: string,
    last-message: string,
    timestamp: string,
    unread: int,
    is-group: bool,
    is-online: bool,
    is-session-ready: bool,
    is-relay: bool,
    is-queued: bool,
    is-verified: bool,
}

export component ContactRow inherits Rectangle {
    in property <string> name: "";
    in property <string> initials: "";
    in property <string> last-message: "";
    in property <string> timestamp: "";
    in property <int> unread: 0;
    in property <bool> is-group: false;
    in property <bool> is-online: false;
    in property <bool> is-session-ready: false;
    in property <bool> is-relay: false;
    in property <bool> is-queued: false;
    in property <bool> is-verified: false;

    callback clicked();

    height: 84px;
    background: touch.has-hover ? AppTheme.surface-hover : AppTheme.surface-primary;
    border-radius: AppTheme.radius-md;
    animate background { duration: AppTheme.dur-short; }

    touch := TouchArea {
        clicked => { root.clicked(); }
        
        HorizontalLayout {
            padding-left: AppTheme.sp-md;
            padding-right: AppTheme.sp-md;
            spacing: AppTheme.sp-md;
            alignment: start;

            // --- Avatar Section ---
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 56px; height: 56px;
                    border-radius: 28px;
                    background: is-group 
                        ? @linear-gradient(135deg, #FF9500 0%, #FF3B30 100%)
                        : @linear-gradient(135deg, AppTheme.accent 0%, #0056b3 100%);
                    
                    Text {
                        text: is-group ? "👥" : initials;
                        font-size: is-group ? 20px : 18px;
                        font-weight: 800;
                        color: #FFFFFF;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    if is-online: Rectangle {
                        x: parent.width - 14px;
                        y: parent.height - 14px;
                        width: 14px; height: 14px;
                        border-radius: 7px;
                        background: is-session-ready ? AppTheme.accent-success : AppTheme.accent-warning;
                        border-width: 2px;
                        border-color: root.background;
                    }
                }
            }

            // --- Content Section ---
            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                spacing: AppTheme.sp-xs;

                HorizontalLayout {
                    alignment: space-between;
                    Text {
                        text: name;
                        font-size: 16px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                        overflow: elide;
                    }
                    Text {
                        text: timestamp;
                        font-size: 12px;
                        color: unread > 0 ? AppTheme.accent : AppTheme.text-tertiary;
                    }
                }

                HorizontalLayout {
                    spacing: AppTheme.sp-sm;
                    alignment: start;

                    if is-verified: Text { text: "✓"; font-size: 13px; color: AppTheme.accent-success; vertical-alignment: center; }
                    if is-relay: Text { text: "⇁"; font-size: 13px; color: AppTheme.accent-warning; vertical-alignment: center; }
                    if is-queued: Text { text: "⏳"; font-size: 13px; color: AppTheme.accent-warning; vertical-alignment: center; }

                    Text {
                        horizontal-stretch: 1;
                        text: last-message != "" ? last-message : "P2P Handshake ready";
                        font-size: 14px;
                        color: AppTheme.text-tertiary;
                        overflow: elide;
                        vertical-alignment: center;
                    }

                    if unread > 0: Rectangle {
                        width: 24px; height: 20px;
                        border-radius: 10px;
                        background: AppTheme.accent;
                        Text {
                            text: unread > 99 ? "99+" : unread;
                            font-size: 10px; font-weight: 800; color: #FFFFFF;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // --- Bottom Divider ---
    Rectangle {
        y: parent.height - 1px;
        x: 84px;
        width: parent.width - 84px;
        height: 1px;
        background: AppTheme.divider;
    }
}

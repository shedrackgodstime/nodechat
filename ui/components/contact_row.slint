import { AppTheme } from "../theme.slint";

// ContactRow — Professional Left-Aligned Messaging Row (Stability Fix)
// Resolved non-layout padding warnings and potential width binding loops.

export component ContactRow inherits Rectangle {
    in property <string>  name: "";
    in property <string>  last-message: "";
    in property <string>  timestamp: "";
    in property <int>     unread: 0;
    in property <bool>    is-group: false;
    in property <bool>    is-online: false;
    in property <bool>    is-relay: false;
    in property <bool>    is-queued: false;
    in property <bool>    is-verified: false;
    in property <bool>    is-selected: false;
    in property <string>  initials: "";

    callback clicked();

    min-height: 74px;
    background: is-selected ? AppTheme.surface-tertiary : AppTheme.surface-primary;

    animate background { duration: 150ms; easing: ease-out; }

    TouchArea {
        clicked => { root.clicked(); }

        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            spacing: 14px;
            alignment: start; 

            // ---- Avatar Section ----
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 52px;
                    height: 52px;
                    
                    Rectangle {
                        width: 100%; height: 100%;
                        border-radius: 26px;
                        background: is-group ? AppTheme.surface-tertiary : AppTheme.accent;
                    }

                    Text {
                        text: initials != "" ? initials : (is-group ? "GR" : "?");
                        font-size: 18px;
                        font-weight: 700;
                        color: #FFFFFF;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    if !is-group: Rectangle {
                        x: parent.width - 14px;
                        y: parent.height - 14px;
                        width: 16px;
                        height: 16px;
                        border-radius: 8px;
                        background: AppTheme.surface-primary;

                        Rectangle {
                            x: 2px; y: 2px;
                            width: 12px; height: 12px;
                            border-radius: 6px;
                            background:
                                is-online && !is-relay ? AppTheme.accent-success :
                                is-relay               ? AppTheme.accent-warning  :
                                AppTheme.surface-tertiary;
                        }
                    }
                }
            }

            // ---- Content Section ----
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 2px;
                alignment: center;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: name;
                        font-size: 16px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                        horizontal-stretch: 1;
                        overflow: elide;
                        vertical-alignment: center;
                    }

                    if is-verified: VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 14px; height: 14px;
                            border-radius: 7px;
                            background: AppTheme.accent-success;
                            Text {
                                text: "✓"; font-size: 9px; font-weight: 900; color: #FFFFFF;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }

                    Text {
                        text: timestamp;
                        font-size: 12px;
                        color: unread > 0 ? AppTheme.accent-success : AppTheme.text-tertiary;
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text:
                            is-queued ? unread + " msgs waiting" :
                            !is-verified ? "Safety keys not verified" :
                            last-message;
                        font-size: 14px;
                        color:
                            is-queued    ? AppTheme.accent-warning :
                            !is-verified ? AppTheme.accent-warning :
                            AppTheme.text-secondary;
                        horizontal-stretch: 1;
                        overflow: elide;
                        vertical-alignment: center;
                    }

                    if unread > 0 && !is-queued: VerticalLayout {
                        alignment: center;
                        Rectangle {
                            min-width: 20px;
                            height: 20px;
                            border-radius: 10px;
                            background: AppTheme.accent-success;
                            
                            HorizontalLayout {
                                padding-left: 6px;
                                padding-right: 6px;
                                Text {
                                    text: unread > 99 ? "99+" : unread;
                                    font-size: 10px; font-weight: 900; color: #FFFFFF;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Divider (Stability Fix: No width-loop binding)
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        x: 82px; 
        width: root.width - 82px; // Binding to root (Rectangle) is safer than parent in loops
        background: AppTheme.divider;
        opacity: 0.15;
    }
}
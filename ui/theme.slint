// NodeChat Design System — Dark Mode
// Tokens defined here, referenced everywhere. Never hardcode hex in components.

export global AppTheme {
    // --- Surface Colors ---
    out property <color> surface-primary:   #1C1C1E;
    out property <color> surface-secondary: #2C2C2E;
    out property <color> surface-tertiary:  #3A3A3C;

    // --- Accent Colors ---
    out property <color> accent:          #4A9EE8;   // Sent bubbles, CTAs, links
    out property <color> accent-success:  #34C774;   // Online, verified
    out property <color> accent-warning:  #F4A623;   // Relay mode, unverified
    out property <color> accent-danger:   #FF453A;   // Errors, destructive

    // --- Text Colors ---
    out property <color> text-primary:   #FFFFFF;
    out property <color> text-secondary: #8E8E93;
    out property <color> text-tertiary:  #636366;

    // --- Chat Bubble Colors ---
    out property <color> bubble-out: #1A5FA8;  // Outgoing  (strong blue)
    out property <color> bubble-in:  #2C2C2E;  // Incoming  (surface-secondary)

    // --- Divider ---
    out property <color> divider: #3A3A3C;

    // --- Spacing ---
    out property <length> sp-xs:  4px;
    out property <length> sp-sm:  8px;
    out property <length> sp-md: 16px;
    out property <length> sp-lg: 24px;

    // --- Radius ---
    out property <length> radius-sm:  8px;
    out property <length> radius-md: 12px;
    out property <length> radius-lg: 20px;
    out property <length> radius-pill: 22px;
}

// NodeChat Design System — Dark Mode
// Tokens defined here, referenced everywhere. Never hardcode hex in components.

export global AppTheme {
    // --- Surface Colors (Premium Charcoal/Navy palette) ---
    out property <color> surface-primary:   #0F0F10;   // Deepest background
    out property <color> surface-secondary: #1C1C1E;   // Main cards/headers
    out property <color> surface-tertiary:  #2C2C2E;   // Dividers/Input fields
    out property <color> surface-hover:     #3A3A3C;

    // --- Accent Colors (Vibrant Electric Blue) ---
    out property <color> accent:          #0A84FF;   // Primary Action
    out property <color> accent-gradient: #0A84FF;   // Used for gradients
    out property <color> accent-soft:     rgba(10, 132, 255, 0.15);
    out property <color> accent-success:  #32D74B;   // Online/Secure
    out property <color> accent-warning:  #FFD60A;   // Relay/Pending
    out property <color> accent-danger:   #FF453A;   // Error/Delete

    // --- Text Colors (High Contrast) ---
    out property <color> text-primary:   #FFFFFF;
    out property <color> text-secondary: #EBEBF5;   // 60% opacity secondary
    out property <color> text-tertiary:  #8E8E93;   // Muted
    out property <color> text-inverted:  #000000;

    // --- Chat Bubble Palette ---
    out property <color> bubble-out:      #007AFF;
    out property <color> bubble-out-text: #FFFFFF;
    out property <color> bubble-in:       #262629;
    out property <color> bubble-in-text:  #FFFFFF;

    // --- Dividers & Borders ---
    out property <color> divider: rgba(255, 255, 255, 0.08);
    out property <color> border:  rgba(255, 255, 255, 0.12);

    // --- Spacing (8pt Grid) ---
    out property <length> sp-xs: 4px;
    out property <length> sp-sm: 8px;
    out property <length> sp-md: 16px;
    out property <length> sp-lg: 24px;
    out property <length> sp-xl: 32px;

    // --- Rounded Corners ---
    out property <length> radius-sm:   8px;
    out property <length> radius-md:  12px;
    out property <length> radius-lg:  20px;
    out property <length> radius-xl:  28px;
    out property <length> radius-pill: 99px;

    // --- Animation Timings ---
    out property <duration> dur-short: 150ms;
    out property <duration> dur-md:    300ms;
}


// NodeChat New — Information Screen (Contact & Group Info)
// ---------------------------------------------------------

import { AppTheme, VertScroll } from "../theme.slint";
import { ActionRow } from "../components/action_row.slint";
import { ContactData, GroupData } from "../components/row_data.slint";
import { Button } from "../components/button.slint";

component ActionCircle inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> active: true;
    in property <color> tint: AppTheme.accent;
    callback clicked();

    width: 72px;
    height: 80px;

    VerticalLayout {
        spacing: 8px;
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 48px;
                height: 48px;
                border-radius: 24px;
                background: AppTheme.surface-secondary;
                border-width: 1px;
                border-color: AppTheme.divider;
                
                Image {
                    source: icon;
                    width: 22px;
                    height: 22px;
                    colorize: tint;
                }

                TouchArea {
                    clicked => { clicked(); }
                }
            }
        }
        Text {
            text: label;
            font-size: 11px;
            font-weight: 700;
            color: tint;
            horizontal-alignment: center;
        }
    }
}

export component InfoScreen inherits Rectangle {
    in property <bool> is-group: false;
    in property <ContactData> contact;
    in property <GroupData> group;
    in property <bool> is-desktop: false;

    callback back-clicked();
    callback chat-clicked();
    callback toggle-verify(bool);
    callback copy-text(string);
    callback request-clear-history();
    callback request-delete();
    callback add-members();
    callback share-clicked();

    in property <bool> show-copied: false;
    property <bool> show-copied-row1: false;
    property <bool> show-copied-row2: false;

    Timer {
        interval: 2000ms;
        running: root.show-copied-row1 || root.show-copied-row2;
        triggered => {
            root.show-copied-row1 = false;
            root.show-copied-row2 = false;
        }
    }

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // 1. Header (Mirrors PasswordScreen consistency)
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;
            
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { 
                        text: "←"; 
                        font-size: 24px; 
                        color: AppTheme.text-primary; 
                        vertical-alignment: center; 
                        horizontal-alignment: center;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Text { 
                        text: is-group ? "Group Info" : "Peer Identity"; 
                        font-size: is-desktop ? 24px : 18px; 
                        font-weight: 700; 
                        color: AppTheme.text-primary; 
                    }
                    Text { 
                        text: is-group ? "Manage swarm settings and keys" : "View network identifiers and trust"; 
                        font-size: 13px; 
                        color: AppTheme.text-secondary; 
                    }
                }
            }
        }

        // 2. Body
        VertScroll {
            vertical-stretch: 1;
            viewport-height: body.preferred-height;

            body := VerticalLayout {
                width: parent.width;
                padding: AppTheme.sp-md;
                padding-top: AppTheme.sp-xl;
                spacing: AppTheme.sp-lg;
                alignment: start;

                // --- 1. Hero Summary ---
                Rectangle {
                    background: AppTheme.surface-secondary;
                    border-radius: AppTheme.radius-lg;
                    border-width: 1px;
                    border-color: AppTheme.divider;
                    
                    HorizontalLayout {
                        padding: AppTheme.sp-lg;
                        spacing: AppTheme.sp-lg;
                        alignment: start;

                        // Avatar
                        Rectangle {
                            width: 64px;
                            height: 64px;
                            border-radius: 32px;
                            background: AppTheme.accent-soft;
                            border-width: 1px;
                            border-color: AppTheme.accent;

                            Text {
                                text: is-group ? group.initials : contact.initials;
                                font-size: 24px;
                                font-weight: 800;
                                color: AppTheme.accent;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 4px;
                            Text {
                                text: is-group ? group.name : contact.name;
                                font-size: 20px;
                                font-weight: 700;
                                color: AppTheme.text-primary;
                            }
                            Text {
                                text: is-group ? (group.member-count + " Active Members") : (contact.is-online ? "Connected via " + (contact.is-relay ? "Relay" : "Direct P2P") : "Identity Offline");
                                font-size: 13px;
                                font-weight: 600;
                                color: (is-group || !contact.is-online) ? AppTheme.text-tertiary : AppTheme.accent-success;
                            }
                        }
                    }
                }

                // --- 2. Action Controls (PRO Action Bar Card) ---
                Rectangle {
                    background: AppTheme.surface-secondary;
                    border-radius: AppTheme.radius-lg;
                    border-width: 1px;
                    border-color: AppTheme.divider;
                    
                    HorizontalLayout {
                        alignment: center;
                        spacing: is-desktop ? 40px : 24px;
                        padding-top: AppTheme.sp-lg;
                        padding-bottom: AppTheme.sp-lg;
                        padding-left: AppTheme.sp-md;
                        padding-right: AppTheme.sp-md;

                        // 1. Message
                        ActionCircle {
                            label: "Message";
                            icon: @image-url("../images/nav/chats.svg");
                            clicked => { root.chat-clicked(); }
                        }

                        // 2. Share
                        if !is-group : ActionCircle {
                            label: "Share";
                            icon: @image-url("../images/nav/globe.svg");
                            clicked => { root.share-clicked(); }
                        }

                        // 3. Add (Group Only)
                        if is-group : ActionCircle {
                            label: "Add Member";
                            icon: @image-url("../images/nav/add.svg");
                            clicked => { root.add-members(); }
                        }

                        // 4. Verify (Peer Only)
                        if !is-group : ActionCircle {
                            label: contact.is-verified ? "Verified" : "Verify";
                            icon: @image-url("../images/nav/check.svg");
                            tint: contact.is-verified ? AppTheme.accent-success : AppTheme.accent;
                            clicked => { root.toggle-verify(!contact.is-verified); }
                        }
                    }
                }

                // --- 3. Persistent Data (Improved Display) ---
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: is-group ? "PROTOCOL DATA" : "IDENTIFIERS"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1.5px; }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        clip: true;

                        VerticalLayout {
                            row1 := TouchArea {
                                clicked => { 
                                    root.copy-text(is-group ? group.topic : contact.node-id); 
                                    root.show-copied-row1 = true;
                                }
                                Rectangle {
                                    background: row1.has-hover ? AppTheme.surface-hover : transparent;
                                    VerticalLayout {
                                        padding: AppTheme.sp-md;
                                        spacing: 8px;
                                        HorizontalLayout {
                                            alignment: space-between;
                                            Text { text: is-group ? "TOPIC / SWARM ID" : "NODE ID"; font-size: 10px; font-weight: 900; color: root.show-copied-row1 ? AppTheme.accent-success : AppTheme.accent; letter-spacing: 0.5px; }
                                            Text { text: root.show-copied-row1 ? "COPIED ✅" : "COPY"; font-size: 10px; font-weight: 800; color: root.show-copied-row1 ? AppTheme.accent-success : AppTheme.text-tertiary; }
                                        }
                                        Text {
                                            text: is-group ? group.topic : contact.node-id;
                                            font-family: "monospace";
                                            font-size: 13px;
                                            color: AppTheme.text-primary;
                                            wrap: char-wrap;
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 1px; background: AppTheme.divider; }

                            row2 := TouchArea {
                                clicked => { 
                                    root.copy-text(is-group ? group.id : contact.ticket); 
                                    root.show-copied-row2 = true;
                                }
                                Rectangle {
                                    background: row2.has-hover ? AppTheme.surface-hover : transparent;
                                    VerticalLayout {
                                        padding: AppTheme.sp-md;
                                        spacing: 8px;
                                        HorizontalLayout {
                                            alignment: space-between;
                                            Text { text: is-group ? "GROUP ID" : "ENDPOINT TICKET"; font-size: 10px; font-weight: 900; color: root.show-copied-row2 ? AppTheme.accent-success : AppTheme.accent; }
                                            Text { text: root.show-copied-row2 ? "COPIED ✅" : "COPY"; font-size: 10px; font-weight: 800; color: root.show-copied-row2 ? AppTheme.accent-success : AppTheme.text-tertiary; }
                                        }
                                        Text {
                                            text: is-group ? group.id : (contact.ticket != "" ? contact.ticket : "Identity offline");
                                            font-family: "monospace";
                                            font-size: 13px;
                                            color: AppTheme.text-tertiary;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // --- 4. Danger Zone ---
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "DANGER ZONE"; font-size: 11px; font-weight: 800; color: AppTheme.accent-danger; letter-spacing: 1.5px; }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        clip: true;

                        VerticalLayout {
                            ActionRow {
                                icon-svg: @image-url("../images/nav/delete.svg");
                                title: "Clear History";
                                subtitle: "Delete all messages for this chat";
                                is-danger: true;
                                clicked => { root.request-clear-history(); }
                            }
                            HorizontalLayout { padding-left: 56px; Rectangle { height: 1px; background: AppTheme.divider; } }
                            ActionRow {
                                icon-svg: @image-url("../images/nav/warning.svg");
                                title: is-group ? "Leave Group" : "Remove Contact";
                                subtitle: is-group ? "Exit the p2p conversation" : "Irreversibly unlink peer";
                                is-danger: true;
                                clicked => { root.request-delete(); }
                            }
                        }
                    }
                }

                // Bottom safe area spacer
                Rectangle { height: 40px; }
            }
        }
    }
}

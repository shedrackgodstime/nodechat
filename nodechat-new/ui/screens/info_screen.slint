// NodeChat New — Information Screen (Contact & Group Info)
// ---------------------------------------------------------

import { AppTheme, VertScroll } from "../theme.slint";
import { ActionRow } from "../components/action_row.slint";
import { ContactData, GroupData } from "../components/row_data.slint";
import { Button } from "../components/button.slint";

export component InfoScreen inherits Rectangle {
    in property <bool> is-group: false;
    in property <ContactData> contact;
    in property <GroupData> group;
    in property <bool> is-desktop: false;

    callback back-clicked();
    callback chat-clicked();
    callback toggle-verify(bool);
    callback copy-text(string);
    callback request-clear-history();
    callback request-delete();
    callback add-members();

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // 1. Header (Mirrors PasswordScreen consistency)
        Rectangle {
            height: is-desktop ? 90px : 74px;
            background: AppTheme.surface-secondary;
            
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { 
                        text: "←"; 
                        font-size: 24px; 
                        color: AppTheme.text-primary; 
                        vertical-alignment: center; 
                        horizontal-alignment: center;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Text { 
                        text: is-group ? "Group Info" : "Peer Identity"; 
                        font-size: is-desktop ? 24px : 18px; 
                        font-weight: 700; 
                        color: AppTheme.text-primary; 
                    }
                    Text { 
                        text: is-group ? "Manage swarm settings and keys" : "View network identifiers and trust"; 
                        font-size: 13px; 
                        color: AppTheme.text-secondary; 
                    }
                }
            }
        }

        // 2. Body
        VertScroll {
            vertical-stretch: 1;
            viewport-height: body.preferred-height;

            body := VerticalLayout {
                width: parent.width;
                padding: AppTheme.sp-md;
                padding-top: AppTheme.sp-xl;
                spacing: AppTheme.sp-lg;
                alignment: start;

                // --- 1. Hero Summary ---
                Rectangle {
                    background: AppTheme.surface-secondary;
                    border-radius: AppTheme.radius-lg;
                    border-width: 1px;
                    border-color: AppTheme.divider;
                    
                    HorizontalLayout {
                        padding: AppTheme.sp-lg;
                        spacing: AppTheme.sp-lg;
                        alignment: start;

                        // Avatar
                        Rectangle {
                            width: 64px;
                            height: 64px;
                            border-radius: 32px;
                            background: AppTheme.accent-soft;
                            border-width: 1px;
                            border-color: AppTheme.accent;

                            Text {
                                text: is-group ? group.initials : contact.initials;
                                font-size: 24px;
                                font-weight: 800;
                                color: AppTheme.accent;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 4px;
                            Text {
                                text: is-group ? group.name : contact.name;
                                font-size: 20px;
                                font-weight: 700;
                                color: AppTheme.text-primary;
                            }
                            Text {
                                text: is-group ? (group.member-count + " Active Members") : (contact.is-online ? "Connected via " + (contact.is-relay ? "Relay" : "Direct P2P") : "Identity Offline");
                                font-size: 13px;
                                font-weight: 600;
                                color: (is-group || !contact.is-online) ? AppTheme.text-tertiary : AppTheme.accent-success;
                            }
                        }
                    }
                }

                // --- 2. Action Controls ---
                HorizontalLayout {
                    spacing: AppTheme.sp-md;
                    Button {
                        text: "Message Now";
                        kind: "primary";
                        horizontal-stretch: 1;
                        clicked => { root.chat-clicked(); }
                    }
                    if is-group : Button {
                        text: "Add Member";
                        kind: "secondary";
                        horizontal-stretch: 0;
                        clicked => { root.add-members(); }
                    }
                    if !is-group : Button {
                        text: contact.is-verified ? "Verified" : "Verify";
                        kind: "secondary";
                        icon-svg: contact.is-verified ? @image-url("../../assets/icons/check.svg") : @image-url("");
                        horizontal-stretch: 0;
                        clicked => { root.toggle-verify(!contact.is-verified); }
                    }
                }

                // --- 3. Persistent Data (Improved Display) ---
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: is-group ? "PROTOCOL DATA" : "IDENTIFIERS"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1.5px; }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        clip: true;

                        VerticalLayout {
                            // Node ID / Topic
                            row1 := TouchArea {
                                clicked => { root.copy-text(is-group ? group.topic : contact.node-id); }
                                Rectangle {
                                    background: row1.has-hover ? AppTheme.surface-hover : transparent;
                                    VerticalLayout {
                                        padding: AppTheme.sp-md;
                                        spacing: 8px;
                                        HorizontalLayout {
                                            alignment: space-between;
                                            Text { text: is-group ? "TOPIC ID" : "PUBLIC NODE ID"; font-size: 10px; font-weight: 900; color: AppTheme.accent; letter-spacing: 0.5px; }
                                            Text { text: "COPY"; font-size: 10px; font-weight: 800; color: AppTheme.text-tertiary; }
                                        }
                                        Text {
                                            text: is-group ? group.topic : contact.node-id;
                                            font-family: "monospace";
                                            font-size: 13px;
                                            color: AppTheme.text-primary;
                                            wrap: char-wrap;
                                        }
                                    }
                                }
                            }

                            Rectangle { height: 1px; background: AppTheme.divider; }

                            // Secret Key / Endpoint
                            row2 := TouchArea {
                                clicked => { root.copy-text(is-group ? group.secret-key : "node_" + contact.id); }
                                Rectangle {
                                    background: row2.has-hover ? AppTheme.surface-hover : transparent;
                                    VerticalLayout {
                                        padding: AppTheme.sp-md;
                                        spacing: 8px;
                                        HorizontalLayout {
                                            alignment: space-between;
                                            Text { text: is-group ? "SECRET SWARM KEY" : "LOCAL REFERENCE"; font-size: 10px; font-weight: 900; color: AppTheme.accent; }
                                            Text { text: "COPY"; font-size: 10px; font-weight: 800; color: AppTheme.text-tertiary; }
                                        }
                                        Text {
                                            text: is-group ? "••••••••••••••••••••••••••••••••" : "node_" + contact.id;
                                            font-family: "monospace";
                                            font-size: 13px;
                                            color: AppTheme.text-tertiary;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // --- 4. Danger Zone ---
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "DANGER ZONE"; font-size: 11px; font-weight: 800; color: AppTheme.accent-danger; letter-spacing: 1.5px; }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        clip: true;

                        VerticalLayout {
                            ActionRow {
                                icon: "🗑️";
                                title: "Clear History";
                                subtitle: "Delete all messages for this chat";
                                is-danger: true;
                                clicked => { root.request-clear-history(); }
                            }
                            HorizontalLayout { padding-left: 56px; Rectangle { height: 1px; background: AppTheme.divider; } }
                            ActionRow {
                                icon: "🧨";
                                title: is-group ? "Leave Group" : "Remove Contact";
                                subtitle: is-group ? "Exit the p2p conversation" : "Irreversibly unlink peer";
                                is-danger: true;
                                clicked => { root.request-delete(); }
                            }
                        }
                    }
                }

                // Bottom safe area spacer
                Rectangle { height: 40px; }
            }
        }
    }
}

// NodeChat New — Contacts Screen
// ---------------------------------------------------------

import { AppTheme, VertScroll } from "../theme.slint";
import { ActionRow } from "../components/action_row.slint";
import { ContactData } from "../components/row_data.slint";

export component ContactsScreen inherits Rectangle {
    in property <[ContactData]> contacts: [];
    in property <bool> is-desktop: false;

    callback back-clicked();
    callback add-contact();
    callback new-group();
    callback open-contact(ContactData);

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // 1. Header
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;

            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { text: "←"; font-size: 24px; color: AppTheme.text-primary; vertical-alignment: center; }
                }

                VerticalLayout {
                    alignment: center;
                    Text { text: "Contacts"; font-size: is-desktop ? 28px : 18px; font-weight: 700; color: AppTheme.text-primary; }
                    Text { text: "Your P2P Network"; font-size: 13px; color: AppTheme.text-secondary; }
                }
            }
        }

        // 2. Body
        VertScroll {
            vertical-stretch: 1;
            viewport-height: contacts-body.preferred-height;

            contacts-body := VerticalLayout {
                width: parent.width;
                padding: AppTheme.sp-md;
                spacing: AppTheme.sp-lg;
                alignment: start;

                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "QUICK ACTIONS"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        clip: true;

                        VerticalLayout {
                            ActionRow {
                                icon: "➕";
                                title: "Add Peer by Ticket";
                                subtitle: "Invite someone new";
                                clicked => { root.add-contact(); }
                            }
                            HorizontalLayout { padding-left: 56px; Rectangle { height: 1px; background: AppTheme.divider; } }
                            ActionRow {
                                icon: "👥";
                                title: "New Group Chat";
                                clicked => { root.new-group(); }
                            }
                        }
                    }
                }

                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text { text: "PEER DIRECTORY"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }

                    if root.contacts.length == 0 : Rectangle {
                        height: 120px;
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        Text { text: "No contacts found."; color: AppTheme.text-tertiary; horizontal-alignment: center; vertical-alignment: center; }
                    }

                    VerticalLayout {
                        spacing: 2px;
                        for contact in root.contacts : ActionRow {
                            title: contact.name;
                            subtitle: contact.node-id;
                            initials: contact.initials;
                            is-online: contact.is-online;
                            is-relay: contact.is-relay;
                            is-verified: contact.is-verified;
                            accessory: "arrow";
                            clicked => { root.open-contact(contact); }
                        }
                    }
                }
            }
        }
    }
}

// NodeChat New — Contacts Directory
// ---------------------------------------------------------
// Peer address book for 1:1 and group communication.
// Layout:
//   1. Quick Actions (Add Contact, Create Group)
//   2. Peer Directory (Scrollable list of ContactRows)
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";
import { PageShell } from "../components/page_shell.slint";
import { ActionRow } from "../components/action_row.slint";
import { ContactData } from "../components/row_data.slint";

export { ContactData }

export component ContactsScreen inherits PageShell {
    title: "Contacts";
    subtitle: "Your P2P Network";
    show-back: true;

    in property <[ContactData]> contacts: [];

    callback add-contact();
    callback new-group();
    callback open-contact(ContactData);

    background: transparent;

    VerticalLayout {
        spacing: AppTheme.sp-lg;
        padding-bottom: AppTheme.sp-xl;

        // --- 1. Quick Actions ---
        VerticalLayout {
            spacing: AppTheme.sp-sm;
            HorizontalLayout {
                padding-left: AppTheme.sp-sm;
                Text {
                    text: "QUICK ACTIONS";
                    font-size: 11px;
                    font-weight: 800;
                    color: AppTheme.text-tertiary;
                    letter-spacing: 1px;
                }
            }

            Rectangle {
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;
                border-width: 1px;
                border-color: AppTheme.divider;
                clip: true;

                VerticalLayout {
                    ActionRow {
                        icon-svg: @image-url("../images/nav/add.svg");
                        title: "Add Peer by Ticket";
                        subtitle: "Invite someone new to your network";
                        accessory: "arrow";
                        clicked => { root.add-contact(); }
                    }
                    HorizontalLayout { padding-left: 56px; Rectangle { height: 1px; background: AppTheme.divider; } }
                    ActionRow {
                        icon-svg: @image-url("../images/nav/contacts.svg");
                        icon-color: #FF9500;
                        title: "New Group Chat";
                        subtitle: "Broadcast to multiple peers";
                        accessory: "arrow";
                        clicked => { root.new-group(); }
                    }
                }
            }
        }

        // --- 2. Directory ---
        VerticalLayout {
            spacing: AppTheme.sp-sm;
            HorizontalLayout {
                padding-left: AppTheme.sp-sm;
                Text {
                    text: "PEER DIRECTORY";
                    font-size: 11px;
                    font-weight: 800;
                    color: AppTheme.text-tertiary;
                    letter-spacing: 1px;
                }
            }

            if contacts.length == 0 : Rectangle {
                height: 200px;
                background: AppTheme.surface-secondary;
                border-radius: AppTheme.radius-lg;
                border-width: 1px;
                border-color: AppTheme.divider;

                VerticalLayout {
                    alignment: center;
                    spacing: AppTheme.sp-sm;
                    Text { text: "👤"; font-size: 40px; horizontal-alignment: center; }
                    Text { text: "Your address book is empty"; font-size: 16px; font-weight: 700; color: AppTheme.text-primary; horizontal-alignment: center; }
                    Text { text: "Invite friends via ticket to start chatting."; font-size: 13px; color: AppTheme.text-tertiary; horizontal-alignment: center; }
                }
            }

            VerticalLayout {
                spacing: 2px;
                for contact in root.contacts : ActionRow {
                    title: contact.name;
                    subtitle: contact.node-id;
                    initials: contact.initials;
                    is-online: contact.is-online;
                    is-relay: contact.is-relay;
                    is-verified: contact.is-verified;
                    accessory: "arrow";
                    clicked => { root.open-contact(contact); }
                }
            }
        }
    }
}

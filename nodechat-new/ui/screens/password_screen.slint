// NodeChat New — Setup/Change Password Screen
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";
import { Button } from "../components/button.slint";
import { FormInput } from "../components/form_input.slint";

export component PasswordScreen inherits Rectangle {
    in property <bool> is-desktop: false;
    in property <bool> has-password: false;
    
    callback back-clicked();
    /// Fired when confirming a new password. If has-password is true, current-pin is provided, otherwise it's empty.
    callback confirm-password(string, string);
    /// Fired to remove the password.
    callback remove-password(string);

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // 1. Header
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => { root.back-clicked(); }
                    Text { text: "←"; font-size: 24px; color: AppTheme.text-primary; vertical-alignment: center; }
                }

                VerticalLayout {
                    alignment: center;
                    Text { 
                        text: root.has-password ? "Change Password" : "Setup Password"; 
                        font-size: is-desktop ? 28px : 18px; 
                        font-weight: 700; 
                        color: AppTheme.text-primary; 
                    }
                    Text { 
                        text: root.has-password ? "Update your security credentials" : "Lock your vault (Optional)"; 
                        font-size: 13px; color: AppTheme.text-secondary; 
                    }
                }
            }
        }

        // 2. Content
        VerticalLayout {
            padding: AppTheme.sp-lg;
            spacing: AppTheme.sp-lg;

            if !root.has-password: VerticalLayout {
                spacing: AppTheme.sp-sm;
                Text { text: "ENABLE LOCAL ENCRYPTION"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                
                Rectangle {
                    background: AppTheme.surface-secondary;
                    border-radius: AppTheme.radius-md;
                    border-width: 1px;
                    border-color: AppTheme.divider;

                    VerticalLayout {
                        padding: AppTheme.sp-md;
                        Text { 
                            text: "Setting up a password encrypts your identity and chat history locally on this device. NodeChat has no servers, so there is no password reset process. If you forget your password, your vault cannot be recovered.";
                            font-size: 13px;
                            color: AppTheme.text-secondary;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: AppTheme.sp-sm;
                visible: root.has-password;
                Text { text: "CURRENT PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                current-input := FormInput {
                    placeholder: "Enter current password...";
                    input-type: InputType.password;
                }
            }

            VerticalLayout {
                spacing: AppTheme.sp-sm;
                Text { text: "NEW PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                new-input := FormInput {
                    placeholder: "Enter new password...";
                    input-type: InputType.password;
                }
            }

            VerticalLayout {
                spacing: AppTheme.sp-sm;
                Text { text: "CONFIRM PASSWORD"; font-size: 11px; font-weight: 800; color: AppTheme.text-tertiary; letter-spacing: 1px; }
                confirm-input := FormInput {
                    placeholder: "Re-enter new password...";
                    input-type: InputType.password;
                }
            }
            
            if new-input.text != "" && new-input.text != confirm-input.text : Text {
                text: "Passwords do not match.";
                color: AppTheme.accent-danger;
                font-size: 12px;
            }

            // A spacer
            Rectangle { height: 8px; }

            Button {
                text: root.has-password ? "Save New Password" : "Secure Vault";
                kind: "primary";
                enabled: new-input.text != "" && (new-input.text == confirm-input.text) && (!root.has-password || current-input.text != "");
                clicked => { root.confirm-password(root.has-password ? current-input.text : "", new-input.text); }
            }

            if root.has-password : Button {
                text: "Remove Password";
                kind: "danger";
                enabled: current-input.text != "";
                clicked => { root.remove-password(current-input.text); }
            }

            Rectangle { vertical-stretch: 1; }
        }
    }
}

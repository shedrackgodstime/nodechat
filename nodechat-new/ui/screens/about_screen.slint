// NodeChat New — About & Diagnostics Screen
// ---------------------------------------------------------

import { AppTheme, VertScroll } from "../theme.slint";
import { ActionRow } from "../components/action_row.slint";
import { AppInfo } from "../components/row_data.slint";
import { DebugView } from "../components/debug_view.slint";

export component AboutScreen inherits Rectangle {
    in property <AppInfo> app-info;
    in property <bool> is-desktop: false;
    
    // State to toggle debug view
    property <bool> show-debug: false;
    in property <bool> show-copied: false;
    in property <string> debug-logs: "[NodeChat] Waiting for events...";

    callback back-clicked();
    callback open-url(string);
    callback copy-logs(string);

    background: AppTheme.surface-primary;

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // 1. Header (Follows ContactsScreen Pattern)
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: AppTheme.surface-secondary;

            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: AppTheme.divider;
            }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                TouchArea {
                    width: 32px;
                    clicked => {
                        root.back-clicked();
                    }
                    Text {
                        text: "←";
                        font-size: 24px;
                        color: AppTheme.text-primary;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "About " + root.app-info.name;
                        font-size: is-desktop ? 28px : 18px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                    }

                    if is-desktop: Text {
                        text: "Project Information & Diagnostics";
                        font-size: 13px;
                        color: AppTheme.text-secondary;
                    }
                }
            }
        }

        // 2. Body
        VertScroll {
            vertical-stretch: 1;
            viewport-height: about-body.preferred-height;

            about-body := VerticalLayout {
                width: parent.width;
                padding: AppTheme.sp-md;
                spacing: AppTheme.sp-lg;
                alignment: start;

                // --- 1. PREMIUM BRANDING ---
                VerticalLayout {
                    spacing: AppTheme.sp-md;
                    padding-top: AppTheme.sp-lg;
                    padding-bottom: AppTheme.sp-lg;
                    Rectangle {
                        width: 280px;
                        height: 120px;
                        x: (parent.width - self.width) / 2;
                        Image {
                            source: @image-url("../../assets/images/app_logo_with_name_transparent_bg.png");
                            width: 100%;
                            height: 100%;
                            image-fit: contain;
                        }
                    }

                    VerticalLayout {
                        spacing: AppTheme.sp-xs;
                        Text {
                            text: root.app-info.version-type + " " + root.app-info.version;
                            font-size: 13px;
                            font-weight: 700;
                            color: AppTheme.accent;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: root.app-info.description;
                            font-size: 13px;
                            color: AppTheme.text-tertiary;
                            horizontal-alignment: center;
                        }
                    }
                }

                // --- 2. PROJECT ORIGINS (AUCHI POLY) ---
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text {
                        text: "ACADEMIC RESEARCH & ORIGINS";
                        font-size: 11px;
                        font-weight: 800;
                        color: AppTheme.text-tertiary;
                        letter-spacing: 1px;
                    }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        VerticalLayout {
                            padding: AppTheme.sp-lg;
                            spacing: AppTheme.sp-sm;
                            Text {
                                text: "Final Year Polytechnic Project";
                                font-size: 16px;
                                font-weight: 700;
                                color: AppTheme.text-primary;
                            }

                            Text {
                                text: "This project was developed for Auchi Polytechnic as a research framework for decentralized communication. It explores the intersection of Iroh P2P protocols and End-to-End Encryption (E2EE) in a native application environment.";
                                font-size: 14px;
                                color: AppTheme.text-secondary;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // --- 3. OPEN SOURCE & CONTRIBUTIONS ---
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text {
                        text: "OPEN SOURCE COMMUNITY";
                        font-size: 11px;
                        font-weight: 800;
                        color: AppTheme.text-tertiary;
                        letter-spacing: 1px;
                    }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        VerticalLayout {
                            padding: AppTheme.sp-lg;
                            spacing: AppTheme.sp-md;

                            Text {
                                text: root.app-info.name + " is an open-source initiative. We are always open to suggestions, feature requests, and code contributions from the community to help make P2P communication accessible to everyone.";
                                font-size: 14px;
                                color: AppTheme.text-secondary;
                                wrap: word-wrap;
                            }

                            VerticalLayout {
                                spacing: 0;
                                ActionRow {
                                    icon-svg: @image-url("../../assets/icons/globe.svg");
                                    title: "Official Website";
                                    subtitle: "Visit our site for news and documentation";
                                    accessory: "arrow";
                                    clicked => {
                                        root.open-url(root.app-info.website);
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: AppTheme.divider;
                                }

                                ActionRow {
                                    icon-svg: @image-url("../../assets/icons/github.svg");
                                    title: "Source Code (GitHub)";
                                    subtitle: "View the Rust and Slint source code";
                                    accessory: "arrow";
                                    clicked => {
                                        root.open-url(root.app-info.repo);
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: AppTheme.divider;
                                }

                                ActionRow {
                                    icon-svg: @image-url("../../assets/icons/bug.svg");
                                    title: "Report a Bug";
                                    subtitle: "Tell us if something isn't working right";
                                    accessory: "arrow";
                                    clicked => {
                                        root.open-url(root.app-info.repo + "/blob/main/nodechat-new/docs/bug_report.md");
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: AppTheme.divider;
                                }

                                ActionRow {
                                    icon-svg: @image-url("../../assets/icons/bulb.svg");
                                    title: "Share Suggestions";
                                    subtitle: "We value your feedback and feature ideas";
                                    accessory: "arrow";
                                    clicked => {
                                        root.open-url(root.app-info.repo + "/blob/main/nodechat-new/docs/feature_request.md");
                                    }
                                }

                                Rectangle {
                                    height: 1px;
                                    background: AppTheme.divider;
                                }

                                ActionRow {
                                    icon-svg: @image-url("../../assets/icons/users.svg");
                                    title: "How to Contribute";
                                    subtitle: "Help us build the future of P2P chat";
                                    accessory: "arrow";
                                    clicked => {
                                        root.open-url(root.app-info.repo + "/blob/main/nodechat-new/docs/contributing.md");
                                    }
                                }
                            }
                        }
                    }
                }

                // --- 4. BUILT WITH (TECHNOLOGIES) ---
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text {
                        text: "BUILT WITH";
                        font-size: 11px;
                        font-weight: 800;
                        color: AppTheme.text-tertiary;
                        letter-spacing: 1px;
                    }

                    Rectangle {
                        background: AppTheme.surface-secondary;
                        border-radius: AppTheme.radius-lg;
                        border-width: 1px;
                        border-color: AppTheme.divider;
                        VerticalLayout {
                            padding: AppTheme.sp-lg;
                            spacing: AppTheme.sp-md;

                            Text {
                                text: root.app-info.name + " is built on a foundation of modern, secure, and performant technologies that make decentralized communication possible.";
                                font-size: 13px;
                                color: AppTheme.text-tertiary;
                                wrap: word-wrap;
                            }

                            VerticalLayout {
                                spacing: AppTheme.sp-sm;
                                Text {
                                    text: "• Rust: Ensuring memory safety and high-performance cross-platform execution.";
                                    font-size: 14px;
                                    color: AppTheme.text-secondary;
                                    wrap: word-wrap;
                                }

                                Text {
                                    text: "• Slint: Powers our native, lightweight UI with smooth animations and minimal overhead.";
                                    font-size: 14px;
                                    color: AppTheme.text-secondary;
                                    wrap: word-wrap;
                                }

                                Text {
                                    text: "• Iroh: The decentralized engine providing reliable P2P discovery and encrypted data sync.";
                                    font-size: 14px;
                                    color: AppTheme.text-secondary;
                                    wrap: word-wrap;
                                }

                                Text {
                                    text: "• SQLite (Rusqlite): Providing a robust, SQL-driven local storage for your chat history.";
                                    font-size: 14px;
                                    color: AppTheme.text-secondary;
                                    wrap: word-wrap;
                                }

                                Text {
                                    text: "• Tokio: The asynchronous runtime driving the high-concurrency networking layer.";
                                    font-size: 14px;
                                    color: AppTheme.text-secondary;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }

                // --- 5. SYSTEM DIAGNOSTICS ---
                VerticalLayout {
                    spacing: AppTheme.sp-sm;
                    Text {
                        text: "DIAGNOSTICS";
                        font-size: 11px;
                        font-weight: 800;
                        color: AppTheme.text-tertiary;
                        letter-spacing: 1px;
                    }

                    VerticalLayout {
                        spacing: AppTheme.sp-md;
                        ActionRow {
                            icon-svg: @image-url("../../assets/icons/chart.svg");
                            title: "Real-time Debug Mode";
                            subtitle: "View low-level networking events";
                            accessory: "toggle";
                            is-toggle-on: root.show-debug;
                            toggled(on) => {
                                root.show-debug = on;
                            }
                        }

                        if root.show-debug: DebugView {
                            debug-logs: root.debug-logs;
                            show-copied: root.show-copied;
                            copy-clicked(logs) => {
                                root.copy-logs(logs);
                            }
                        }
                    }
                }

                // --- FOOTER ---
                VerticalLayout {
                    padding-top: AppTheme.sp-xl;
                    padding-bottom: AppTheme.sp-xl;
                    spacing: AppTheme.sp-xs;
                    Text {
                        text: "© 2026 " + root.app-info.name + " Project";
                        font-size: 12px;
                        color: AppTheme.text-tertiary;
                        horizontal-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.open-url(root.app-info.website + "/team");
                        }
                        mouse-cursor: pointer;
                        Text {
                            text: "Developed by " + root.app-info.name + " Team";
                            font-size: 11px;
                            font-weight: 700;
                            color: AppTheme.accent; // Make it look like a link
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

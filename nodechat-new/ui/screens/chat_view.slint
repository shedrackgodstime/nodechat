// NodeChat New — Chat View Screen
// ---------------------------------------------------------
// The main messaging surface for 1:1 and group conversations.
// Layout zones:
//   1. Header (peer info, back, actions)
//   2. Message stream (scrollable, bottom-anchored)
//   3. Composer (keyboard-safe, fixed bottom)
// ---------------------------------------------------------


import { AppTheme, VertScroll } from "../theme.slint";
import { MessageBubble, MessageData } from "../components/message_bubble.slint";
import { Composer } from "../components/composer.slint";

export { MessageData }

export component ChatViewScreen inherits Rectangle {
    in property <bool> is-desktop: false;
    in property <string> peer-name: "Chat";
    in property <string> peer-initials: "?";
    in property <string> peer-node-id: "";
    in property <string> connection-mode: "direct"; // "direct" | "group"
    in property <bool> is-online: false;
    in property <bool> is-verified: false;
    in property <bool> is-relay: false;
    in property <string> connection-stage: "";
    in property <[MessageData]> messages: [];
    in property <length> virtual-keyboard-height: 0px;

    callback go-back();
    callback send-message(string);
    callback open-contact-info();
    callback open-invite(string, string, string, bool);
    callback retry-queued();
    callback request-delete-conversation();

    background: AppTheme.surface-primary;

    VerticalLayout {
        spacing: 0;

        // 1. HEADER
        Rectangle {
            height: 60px;
            background: AppTheme.surface-secondary;
            border-color: AppTheme.divider;

            HorizontalLayout {
                padding-left: AppTheme.sp-sm;
                padding-right: 2px; // Absolute far right
                spacing: AppTheme.sp-sm;
                alignment: stretch;

                // Back Button
                TouchArea {
                    width: 44px;
                    clicked => { root.go-back(); }

                    Text {
                        text: "←";
                        font-size: 22px;
                        color: AppTheme.text-primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Avatar
                Rectangle {
                    width: 38px;
                    height: 38px;
                    y: (parent.height - self.height) / 2;

                    Rectangle {
                        width: 100%;
                        height: 100%;
                        border-radius: 19px;
                        background: AppTheme.accent-soft;

                        Text {
                            text: root.peer-initials;
                            font-size: 13px;
                            font-weight: 700;
                            color: AppTheme.accent;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        // Presence Dot
                        if is-online || is-relay : Rectangle {
                            width: 12px;
                            height: 12px;
                            border-radius: 6px;
                            background: is-relay ? AppTheme.accent-warning : AppTheme.accent-success;
                            border-color: AppTheme.surface-secondary;
                            border-width: 2px;
                            x: parent.width - self.width - 1px;
                            y: parent.height - self.height - 1px;
                        }
                    }
                }

                // Peer Name + Status
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    spacing: 1px;

                    HorizontalLayout {
                        spacing: AppTheme.sp-xs;

                        Text {
                            text: peer-name;
                            font-size: 16px;
                            font-weight: 700;
                            color: AppTheme.text-primary;
                            overflow: elide;
                        }

                    }

                    Text {
                        text: connection-stage != "" ? connection-stage
                            : is-online ? (is-relay ? "via relay" : "direct")
                            : "offline";
                        font-size: 12px;
                        color: is-online
                            ? (is-relay ? AppTheme.accent-warning : AppTheme.accent-success)
                            : AppTheme.text-tertiary;
                    }
                }

                // Info Button
                TouchArea {
                    width: 44px;
                    clicked => { root.open-contact-info(); }

                    Image {
                        source: @image-url("../images/nav/dots-vertical.svg");
                        width: 24px;
                        height: 24px;
                        colorize: AppTheme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Thin separator
        Rectangle {
            height: 1px;
            background: AppTheme.divider;
        }

        // 2. MESSAGE LIST (vertical scroll only)
        VertScroll {
            vertical-stretch: 1;
            viewport-height: msg-list.preferred-height;

            msg-list := VerticalLayout {
                width: parent.width;
                preferred-width: 100%;
                padding: AppTheme.sp-sm;
                spacing: AppTheme.sp-sm;
                
                // Vertical Spacer: Replaces expensive 'alignment: end'.
                // It pushes messages to the bottom but is much faster for scrolling.
                Rectangle { vertical-stretch: 1; }

                if messages.length == 0 : VerticalLayout {
                    alignment: center;
                    spacing: AppTheme.sp-md;
                    padding: AppTheme.sp-xl;

                    Text {
                        text: (connection-mode == "group") ? "👥" : "🔒";
                        font-size: 40px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: (connection-mode == "group") ? "Swarm Established" : "End-to-end encrypted";
                        font-size: 15px;
                        font-weight: 600;
                        color: AppTheme.text-primary;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: (connection-mode == "group") 
                            ? "This p2p group is ready. Tap the header to share the invite ticket with others!"
                            : "Messages are encrypted in transit.\nSay hello!";
                        font-size: 13px;
                        color: AppTheme.text-secondary;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }

                for msg in root.messages : MessageBubble {
                    data: msg;
                    is-desktop: root.is-desktop;
                    open-invite(topic, name, key, joined) => {
                        root.open-invite(topic, name, key, joined);
                    }
                }
            }
        }

        // 3. COMPOSER (Keyboard-safe, anchored bottom)
        Composer {
            is-disabled: !is-online && connection-mode == "direct";
            placeholder: is-online ? "Message..." : "Connecting...";
            send-message(msg) => { root.send-message(msg); }
        }
    }
}

// NodeChat New — Chat List Screen
// ---------------------------------------------------------
// The main home screen. Shows recent conversations.
// Desktop: renders as the sidebar panel.
// Mobile: renders as a full-screen panel.
// ---------------------------------------------------------

import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { ChatPreview } from "../components/row_data.slint";
import { ActionRow } from "../components/action_row.slint";
import { Button } from "../components/button.slint";

export { ChatPreview }

export component ChatListScreen inherits Rectangle {
    in property <bool> is-desktop: false;
    in property <bool> compact: false;
    in property <string> active-id: "";
    in property <[ChatPreview]> chats: [];
    in property <int> direct-peers: 0;
    in property <int> relay-peers: 0;
    in property <bool> is-offline: false;

    callback open-chat(ChatPreview);
    callback add-contact();
    callback open-contacts();
    callback open-settings();

    background: transparent;

    VerticalLayout {
        spacing: 0;

        if !compact: VerticalLayout {
            // --- Header Bar ---
            Rectangle {
                height: is-desktop ? 80px : 60px;
                background: is-desktop ? transparent : AppTheme.surface-secondary;
                border-color: AppTheme.divider;

                HorizontalLayout {
                    padding-left: AppTheme.space.md;
                    padding-right: 2px; // Absolute far right
                    alignment: stretch;

                    // --- Left: Brand & Status ---
                    HorizontalLayout {
                        spacing: AppTheme.space.sm;
                        alignment: start;
                        horizontal-stretch: 1;

                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "Chats";
                                font-size: AppTheme.typo.title.size;
                                font-weight: AppTheme.typo.title.weight;
                                color: AppTheme.text-primary;
                            }
                        }

                        // System Status Dot (Integrated)
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: is-offline ? AppTheme.accent-danger : (relay-peers > 0 ? AppTheme.accent-warning : AppTheme.accent-success);
                            }
                        }
                    }

                    // --- Right: Key Actions ---
                    HorizontalLayout {
                        spacing: AppTheme.space.xs;
                        alignment: end;

                        TouchArea {
                            width: 44px;
                            clicked => { root.add-contact(); }
                            Image {
                                source: @image-url("../images/nav/add.svg");
                                width: 22px;
                                height: 22px;
                                colorize: AppTheme.accent;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: AppTheme.divider;
            }
            
            // Header-to-list breathing room
            Rectangle { height: AppTheme.space.sm; }
        }

        // --- Chat List Body ---
        if chats.length == 0 && !compact: VerticalLayout {
            alignment: center;
            spacing: AppTheme.space.md;
            vertical-stretch: 1;
            padding: AppTheme.space.xl;

            Text {
                text: "💬";
                font-size: 48px;
                horizontal-alignment: center;
            }

            Text {
                text: "No conversations yet";
                font-size: AppTheme.typo.header.size;
                font-weight: AppTheme.typo.header.weight;
                color: AppTheme.text-primary;
                horizontal-alignment: center;
            }

            Text {
                text: "Add a contact to start chatting.";
                font-size: AppTheme.typo.body.size;
                font-weight: AppTheme.typo.body.weight;
                color: AppTheme.text-secondary;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
            Button {
                text: "Add New Peer";
                icon-svg: @image-url("../images/nav/add.svg");
                kind: "primary";
                clicked => { root.add-contact(); }
            }
        }

        if chats.length > 0: ScrollView {
            vertical-stretch: 1;
            viewport-height: list-body.preferred-height;
            viewport-width: parent.width;

            list-body := VerticalLayout {
                padding-left: AppTheme.space.sm;
                padding-right: AppTheme.space.sm;
                padding-top: compact ? 0 : AppTheme.space.sm;
                padding-bottom: AppTheme.space.sm;
                spacing: 2px;

                for chat in root.chats: ActionRow {
                    title: chat.name;
                    subtitle: chat.last-message;
                    initials: chat.initials;
                    timestamp: chat.timestamp;
                    badge-count: chat.unread;
                    is-online: chat.is-online;
                    is-relay: chat.is-relay;
                    is-verified: chat.is-verified;
                    is-selected: chat.id == root.active-id;
                    compact: root.compact;
                    clicked => {
                        root.open-chat(chat);
                    }
                }
            }
        }
    }
}

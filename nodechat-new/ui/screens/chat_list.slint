// NodeChat New — Chat List Screen
// ---------------------------------------------------------
// The main home screen. Shows recent conversations.
// Desktop: renders as the sidebar panel.
// Mobile: renders as a full-screen panel.
// ---------------------------------------------------------

import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { ChatRow, ChatPreview } from "../components/chat_row.slint";

export { ChatPreview }

export component ChatListScreen inherits Rectangle {
    in property <bool> is-desktop: false;
    in property <bool> compact: false;
    in property <[ChatPreview]> chats: [];
    in property <int> direct-peers: 0;
    in property <int> relay-peers: 0;
    in property <bool> is-offline: false;

    callback open-chat(ChatPreview);
    callback add-contact();
    callback open-contacts();
    callback open-settings();

    background: transparent;

    VerticalLayout {
        spacing: 0;

        if !compact : VerticalLayout {
            // --- Header Bar ---
            Rectangle {
                height: is-desktop ? 80px : 60px;
                background: is-desktop ? transparent : AppTheme.surface-secondary;
                border-color: AppTheme.divider;

                HorizontalLayout {
                    padding-left: AppTheme.space.md;
                    padding-right: AppTheme.space.sm;
                    spacing: AppTheme.space.sm;
                    alignment: start;

                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;

                        Text {
                            text: "Chats";
                            font-size: AppTheme.typo.title.size;
                            font-weight: AppTheme.typo.title.weight;
                            color: AppTheme.text-primary;
                        }

                        // Network Status Badge
                        Rectangle {
                            height: 18px;
                            width: status-text.preferred-width + 12px;
                            x: 0;

                            Rectangle {
                                border-radius: AppTheme.space.radius-sm;
                                background: is-offline ? AppTheme.accent-danger
                                    : (relay-peers > 0 ? AppTheme.accent-warning : AppTheme.accent-success);
                                opacity: 0.1;
                            }

                            status-text := Text {
                                text: is-offline ? "OFFLINE"
                                    : (relay-peers > 0 ? "RELAY"
                                        : "DIRECT");
                                font-size: AppTheme.typo.label.size;
                                font-weight: AppTheme.typo.label.weight;
                                color: is-offline ? AppTheme.accent-danger
                                    : (relay-peers > 0 ? AppTheme.accent-warning : AppTheme.accent-success);
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // Action Buttons (Simple rounded square)
                    TouchArea {
                        width: 40px;
                        height: 40px;
                        y: (parent.height - self.height) / 2;
                        clicked => { root.add-contact(); }

                        Rectangle {
                            border-radius: AppTheme.space.radius-md;
                            background: AppTheme.surface-tertiary;
                            border-width: 1px;
                            border-color: AppTheme.divider;

                            Image {
                                source: @image-url("../images/nav/add.svg");
                                width: 20px;
                                height: 20px;
                                colorize: AppTheme.accent;
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: AppTheme.divider;
            }
        }

        // --- Chat List Body ---
        if chats.length == 0 && !compact : VerticalLayout {
            alignment: center;
            spacing: AppTheme.space.md;
            vertical-stretch: 1;
            padding: AppTheme.space.xl;

            Text { text: "💬"; font-size: 48px; horizontal-alignment: center; }
            Text { text: "No conversations yet"; font-size: AppTheme.typo.header.size; font-weight: AppTheme.typo.header.weight; color: AppTheme.text-primary; horizontal-alignment: center; }
            Text { text: "Add a contact to start chatting."; font-size: AppTheme.typo.body.size; font-weight: AppTheme.typo.body.weight; color: AppTheme.text-secondary; horizontal-alignment: center; wrap: word-wrap; }
        }

        if chats.length > 0 : ScrollView {
            vertical-stretch: 1;
            viewport-height: list-body.preferred-height;

            list-body := VerticalLayout {
                padding-left: AppTheme.space.sm;
                padding-right: AppTheme.space.sm;
                padding-top: compact ? 0 : AppTheme.space.sm;
                padding-bottom: AppTheme.space.sm;
                spacing: 2px;

                for chat in root.chats : ChatRow {
                    data: chat;
                    compact: root.compact;
                    clicked => { root.open-chat(chat); }
                }
            }
        }
    }
}

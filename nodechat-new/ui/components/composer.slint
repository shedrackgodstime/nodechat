// NodeChat New — Precision Message Composer
// ---------------------------------------------------------
// An advanced multi-line input featuring manual scroll tracking
// and sticky action buttons. Adapted from ChatInput legacy.
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";

export component Composer inherits Rectangle {
    // Component API
    in property <bool> is-disabled: false;
    in property <bool> is-mobile: false;
    in property <string> placeholder: "Message...";
    in-out property <string> draft <=> input.text;

    // Callbacks
    callback send-message(string);
    callback attach-file();

    // Height calculation: grows from 52px to 140px
    height: Math.min(140px, Math.max(52px, input.preferred-height + 16px));
    background: AppTheme.surface-secondary;
    border-color: AppTheme.divider;
    border-width: 0px; // Seamless look

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 15px;
        spacing: 8px;
        // --- Attachment Button (Sticky at bottom) ---
        VerticalLayout {
            alignment: end;
            padding-bottom: 8px;
            TouchArea {
                width: 36px;
                height: 36px;
                enabled: !root.is-disabled;
                Rectangle {
                    border-radius: 18px;
                    background: parent.has-hover ? AppTheme.surface-hover : transparent;
                    Image {
                        source: @image-url("../images/nav/paperclip.svg");
                        width: 20px;
                        height: 20px;
                        colorize: root.is-disabled ? AppTheme.text-tertiary : AppTheme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                clicked => {
                    input.focus();
                    root.attach-file();
                }
            }
        }

        // --- Smart Multi-line Input Area ---
        Rectangle {
            horizontal-stretch: 1;
            background: AppTheme.surface-tertiary;
            border-radius: 20px;
            border-width: 1px;
            border-color: input.has-focus ? AppTheme.accent : AppTheme.border;
            clip: true;

            // Background focus catcher (behind Flickable)
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    input.focus();
                }
            }

            scroll := Flickable {
                width: 100%;
                height: 100%;
                interactive: true;
                viewport-width: self.width;
                viewport-height: Math.max(parent.height, input.preferred-height);

                Rectangle {
                    width: 100%;
                    height: input.preferred-height;
                    
                    // Manual Placeholder
                    if input.text == "": Text {
                        x: 14px;
                        width: parent.width - 28px;
                        height: 100%;
                        text: root.placeholder;
                        font-size: 16px;
                        color: #777777;
                        vertical-alignment: center;
                    }

                    input := TextInput {
                        x: 14px;
                        width: parent.width - 28px;
                        font-size: 16px;
                        color: AppTheme.text-primary;
                        vertical-alignment: center;
                        single-line: false;
                        wrap: word-wrap;
                        enabled: !root.is-disabled;

                        // --- THE MAGIC: Auto-scroll to cursor ---
                        cursor-position-changed(cursor-pos) => {
                            if (cursor-pos.y + scroll.viewport-y < 8px) {
                                scroll.viewport-y = - cursor-pos.y + 8px;
                            } else if (cursor-pos.y + scroll.viewport-y > scroll.height - 32px) {
                                scroll.viewport-y = scroll.height - cursor-pos.y - 32px;
                            }
                        }

                        key-pressed(event) => {
                            if (!root.is-mobile && event.text == Key.Return && !event.modifiers.control) {
                                if (self.text != "") {
                                    root.send-message(self.text);
                                    self.text = "";
                                }
                                return EventResult.accept;
                            }
                            return EventResult.reject;
                        }
                    }
                }
            }
        }

        // --- Send Button (Sticky at bottom) ---
        VerticalLayout {
            alignment: end;
            padding-bottom: 8px;
            TouchArea {
                width: 44px;
                height: 38px;
                enabled: input.text != "" && !root.is-disabled;
                Rectangle {
                    border-radius: 19px;
                    background: input.text == "" ? AppTheme.surface-hover : AppTheme.accent;
                    animate background { duration: 150ms; }
                    Image {
                        source: @image-url("../images/nav/send.svg");
                        width: 18px;
                        height: 18px;
                        colorize: input.text == "" ? AppTheme.text-tertiary : #ffffff;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                clicked => {
                    if (input.text != "") {
                        root.send-message(input.text);
                        input.text = "";
                    }
                }
            }
        }
    }
}

// NodeChat New — Message Composer Component
// ---------------------------------------------------------
// The input bar anchored at the bottom of ChatView.
// Keyboard-safe: sits above the virtual keyboard on mobile.
// Supports: text input, attachment (future), send button, disabled state.
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";

export component Composer inherits Rectangle {
    in property <bool> is-disabled: false;
    in property <string> placeholder: "Message...";

    callback send-message(string);

    // Internal state
    property <string> draft: "";

    // Dynamic height: standard bar look
    height: 68px;
    background: AppTheme.surface-secondary;
    border-color: AppTheme.divider;

    HorizontalLayout {
        padding-left: AppTheme.sp-sm;
        padding-right: AppTheme.sp-sm;
        padding-top: AppTheme.sp-sm;
        padding-bottom: AppTheme.sp-sm;
        spacing: AppTheme.sp-xs;
        alignment: center;

        // --- Attachment Button ---
        TouchArea {
            width: 40px;
            height: 40px;
            enabled: !root.is-disabled;

            Rectangle {
                border-radius: 20px;
                background: transparent;

                Image {
                    source: @image-url("../images/nav/paperclip.svg");
                    width: 20px;
                    height: 20px;
                    colorize: root.is-disabled ? AppTheme.text-tertiary : AppTheme.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // --- Text Input Area ---
        Rectangle {
            horizontal-stretch: 1;
            height: 42px;
            border-radius: AppTheme.radius-pill;
            background: AppTheme.surface-tertiary;
            border-color: input.has-focus ? AppTheme.accent : AppTheme.border;
            border-width: 1px;

            // Animate border on focus
            animate border-color { duration: AppTheme.dur-short; }

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-sm;

                // Placeholder text overlay
                if root.draft == "" : Text {
                    text: root.placeholder;
                    font-size: 15px;
                    color: AppTheme.text-tertiary;
                    vertical-alignment: center;
                }

                input := TextInput {
                    text <=> root.draft;
                    font-size: 15px;
                    color: root.is-disabled ? AppTheme.text-tertiary : AppTheme.text-primary;
                    enabled: !root.is-disabled;
                    vertical-alignment: center;
                    single-line: true;
                    horizontal-stretch: 1;

                    accepted => {
                        if root.draft != "" && !root.is-disabled {
                            root.send-message(root.draft);
                            root.draft = "";
                        }
                    }
                }
            }
        }

        // --- Send Button (SVG icon, accent when active) ---
        TouchArea {
            width: 42px;
            height: 42px;
            enabled: root.draft != "" && !root.is-disabled;

            clicked => {
                if root.draft != "" && !root.is-disabled {
                    root.send-message(root.draft);
                    root.draft = "";
                }
            }

            Rectangle {
                border-radius: 21px;
                background: root.draft != "" && !root.is-disabled
                    ? AppTheme.accent
                    : AppTheme.surface-hover;

                animate background { duration: AppTheme.dur-short; }

                Image {
                    source: @image-url("../images/nav/send.svg");
                    width: 18px;
                    height: 18px;
                    colorize: root.draft != "" && !root.is-disabled
                        ? #FFFFFF
                        : AppTheme.text-tertiary;
                    horizontal-alignment: center;
                    vertical-alignment: center;

                    animate colorize { duration: AppTheme.dur-short; }
                }
            }
        }
    }
}

// NodeChat New — Confirmation Modal
// ---------------------------------------------------------
// A high-impact modal for destructive or critical actions.
// Supports: title, subtitle, checkbox confirmation, pin entry.
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";

export component ConfirmModal inherits Rectangle {
    in property <string> title: "Are you sure?";
    in property <string> subtitle: "This action cannot be undone.";
    in property <string> confirm-text: "I Understand, Confirm";
    in property <string> action-slug: ""; // Used to toggle PIN requirement
    in property <string> error-msg: "";
    
    in-out property <string> pin: "";
    in-out property <bool> is-checked: false;

    callback confirm(string);
    callback cancel();

    // Full-screen backdrop
    background: rgba(0, 0, 0, 0.7);
    
    // Backdrop blur (Standard Slint Window property usually, but we simulate with opacity)
    // Dismiss on backdrop click
    TouchArea {
        clicked => { root.cancel(); }
    }

    // Centered Modal Card
    Rectangle {
        width: 340px;
        height: card-layout.preferred-height + AppTheme.sp-xl;
        background: AppTheme.surface-secondary;
        border-radius: AppTheme.radius-xl;
        border-width: 1px;
        border-color: AppTheme.divider;
        clip: true;

        // Block clicks from passing through
        TouchArea { width: 100%; height: 100%; }

        card-layout := VerticalLayout {
            padding: AppTheme.sp-lg;
            spacing: AppTheme.sp-lg;
            alignment: center;

            // --- Icon/Header ---
            VerticalLayout {
                spacing: AppTheme.sp-sm;
                Image {
                    source: @image-url("../images/nav/warning.svg");
                    width: 48px;
                    height: 48px;
                    colorize: AppTheme.accent-danger;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.title;
                    font-size: 20px;
                    font-weight: 800;
                    color: AppTheme.text-primary;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.subtitle;
                    font-size: 14px;
                    color: AppTheme.text-secondary;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }

            // --- Confirmation Checkbox ---
            TouchArea {
                clicked => { root.is-checked = !root.is-checked; }
                HorizontalLayout {
                    spacing: AppTheme.sp-md;
                    alignment: start;
                    
                    Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: AppTheme.radius-sm;
                        background: root.is-checked ? AppTheme.accent-danger : AppTheme.surface-tertiary;
                        border-color: root.is-checked ? AppTheme.accent-danger : AppTheme.border;
                        border-width: 1px;
                        animate background { duration: AppTheme.dur-short; }

                        if root.is-checked : Image {
                            source: @image-url("../images/nav/check.svg");
                            width: 16px;
                            height: 16px;
                            colorize: #FFFFFF;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "I confirm this action is IRREVERSIBLE";
                        font-size: 13px;
                        font-weight: 600;
                        color: root.is-checked ? AppTheme.accent-danger : AppTheme.text-secondary;
                        vertical-alignment: center;
                    }
                }
            }

            // --- PIN Input (destructive identity actions) ---
            if action-slug == "delete-identity" : VerticalLayout {
                spacing: AppTheme.sp-sm;
                
                Text {
                    text: "ENTER VAULT PIN";
                    font-size: 11px;
                    font-weight: 800;
                    color: AppTheme.text-tertiary;
                    letter-spacing: 1px;
                    horizontal-alignment: center;
                }

                Rectangle {
                    height: 54px;
                    background: AppTheme.surface-tertiary;
                    border-radius: AppTheme.radius-md;
                    border-color: pin-input.has-focus ? AppTheme.accent : AppTheme.divider;
                    border-width: 1px;

                    HorizontalLayout {
                        padding-left: AppTheme.sp-md;
                        padding-right: AppTheme.sp-md;
                        alignment: center;
                        
                        pin-input := TextInput {
                            text <=> root.pin;
                            font-size: 24px;
                            font-weight: 700;
                            color: AppTheme.text-primary;
                            input-type: password;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    if pin-input.text == "" : Text {
                        text: "••••";
                        font-size: 24px;
                        color: AppTheme.text-tertiary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        opacity: 0.3;
                    }
                }
            }

            // --- Error Message ---
            if root.error-msg != "" : Text {
                text: root.error-msg;
                font-size: 12px;
                font-weight: 600;
                color: AppTheme.accent-danger;
                horizontal-alignment: center;
            }

            // --- Action Buttons ---
            VerticalLayout {
                spacing: AppTheme.sp-md;

                // Confirm Action
                TouchArea {
                    height: 50px;
                    enabled: root.is-checked;
                    clicked => { root.confirm(root.pin); }

                    Rectangle {
                        border-radius: 25px;
                        background: root.is-checked ? AppTheme.accent-danger : AppTheme.surface-tertiary;
                        
                        Text {
                            text: root.confirm-text;
                            font-size: 15px;
                            font-weight: 700;
                            color: root.is-checked ? #FFFFFF : AppTheme.text-tertiary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Cancel Button
                TouchArea {
                    height: 32px;
                    clicked => { root.cancel(); }
                    Text {
                        text: "Cancel";
                        font-size: 14px;
                        font-weight: 600;
                        color: AppTheme.text-tertiary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

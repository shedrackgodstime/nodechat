// NodeChat New — Chat Row Component
// ---------------------------------------------------------
// Reusable row for the Chat List screen.
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";

export struct ChatPreview {
    id: string,
    name: string,
    initials: string,
    last-message: string,
    timestamp: string,
    unread: int,
    is-group: bool,
    is-online: bool,
    is-relay: bool,
    is-verified: bool,
}

export component ChatRow inherits Rectangle {
    in property <ChatPreview> data;
    in property <bool> is-selected: false;
    in property <bool> compact: false;

    callback clicked();

    height: 72px;
    background: is-selected ? AppTheme.accent-soft : transparent;
    border-radius: AppTheme.space.radius-md;

    states [
        hovered when touch.has-hover : {
            background: is-selected ? AppTheme.accent-soft : AppTheme.surface-hover;
        }
    ]

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: compact ? 0 : AppTheme.space.md;
        padding-right: compact ? 0 : AppTheme.space.md;
        spacing: AppTheme.space.md;
        alignment: compact ? center : start;

        // --- Avatar Circle ---
        Rectangle {
            width: 48px;
            height: 48px;
            border-radius: 24px;
            background: AppTheme.accent-soft;
            border-color: data.is-online ? AppTheme.accent-success : transparent;
            border-width: data.is-online ? 2px : 0px;
            y: (parent.height - self.height) / 2;

            Text {
                text: data.initials;
                font-size: AppTheme.typo.header.size;
                font-weight: AppTheme.typo.header.weight;
                color: AppTheme.accent;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            if data.is-online || data.is-relay : Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: data.is-relay ? AppTheme.accent-warning : AppTheme.accent-success;
                border-color: AppTheme.surface-primary;
                border-width: 2px;
                x: parent.width - self.width - 1px;
                y: parent.height - self.height - 1px;
            }
        }

        // --- Chat Text Info (Hidden in compact) ---
        if !compact : VerticalLayout {
            vertical-stretch: 1;
            alignment: center;
            spacing: AppTheme.space.xs;

            HorizontalLayout {
                spacing: AppTheme.space.sm;

                Text {
                    text: data.name;
                    font-size: AppTheme.typo.header.size;
                    font-weight: AppTheme.typo.header.weight;
                    color: AppTheme.text-primary;
                    overflow: elide;
                    horizontal-stretch: 1;
                }

                Text {
                    text: data.timestamp;
                    font-size: AppTheme.typo.label.size;
                    font-weight: AppTheme.typo.label.weight;
                    color: data.unread > 0 ? AppTheme.accent : AppTheme.text-tertiary;
                    vertical-alignment: center;
                }
            }

            HorizontalLayout {
                spacing: AppTheme.space.sm;

                Text {
                    text: data.last-message;
                    font-size: AppTheme.typo.body.size;
                    font-weight: AppTheme.typo.body.weight;
                    color: AppTheme.text-secondary;
                    overflow: elide;
                    horizontal-stretch: 1;
                }

                if data.unread > 0 : Rectangle {
                    width: 20px;
                    height: 20px;
                    border-radius: AppTheme.space.radius-md;
                    background: AppTheme.accent;
                    y: (parent.height - self.height) / 2;

                    Text {
                        text: data.unread > 9 ? "9+" : data.unread;
                        font-size: AppTheme.typo.label.size;
                        font-weight: AppTheme.typo.label.weight;
                        color: AppTheme.text-inverted;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

// NodeChat New — Standard Page Shell
// ---------------------------------------------------------
// This shell wraps standard screens (Settings, Contacts, etc.)
// providing a consistent header, padding, and scroll area.


import { AppTheme, VertScroll } from "../theme.slint";

export component PageShell inherits Rectangle {
    in property <string> title: "Header";
    in property <string> subtitle: "";
    in property <bool> show-back: true;
    in property <bool> is-desktop: false;
    
    callback back-clicked();

    background: transparent;
    
    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // 1. PAGE HEADER (Unified across platforms)
        Rectangle {
            height: is-desktop ? 80px : 64px;
            background: is-desktop ? transparent : AppTheme.surface-secondary;
            border-color: AppTheme.divider;
            border-width: is-desktop ? 0px : 1px; // Bottom border only for mobile

            HorizontalLayout {
                padding-left: AppTheme.sp-md;
                padding-right: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;

                // Back Button (Mobile focus, Desktop optional)
                if show-back : TouchArea {
                    width: 32px;
                    height: 100%;
                    clicked => { root.back-clicked(); }
                    
                    Text {
                        text: "←";
                        font-size: 24px;
                        color: AppTheme.text-primary;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 0;

                    Text {
                        text: root.title;
                        font-size: is-desktop ? 28px : 18px;
                        font-weight: 700;
                        color: AppTheme.text-primary;
                    }

                    if root.subtitle != "" : Text {
                        text: root.subtitle;
                        font-size: 13px;
                        color: AppTheme.text-secondary;
                    }
                }

                // Push actions to right if needed
                Rectangle { horizontal-stretch: 1; }
            }
        }

        // 2. SCROLLABLE BODY (vertical only)
        VertScroll {
            vertical-stretch: 1;
            
            VerticalLayout {
                padding: AppTheme.sp-md;
                spacing: AppTheme.sp-md;
                alignment: start;
                @children
            }
        }
    }
}

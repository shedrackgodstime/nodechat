// NodeChat New — Unified Action Row Component
// ---------------------------------------------------------
// Standardised row for all list-oriented surfaces:
//   - Chat List (Preview + Badge + Timestamp)
//   - Contacts (Avatar + Status + Verified)
//   - Settings (Icon + Action Toggle)
// Supports compact (Rail) and expanded layouts.
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";

export component ActionRow inherits Rectangle {
    // --- Data Properties ---
    in property <string> title;
    in property <string> subtitle;
    in property <string> initials;    // Set for Avatar Mode
    in property <string> icon;        // Text icon (Emoji)
    in property <image> icon-svg: @image-url(""); // Set for Settings Mode
    in property <string> timestamp;
    in property <int> badge-count: 0;
    
    // --- State Properties ---
    in property <bool> is-online: false;
    in property <bool> is-relay: false;
    in property <bool> is-verified: false;
    in property <bool> is-selected: false;
    in property <bool> is-danger: false;
    in property <bool> compact: false;
    
    // --- Appearance ---
    in property <string> accessory: "none"; // "arrow", "toggle", "none"
    in property <bool> is-toggle-on: false;
    in property <color> icon-color: root.is-danger ? AppTheme.accent-danger : AppTheme.accent;
    
    // --- Callbacks ---
    callback clicked();
    callback toggled(bool);

    // --- Layout Constants ---
    property <length> item-height: root.compact ? 60px : (subtitle != "" ? 72px : 64px); 
    height: item-height;
    
    background: root.is-selected ? AppTheme.accent-soft : transparent;
    border-radius: AppTheme.radius-md;
    clip: false; // Only clip at the scrollable container level for better GPU perf

    // --- Interactions ---
    states [
        hovered when touch.has-hover && !is-selected : {
            background: AppTheme.surface-hover;
        }
    ]

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: root.compact ? 0 : AppTheme.space.md;
        padding-right: root.compact ? 0 : AppTheme.space.md;
        spacing: root.compact ? 0 : AppTheme.space.md;
        alignment: root.compact ? center : start;

        // --- 1. LEFT ZONE (Avatar or Icon) ---
        Rectangle {
            width: root.compact ? 48px : (root.initials != "" ? 48px : 38px);
            height: self.width;
            y: (parent.height - self.height) / 2;

            // Avatar Style (Large, Round)
            if root.initials != "" : Rectangle {
                width: 100%;
                height: 100%;
                border-radius: self.width / 2;
                background: AppTheme.accent-soft;
                border-width: 0px;

                Text {
                    text: root.initials;
                    font-size: 15px;
                    font-weight: 700;
                    color: AppTheme.accent;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                // Presence/Relay Indicator
                if (root.is-online || root.is-relay) && !root.compact : Rectangle {
                    width: 12px;
                    height: 12px;
                    border-radius: 6px;
                    background: root.is-relay ? AppTheme.accent-warning : AppTheme.accent-success;
                    border-color: AppTheme.surface-primary;
                    border-width: 2px;
                    x: parent.width - self.width - 1px;
                    y: parent.height - self.height - 1px;
                }
            }

            // Icon/Emoji Style (Standard Box)
            if root.initials == "" && (root.icon-svg.width > 0 || root.icon != "") : Rectangle {
                width: 38px;
                height: 38px;
                border-radius: AppTheme.radius-sm;
                background: AppTheme.surface-tertiary;

                if root.icon-svg.width > 0 : Image {
                    source: root.icon-svg;
                    width: 20px;
                    height: 20px;
                    colorize: root.icon-color;
                }

                if root.icon-svg.width == 0 && root.icon != "" : Text {
                    text: root.icon;
                    font-size: 20px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // --- 2. INFORMATION ZONE (Labels + Meta) ---
        if !root.compact : VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;

            // Title Row (Name + Timestamp)
            HorizontalLayout {
                spacing: AppTheme.space.sm;
                
                HorizontalLayout {
                    horizontal-stretch: 1;
                    spacing: AppTheme.space.xs;
                    alignment: start;
                    
                    Text {
                        text: root.title;
                        font-size: 16px;
                        font-weight: 700;
                        color: root.is-danger ? AppTheme.accent-danger : AppTheme.text-primary;
                        overflow: elide;
                    }

                    if root.is-verified : Text {
                        text: "✓";
                        font-size: 12px;
                        color: AppTheme.accent-success;
                        vertical-alignment: center;
                    }
                }

                if root.timestamp != "" : Text {
                    text: root.timestamp;
                    font-size: 12px;
                    color: root.badge-count > 0 ? AppTheme.accent : AppTheme.text-tertiary;
                }
            }

            // Subtitle Row (Message/ID + Accessory)
            HorizontalLayout {
                spacing: AppTheme.space.sm;
                
                if root.subtitle != "" : Text {
                    text: root.subtitle;
                    font-size: 13px;
                    font-weight: 500;
                    color: AppTheme.text-tertiary;
                    overflow: elide;
                    horizontal-stretch: 1;
                }

                // RIGHT ACCESSORIES
                if root.badge-count > 0 : Rectangle {
                    width: 20px;
                    height: 20px;
                    border-radius: 10px;
                    background: AppTheme.accent;
                    y: (parent.height - self.height) / 2;

                    Text {
                        text: root.badge-count > 9 ? "9+" : root.badge-count;
                        font-size: 10px;
                        font-weight: 800;
                        color: AppTheme.text-inverted;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if root.accessory == "arrow" : Text {
                    text: "›";
                    font-size: 20px;
                    font-weight: 600;
                    color: AppTheme.text-tertiary;
                    vertical-alignment: center;
                }

                if accessory == "toggle" : Rectangle {
                    width: 44px;
                    height: 24px;
                    border-radius: 12px;
                    background: root.is-toggle-on ? AppTheme.accent : AppTheme.surface-tertiary;
                    y: (parent.height - self.height) / 2;
                    animate background { duration: AppTheme.dur-short; }

                    Rectangle {
                        x: root.is-toggle-on ? (parent.width - 20px - 2px) : 2px;
                        width: 20px;
                        height: 20px;
                        border-radius: 10px;
                        background: #FFFFFF;
                        y: (parent.height - self.height) / 2;
                        animate x { duration: AppTheme.dur-short; easing: ease-in-out; }
                    }

                    TouchArea { clicked => { root.toggled(!root.is-toggle-on); } }
                }
            }
        }
    }
}

// NodeChat New — Unified Row Data Models
// ---------------------------------------------------------

export struct ChatPreview {
    id: string,
    name: string,
    initials: string,
    last-message: string,
    timestamp: string,
    unread: int,
    is-group: bool,
    is-online: bool,
    is-relay: bool,
    is-verified: bool,
    last-message-status: string,
    is-last-message-outgoing: bool,
}

export struct ContactData {
    id: string,
    name: string,
    initials: string,
    node-id: string,
    is-online: bool,
    is-session-ready: bool,
    is-relay: bool,
    is-verified: bool,
}

export struct GroupData {
    id: string,
    name: string,
    initials: string,
    topic: string,
    secret-key: string,
    member-count: int,
}

export struct AppInfo {
    name: string,
    version: string,
    version-type: string,
    description: string,
    website: string,
    repo: string,
}
 
export struct GroupCandidateItem {
    contact-id: string,
    display-name: string,
    initials: string,
    is-selected: bool,
    is-online: bool,
}

// NodeChat New — Message Bubble Component
// ---------------------------------------------------------
// Renders a single chat message.
// Supports: outgoing vs incoming, timestamps, status,
// invite bubbles, system messages, and verified badges.
// ---------------------------------------------------------

import { AppTheme } from "../theme.slint";

export struct MessageData {
    id: string,
    sender: string,
    text: string,
    timestamp: string,
    is-outgoing: bool,
    is-system: bool,
    is-invite: bool,
    invite-topic: string,
    invite-name: string,
    invite-key: string,
    is-invite-joined: bool,
    status: string,   // "sent" | "delivered" | "failed" | "queued"
}

export component MessageBubble inherits Rectangle {
    in property <MessageData> data;

    callback open-invite(string, string, string, bool); // topic, name, key, is_joined

    background: transparent;
    // Spacing is handled by the parent list layout

    // --- System Message (centered, no bubble) ---
    if data.is-system : HorizontalLayout {
        alignment: center;
        padding-top: AppTheme.space.sm;
        padding-bottom: AppTheme.space.sm;

        Rectangle {
            border-radius: AppTheme.space.radius-pill;
            background: AppTheme.surface-tertiary;

            HorizontalLayout {
                padding-left: AppTheme.space.md;
                padding-right: AppTheme.space.md;
                padding-top: AppTheme.space.xs;
                padding-bottom: AppTheme.space.xs;

                Text {
                    text: data.text;
                    font-size: AppTheme.typo.label.size;
                    font-weight: AppTheme.typo.label.weight;
                    color: AppTheme.text-tertiary;
                    horizontal-alignment: center;
                }
            }
        }
    }

    // --- Group Invite Bubble ---
    if data.is-invite && !data.is-system : HorizontalLayout {
        alignment: data.is-outgoing ? end : start;
        padding-left: data.is-outgoing ? AppTheme.space.xl : AppTheme.space.md;
        padding-right: data.is-outgoing ? AppTheme.space.md : AppTheme.space.xl;

        Rectangle {
            max-width: 280px;
            border-radius: AppTheme.space.radius-lg;
            background: AppTheme.surface-tertiary;
            border-color: AppTheme.accent-soft;
            border-width: 1px;

            VerticalLayout {
                padding: AppTheme.space.md;
                spacing: AppTheme.space.sm;

                Text {
                    text: "📨 Group Invite";
                    font-size: AppTheme.typo.label.size;
                    font-weight: AppTheme.typo.label.weight;
                    color: AppTheme.accent;
                    letter-spacing: 0.5px;
                }

                Text {
                    text: data.invite-name != "" ? data.invite-name : "Unnamed Group";
                    font-size: AppTheme.typo.header.size;
                    font-weight: AppTheme.typo.header.weight;
                    color: AppTheme.text-primary;
                    wrap: word-wrap;
                }

                TouchArea {
                    height: 36px;
                    clicked => {
                        root.open-invite(data.invite-topic, data.invite-name, data.invite-key, data.is-invite-joined);
                    }

                    Rectangle {
                        border-radius: AppTheme.space.radius-md;
                        background: data.is-invite-joined ? AppTheme.surface-hover : AppTheme.accent;

                        Text {
                            text: data.is-invite-joined ? "✓ Joined" : "Join Group";
                            font-size: AppTheme.typo.label.size;
                            font-weight: AppTheme.typo.label.weight;
                            color: data.is-invite-joined ? AppTheme.text-secondary : AppTheme.text-inverted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // --- Standard Chat Bubble ---
    if !data.is-system && !data.is-invite : HorizontalLayout {
        alignment: data.is-outgoing ? end : start;
        padding-left: data.is-outgoing ? 60px : AppTheme.space.md;
        padding-right: data.is-outgoing ? AppTheme.space.md : 60px;

        VerticalLayout {
            spacing: 2px;

            // Sender label for group messages (incoming only)
            if !data.is-outgoing && data.sender != "" : HorizontalLayout {
                padding-left: AppTheme.space.sm;
                Text {
                    text: data.sender;
                    font-size: AppTheme.typo.label.size;
                    font-weight: AppTheme.typo.label.weight;
                    color: AppTheme.accent;
                }
            }

            // The Bubble
            Rectangle {
                border-radius: AppTheme.space.radius-lg;
                background: data.is-outgoing ? AppTheme.bubble-out : AppTheme.bubble-in;

                VerticalLayout {
                    padding-left: AppTheme.space.md;
                    padding-right: AppTheme.space.md;
                    padding-top: AppTheme.space.sm;
                    padding-bottom: AppTheme.space.sm;
                    spacing: AppTheme.space.xs;

                    Text {
                        text: data.text;
                        font-size: AppTheme.typo.body.size;
                        font-weight: AppTheme.typo.body.weight;
                        color: data.is-outgoing ? #FFFFFF : AppTheme.text-primary; // Simple high contrast
                        wrap: word-wrap;
                    }

                    // Timestamp + Status Row
                    HorizontalLayout {
                        alignment: end;
                        spacing: AppTheme.space.xs;

                        Text {
                            text: data.timestamp;
                            font-size: AppTheme.typo.label.size;
                            font-weight: AppTheme.typo.label.weight;
                            color: data.is-outgoing
                                ? rgba(255, 255, 255, 0.6)
                                : AppTheme.text-tertiary;
                            vertical-alignment: center;
                        }

                        // Status indicator (outgoing only)
                        if data.is-outgoing : Text {
                            text: data.status == "delivered" ? "✓✓"
                                : data.status == "sent"      ? "✓"
                                : data.status == "failed"    ? "✗"
                                : data.status == "queued"    ? "⏱"
                                : "";
                            font-size: AppTheme.typo.label.size;
                            font-weight: AppTheme.typo.label.weight;
                            color: data.status == "delivered" ? AppTheme.accent-success
                                : data.status == "failed"     ? AppTheme.accent-danger
                                : rgba(255, 255, 255, 0.5);
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

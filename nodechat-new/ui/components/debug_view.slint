// NodeChat New — Real-time Debug View
// ---------------------------------------------------------
// Scrollable in BOTH axes: no word-wrap so long lines are fully visible.

import { AppTheme } from "../theme.slint";

export component DebugView inherits Rectangle {
    in property <string> debug-logs: "Initializing P2P stack...\nWaiting for Iroh connection...";

    callback copy-clicked(string);
    in property <bool> show-copied: false;

    background: #000000;
    border-radius: AppTheme.radius-md;
    border-width: 1px;
    border-color: root.show-copied ? AppTheme.accent-success : AppTheme.accent;

    VerticalLayout {
        padding: AppTheme.sp-md;
        spacing: AppTheme.sp-sm;

        // ── Header bar ────────────────────────────────────────────
        HorizontalLayout {
            Text {
                text: "REAL-TIME DIAGNOSTICS";
                font-size: 11px;
                font-weight: 800;
                color: AppTheme.accent;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }

            copy-touch := TouchArea {
                width: 72px;
                height: 24px;
                clicked => { root.copy-clicked(root.debug-logs); }

                Rectangle {
                    background: root.show-copied
                        ? AppTheme.accent-success
                        : (copy-touch.pressed ? AppTheme.accent : AppTheme.surface-tertiary);
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: root.show-copied ? AppTheme.accent-success : AppTheme.accent;

                    Text {
                        text: root.show-copied ? "COPIED ✅" : "COPY";
                        font-size: 10px;
                        font-weight: 800;
                        color: root.show-copied
                            ? #FFFFFF
                            : (copy-touch.pressed ? #000000 : AppTheme.accent);
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── 2-D scroll console ────────────────────────────────────
        // Flickable gives us both X and Y scrolling.
        // The inner Text has no word-wrap so every line stays on one line.
        Rectangle {
            height: 220px;
            background: #09090B;
            border-radius: 4px;
            clip: true;

            scroll-area := Flickable {
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                // Let content decide how much space it needs in both axes.
                viewport-width: log-text.preferred-width + 32px;
                viewport-height: log-text.preferred-height + 16px;
                interactive: true;

                log-text := Text {
                    x: 8px;
                    y: 8px;
                    text: root.debug-logs;
                    font-size: 12px;
                    font-family: "monospace";
                    color: #A1A1AA;
                    // NO word-wrap — horizontal scroll shows the full line
                    wrap: no-wrap;
                }
            }
        }
    }
}

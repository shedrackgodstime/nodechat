// NodeChat New — Real-time Debug View
// ---------------------------------------------------------

import { AppTheme, VertScroll } from "../theme.slint";

export component DebugView inherits Rectangle {
    in property <string> debug-logs: "Initializing P2P stack...\nWaiting for Iroh connection...\nNode Identity: x25519:abc...123\nListening on port 54321...";
    
    callback copy-clicked(string);

    background: #000000;
    border-radius: AppTheme.radius-md;
    border-width: 1px;
    border-color: AppTheme.accent;

    VerticalLayout {
        padding: AppTheme.sp-md;
        spacing: AppTheme.sp-sm;

        HorizontalLayout {
            Text { text: "REAL-TIME DIAGNOSTICS"; font-size: 11px; font-weight: 800; color: AppTheme.accent; vertical-alignment: center; }
            Rectangle { horizontal-stretch: 1; }
            
            copy-touch := TouchArea {
                clicked => { root.copy-clicked(root.debug-logs); }
                width: 60px;
                height: 24px;
                
                Rectangle {
                    background: copy-touch.pressed ? AppTheme.accent : AppTheme.surface-tertiary;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: AppTheme.accent;
                    
                    Text {
                        text: "COPY";
                        font-size: 10px;
                        font-weight: 800;
                        color: copy-touch.pressed ? #000000 : AppTheme.accent;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            height: 200px;
            background: #09090B;
            border-radius: 4px;
            
            VertScroll {
                vertical-stretch: 1;
                viewport-height: logs-layout.preferred-height;
                
                logs-layout := VerticalLayout {
                    padding: 8px;
                    logs-txt := Text {
                        text: root.debug-logs;
                        font-size: 12px;
                        font-family: "monospace";
                        color: #A1A1AA;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}

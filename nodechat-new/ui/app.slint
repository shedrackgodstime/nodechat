// NodeChat New — Root Application Shell
// ---------------------------------------------------------
// This file serves as the primary layout controller.
// It manages:
//   - Responsive breakpoints (Mobile vs Tablet vs Desktop)
//   - Safe areas for mobile/keyboard
//   - Navigation state (Routing)
//   - Theme token application
// ---------------------------------------------------------

import { AppTheme } from "./theme.slint";
import { ChatPreview, ContactData } from "./components/row_data.slint";
import { ChatListScreen } from "./screens/chat_list.slint";
import { ChatViewScreen, MessageData } from "./screens/chat_view.slint";
import { SettingsScreen } from "./screens/settings_screen.slint";
import { ConfirmModal } from "./components/confirm_modal.slint";
import { ContactsScreen } from "./screens/contacts_screen.slint";
import { NavBar } from "./components/nav_bar.slint";

export { ChatPreview, MessageData }

export enum DeviceType { mobile, tablet, desktop }

export struct ConversationContext {
    kind: string,           // "direct" | "group"
    id: string,
    title: string,
    initials: string,
    is-online: bool,
    is-relay: bool,
    is-verified: bool,
    is-session-ready: bool,
    connection-stage: string,
    return-screen: int,
}

export component AppWindow inherits Window {
    title: "NodeChat";

    // --- Window Constraints ---
    min-width: 360px;
    min-height: 560px;
    preferred-width: 1080px;
    preferred-height: 800px;
    background: AppTheme.surface-primary;

    // --- Shell State ---
    // Breakpoints: Mobile (< 700px), Tablet (700px - 1000px), Desktop (> 1000px)
    out property <DeviceType> device: root.width > 1000px ? DeviceType.desktop : root.width > 700px ? DeviceType.tablet : DeviceType.mobile;
    out property <bool> is-desktop: root.device == DeviceType.desktop || root.device == DeviceType.tablet;
    
    // Decoupled width property to prevent binding loops in layout negotiation
    property <length> concrete-sidebar-width: (root.device == DeviceType.desktop) ? 320px : (root.device == DeviceType.tablet ? 170px : 0px);
    in-out property <int> current-screen: 0;
    in-out property <bool> has-identity: false;
    in-out property <bool> is-locked: false;

    // --- App Data ---
    in property <string> display-name: "Shedrack G.";
    in property <string> initials: "SG";
    in property <string> endpoint-ticket: "";
    in property <[ChatPreview]> chats: [
        {
            id: "1",
            name: "Alice",
            initials: "A",
            last-message: "The P2P relay is active now.",
            timestamp: "12:45",
            unread: 0,
            is-group: false,
            is-online: true,
            is-relay: false,
            is-verified: true
        },
        {
            id: "2",
            name: "Global Dev Group",
            initials: "GD",
            last-message: "Let's test the group broadcast.",
            timestamp: "10:20",
            unread: 12,
            is-group: true,
            is-online: true,
            is-relay: false,
            is-verified: false
        },
        {
            id: "3",
            name: "Bob",
            initials: "B",
            last-message: "Are you online?",
            timestamp: "Yesterday",
            unread: 0,
            is-group: false,
            is-online: false,
            is-relay: false,
            is-verified: false
        },
        {
            id: "4",
            name: "Charlie",
            initials: "C",
            last-message: "Connection established via relay 42.",
            timestamp: "Mon",
            unread: 2,
            is-group: false,
            is-online: true,
            is-relay: true,
            is-verified: false
        },
        {
            id: "5",
            name: "Satoshi",
            initials: "S",
            last-message: "The genesis block is ready.",
            timestamp: "2009",
            unread: 0,
            is-group: false,
            is-online: false,
            is-relay: false,
            is-verified: true
        }
    ];
    in property <[ContactData]> contacts: [
        {
            id: "1",
            name: "Alice",
            initials: "A",
            node-id: "node_7f8a9b...",
            is-online: true,
            is-session-ready: true,
            is-relay: false,
            is-verified: true
        },
        {
            id: "3",
            name: "Bob",
            initials: "B",
            node-id: "node_1a2b3c...",
            is-online: false,
            is-session-ready: false,
            is-relay: false,
            is-verified: false
        },
        {
            id: "4",
            name: "Charlie",
            initials: "C",
            node-id: "node_x9y8z7...",
            is-online: true,
            is-session-ready: true,
            is-relay: true,
            is-verified: false
        },
        {
            id: "5",
            name: "Satoshi",
            initials: "S",
            node-id: "node_BTC123...",
            is-online: false,
            is-session-ready: false,
            is-relay: false,
            is-verified: true
        }
    ];
    in-out property <[MessageData]> active-messages: [
        {
            id: "m1",
            sender: "Alice",
            text: "Hey! Did you see the new relay protocol?",
            timestamp: "12:45",
            is-outgoing: false,
            is-system: false,
            is-invite: false,
            invite-topic: "",
            invite-name: "",
            invite-key: "",
            is-invite-joined: false,
            status: "read"
        },
        {
            id: "m2",
            sender: "System",
            text: "Direct P2P connection established with Alice.",
            timestamp: "12:46",
            is-outgoing: false,
            is-system: true,
            is-invite: false,
            invite-topic: "",
            invite-name: "",
            invite-key: "",
            is-invite-joined: false,
            status: ""
        },
        {
            id: "m3",
            sender: "Shedrack G.",
            text: "Yeah, it looks like it's much faster now. I'm seeing sub-50ms latency.",
            timestamp: "12:47",
            is-outgoing: true,
            is-system: false,
            is-invite: false,
            invite-topic: "",
            invite-name: "",
            invite-key: "",
            is-invite-joined: false,
            status: "delivered"
        },
        {
            id: "m4",
            sender: "Alice",
            text: "Exactly. The Iroh broadcast layer is doing most of the heavy lifting. I'll send you an invite to the dev group.",
            timestamp: "12:48",
            is-outgoing: false,
            is-system: false,
            is-invite: false,
            invite-topic: "",
            invite-name: "",
            invite-key: "",
            is-invite-joined: false,
            status: "read"
        }
    ];
    in-out property <ConversationContext> active-conversation: {
        kind: "direct",
        id: "",
        title: "",
        initials: "",
        is-online: false,
        is-relay: false,
        is-verified: false,
        is-session-ready: false,
        connection-stage: "",
        return-screen: 0,
    };
    in property <int> direct-peers: 2;
    in property <int> relay-peers: 1;
    in property <bool> is-offline: false;

    // --- Modal State ---
    in-out property <bool> confirm-modal-show: false;
    in-out property <string> confirm-modal-title: "Confirm Action";
    in-out property <string> confirm-modal-subtitle: "Are you sure you want to do this?";
    in-out property <string> confirm-modal-slug: "";
    in-out property <string> confirm-modal-err: "";
    in-out property <bool> confirm-modal-checked: false;

    // --- Callbacks ---
    callback open-settings;
    callback open-contacts;
    callback add-contact;
    callback open-chat(ChatPreview);

    open-settings => {
        root.current-screen = 3;
    }
    open-contacts => {
        root.current-screen = 4;
    }
    add-contact => { /* Implement ticket entry popup would go here */ }
    open-chat(chat) => {
        root.load-conversation(chat.id, chat.is-group);
        root.active-conversation = {
            kind: chat.is-group ? "group" : "direct",
            id: chat.id,
            title: chat.name,
            initials: chat.initials,
            is-online: chat.is-online,
            is-relay: chat.is-relay,
            is-verified: chat.is-verified,
            is-session-ready: false,
            connection-stage: "",
            return-screen: 0,
        };

        // --- Contextual Mock Data Switcher ---
        if chat.id == "1" {
            root.active-messages = [
                { id: "m1", sender: "Alice", text: "Hey! Did you see the new relay protocol?", timestamp: "12:45", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "m2", sender: "Shedrack G.", text: "Yeah, Alice! Sub-50ms latency is huge.", timestamp: "12:47", is-outgoing: true, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "delivered" },
                { id: "m3", sender: "Alice", text: "Right? The team has been working on it for weeks.", timestamp: "12:48", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "m4", sender: "Alice", text: "I'm testing it now with the new encryption module.", timestamp: "12:48", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "m5", sender: "System", text: "Alice has verified your session.", timestamp: "12:50", is-outgoing: false, is-system: true, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "" },
                { id: "m6", sender: "Shedrack G.", text: "Awesome. Make sure to check the memory usage as well.", timestamp: "12:51", is-outgoing: true, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "delivered" },
                { id: "m7", sender: "Shedrack G.", text: "I noticed a slight spike on ARM devices.", timestamp: "12:51", is-outgoing: true, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "m8", sender: "Alice", text: "Good point. I'll profile it on my Raspberry Pi.", timestamp: "12:53", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "m9", sender: "Alice", text: "By the way, here is the group invite for the core devs.", timestamp: "12:55", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "m10", sender: "Alice", text: "", timestamp: "12:55", is-outgoing: false, is-system: false, is-invite: true, invite-topic: "devs", invite-name: "Core Devs", invite-key: "xyz123", is-invite-joined: false, status: "read" }
            ];
        } else if chat.id == "2" {
            root.active-messages = [
                { id: "g1", sender: "Alice", text: "Has anyone benchmarked the Iroh broadcast yet?", timestamp: "09:00", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "g2", sender: "Bob", text: "I'm seeing 20% faster propagation on ARM64.", timestamp: "09:15", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "g3", sender: "System", text: "Satoshi joined the group via direct link.", timestamp: "10:00", is-outgoing: false, is-system: true, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "" },
                { id: "g4", sender: "Satoshi", text: "Hello everyone. The network looks stable.", timestamp: "10:05", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "g5", sender: "Shedrack G.", text: "Welcome! Yes, we deployed the new relay fallback.", timestamp: "10:07", is-outgoing: true, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "delivered" },
                { id: "g6", sender: "Alice", text: "We should probably release v0.9.0 this week.", timestamp: "10:10", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "g7", sender: "Bob", text: "I agree. The UI is looking incredibly polished now.", timestamp: "10:12", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" },
                { id: "g8", sender: "Shedrack G.", text: "Thanks guys! I've been refining the Slack-like bubble feel and safe-area logic.", timestamp: "10:15", is-outgoing: true, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "delivered" },
                { id: "g9", sender: "System", text: "Charlie changed the group avatar.", timestamp: "10:18", is-outgoing: false, is-system: true, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "" },
                { id: "g10", sender: "Charlie", text: "Let's test the group broadcast.", timestamp: "10:20", is-outgoing: false, is-system: false, is-invite: false, invite-topic: "", invite-name: "", invite-key: "", is-invite-joined: false, status: "read" }
            ];
        } else if chat.id == "4" {
            root.active-messages = [
                {
                    id: "c1",
                    sender: "Charlie",
                    text: "I'm connecting via relay node 42. It works smoothly!",
                    timestamp: "Mon",
                    is-outgoing: false,
                    is-system: false,
                    is-invite: false,
                    invite-topic: "",
                    invite-name: "",
                    invite-key: "",
                    is-invite-joined: false,
                    status: "read"
                }
            ];
        } else {
            root.active-messages = [
                {
                    id: "x1",
                    sender: chat.name,
                    text: "Wait, this is a new conversation context with " + chat.name,
                    timestamp: "Now",
                    is-outgoing: false,
                    is-system: false,
                    is-invite: false,
                    invite-topic: "",
                    invite-name: "",
                    invite-key: "",
                    is-invite-joined: false,
                    status: "read"
                }
            ];
        }

        root.current-screen = chat.is-group ? 2 : 1;
    }

    callback send-message(string);
    callback send-group-message(string);
    callback load-conversation(string, bool);
    callback open-contact-info();
    callback open-group-info();
    callback accept-group-invite(string, string, string);
    callback retry-queued();
    callback request-delete-conversation();
    callback confirm-modal-confirmed(string, string);
    callback edit-display-name();
    callback copy-node-id();
    callback change-password();
    callback open-debug-console();
    callback request-clear-history();
    callback request-reset-identity();

    // --- Safe Areas ---
    property <length> safe-area-top: root.safe-area-insets.top;
    property <length> safe-area-bottom: root.safe-area-insets.bottom;
    property <length> kb-height: root.virtual-keyboard-size.height;

    // --- Application Root Shell ---
    Rectangle {
        background: AppTheme.surface-primary;

        // 1. SIDEBAR (Absolute positioning to break layout loops)
        Rectangle {
            x: 0;
            y: 0;
            width: root.concrete-sidebar-width;
            height: 100%;
            clip: true;
            visible: root.concrete-sidebar-width > 0;
            background: AppTheme.surface-secondary;

            VerticalLayout {
                spacing: 0;
                if root.device == DeviceType.desktop: VerticalLayout {
                    spacing: 0;
                    ChatListScreen {
                        vertical-stretch: 1;
                        is-desktop: true;
                        chats: root.chats;
                        direct-peers: root.direct-peers;
                        relay-peers: root.relay-peers;
                        is-offline: root.is-offline;
                        active-id: root.active-conversation.id;
                        open-chat(chat) => {
                            root.open-chat(chat);
                        }
                        add-contact => {
                            root.add-contact();
                        }
                        open-contacts => {
                            root.open-contacts();
                        }
                        open-settings => {
                            root.open-settings();
                        }
                    }

                    NavBar {
                        height: 72px;
                        active-screen: root.current-screen;
                        nav-to(id) => {
                            root.current-screen = id;
                        }
                    }
                }

                if root.device == DeviceType.tablet: HorizontalLayout {
                    spacing: 0;
                    vertical-stretch: 1;
                    NavBar {
                        width: 90px;
                        active-screen: root.current-screen;
                        is-vertical: true;
                        nav-to(id) => {
                            root.current-screen = id;
                        }
                        add-contact-clicked => {
                            root.add-contact();
                        }
                    }

                    ChatListScreen {
                        horizontal-stretch: 1;
                        is-desktop: true;
                        compact: true;
                        chats: root.chats;
                        direct-peers: root.direct-peers;
                        relay-peers: root.relay-peers;
                        is-offline: root.is-offline;
                        active-id: root.active-conversation.id;
                        open-chat(chat) => {
                            root.open-chat(chat);
                        }
                        add-contact => {
                            root.add-contact();
                        }
                        open-contacts => {
                            root.open-contacts();
                        }
                        open-settings => {
                            root.open-settings();
                        }
                    }
                }
            }

            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                background: AppTheme.divider;
            }
        }

        // 2. PRIMARY CONTENT AREA (Absolute positioning to break layout loops)
        Rectangle {
            x: root.concrete-sidebar-width;
            y: 0;
            width: parent.width - root.concrete-sidebar-width;
            height: 100%;

            VerticalLayout {
                spacing: 0;

                // Safe area spacer (Mobile only)
                if !root.is-desktop: Rectangle {
                    height: root.safe-area-top;
                    background: AppTheme.surface-secondary;
                    vertical-stretch: 0;
                }
                
                // Screen Content
                Rectangle {
                    vertical-stretch: 1;
                    clip: true;

                    if root.device == DeviceType.mobile && root.current-screen == 0: ChatListScreen {
                        is-desktop: false;
                        chats: root.chats;
                        direct-peers: root.direct-peers;
                        relay-peers: root.relay-peers;
                        is-offline: root.is-offline;
                        active-id: root.active-conversation.id;
                        open-chat(chat) => {
                            root.open-chat(chat);
                        }
                        add-contact => {
                            root.add-contact();
                        }
                        open-contacts => {
                            root.open-contacts();
                        }
                        open-settings => {
                            root.open-settings();
                        }
                    }

                    if root.is-desktop && root.current-screen == 0: VerticalLayout {
                        alignment: center;
                        spacing: AppTheme.space.md;
                        padding: AppTheme.space.xl;
                        Text {
                            text: "💬";
                            font-size: 56px;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Select a conversation";
                            font-size: 20px;
                            font-weight: 700;
                            color: AppTheme.text-primary;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Choose a chat from the left panel to begin.";
                            font-size: 14px;
                            color: AppTheme.text-secondary;
                            horizontal-alignment: center;
                        }
                    }

                    if root.current-screen == 1 || root.current-screen == 2: ChatViewScreen {
                        is-desktop: root.is-desktop;
                        peer-name: root.active-conversation.title;
                        peer-initials: root.active-conversation.initials;
                        peer-node-id: root.active-conversation.id;
                        connection-mode: root.active-conversation.kind;
                        is-online: root.active-conversation.is-online || root.active-conversation.kind == "group";
                        is-relay: root.active-conversation.is-relay;
                        is-verified: root.active-conversation.is-verified || root.active-conversation.kind == "group";
                        connection-stage: root.active-conversation.connection-stage;
                        messages: root.active-messages;
                        virtual-keyboard-height: root.kb-height;
                        go-back => {
                            root.current-screen = root.active-conversation.return-screen;
                        }
                        send-message(msg) => {
                            if root.active-conversation.kind == "group" {
                                root.send-group-message(msg);
                            } else {
                                root.send-message(msg);
                            }
                        }
                        open-contact-info => {
                            if root.active-conversation.kind == "group" {
                                root.open-group-info();
                            } else {
                                root.open-contact-info();
                            }
                        }
                        retry-queued => {
                            root.retry-queued();
                        }
                        request-delete-conversation => {
                            root.request-delete-conversation();
                        }
                    }

                    if root.current-screen == 3: SettingsScreen {
                        display-name: root.display-name;
                        initials: root.initials;
                        endpoint-ticket: root.endpoint-ticket;
                        back-clicked => {
                            root.current-screen = 0;
                        }
                        edit-display-name => {
                            root.edit-display-name();
                        }
                        copy-node-id => {
                            root.copy-node-id();
                        }
                        change-password => {
                            root.change-password();
                        }
                        open-debug-console => {
                            root.open-debug-console();
                        }
                        request-clear-history => {
                            root.request-clear-history();
                        }
                        request-reset-identity => {
                            root.request-reset-identity();
                        }
                    }
                    if root.current-screen == 4: ContactsScreen {
                        is-desktop: root.is-desktop;
                        contacts: root.contacts;
                        back-clicked => {
                            root.current-screen = 0;
                        }
                        add-contact => {
                            root.add-contact();
                        }
                        new-group => {
                            root.open-settings();
                        }
                        open-contact(contact) => {
                            root.load-conversation(contact.id, false);
                            root.active-conversation = {
                                kind: "direct",
                                id: contact.id,
                                title: contact.name,
                                initials: contact.initials,
                                is-online: contact.is-online,
                                is-relay: contact.is-relay,
                                is-verified: contact.is-verified,
                                is-session-ready: false,
                                connection-stage: "",
                                return-screen: 4,
                            };
                            root.current-screen = 1;
                        }
                    }
                }

                // Systemic Keyboard Spacer (Mobile only)
                // Ensures all screens (Settings, Contacts, etc.) stay above the keyboard.
                if root.device == DeviceType.mobile && root.kb-height > 0px: Rectangle {
                    height: root.kb-height;
                    vertical-stretch: 0;
                    animate height { duration: AppTheme.dur-short; }
                }

                // Mobile Navigation Bar
                if root.device == DeviceType.mobile && root.kb-height < 20px && (root.current-screen == 0 || root.current-screen == 3 || root.current-screen == 4): NavBar {
                    height: 72px + root.safe-area-bottom;
                    vertical-stretch: 0;
                    active-screen: root.current-screen;
                    nav-to(id) => {
                        root.current-screen = id;
                    }
                    safe-area-bottom: root.safe-area-bottom;
                }
            }
        }

        // 3. GLOBAL MODALS
        if root.confirm-modal-show: ConfirmModal {
            title: root.confirm-modal-title;
            subtitle: root.confirm-modal-subtitle;
            action-slug: root.confirm-modal-slug;
            error-msg: root.confirm-modal-err;
            is-checked <=> root.confirm-modal-checked;
            cancel => {
                root.confirm-modal-show = false;
            }
            confirm(pin) => {
                root.confirm-modal-confirmed(root.confirm-modal-slug, pin);
            }
        }
    }
}

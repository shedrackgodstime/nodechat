// NodeChat New — Root Application Shell
// ---------------------------------------------------------
// This file serves as the primary layout controller.
// It manages:
//   - Responsive breakpoints (Mobile vs Tablet vs Desktop)
//   - Safe areas for mobile/keyboard
//   - Navigation state (Routing)
//   - Theme token application
// ---------------------------------------------------------

import { AppTheme } from "./theme.slint";
import { ChatPreview, ContactData, GroupData, AppInfo, GroupCandidateItem } from "./components/row_data.slint";
import { ChatListScreen } from "./screens/chat_list.slint";
import { ChatViewScreen, MessageData } from "./screens/chat_view.slint";
import { ContactsScreen } from "./screens/contacts_screen.slint";
import { SettingsScreen } from "./screens/settings_screen.slint";
import { AddScreen } from "./screens/add_screen.slint";
import { AboutScreen } from "./screens/about_screen.slint";
import { InfoScreen } from "./screens/info_screen.slint";
import { EditNameScreen } from "./screens/edit_name.slint";
import { PasswordScreen } from "./screens/password_screen.slint";
import { ConfirmModal } from "./components/confirm_modal.slint";
import { NavBar } from "./components/nav_bar.slint";
import { CreateGroupScreen } from "./screens/create_group.slint";
import { SelectContactsScreen } from "./screens/select_contacts.slint";

export { ChatPreview, MessageData }

export enum DeviceType { mobile, tablet, desktop }

export struct ConversationContext {
    kind: string,           // "direct" | "group"
    id: string,
    title: string,
    initials: string,
    is-online: bool,
    is-relay: bool,
    is-verified: bool,
    is-session-ready: bool,
    connection-stage: string,
    return-screen: int,
}

export component AppWindow inherits Window {
    title: root.app-info.name;

    // --- Window Constraints ---
    min-width: 0px; 
    min-height: 0px; 
    preferred-width: 1080px;
    preferred-height: 800px;
    background: AppTheme.surface-primary;

    // --- Shell State ---
    // Breakpoints: Mobile (< 700px), Tablet (700px - 1000px), Desktop (> 1000px)
    out property <DeviceType> device: root.width > 1000px ? DeviceType.desktop : root.width > 700px ? DeviceType.tablet : DeviceType.mobile;
    out property <bool> is-desktop: root.device == DeviceType.desktop || root.device == DeviceType.tablet;
    
    // Decoupled width property to prevent binding loops in layout negotiation
    property <length> concrete-sidebar-width: (root.device == DeviceType.desktop) ? 320px : (root.device == DeviceType.tablet ? 170px : 0px);
    in-out property <int> current-screen: 0;
    in property <bool> has-password: false;
    in property <bool> has-identity: false;
    in property <bool> is-locked: false;

    // --- App Data (Driven by Rust) ---
    in property <string> display-name: "";
    in property <string> initials: "";
    in property <string> endpoint-ticket: "";
    in property <[ChatPreview]> chats: [];
    in property <[ContactData]> contacts: [];
    in-out property <[GroupData]> groups: [];
    in-out property <GroupData> active-group: {
        id: "",
        name: "",
        initials: "",
        topic: "",
        secret-key: "",
        member-count: 0
    };

    // --- Temporary State for Flows ---
    property <string> temp-group-name: "";
    property <string> temp-group-desc: "";
    property <int> group-selection-return: 10;

    in property <AppInfo> app-info: {
        name: "",
        version: "",
        version-type: "",
        description: "",
        website: "",
        repo: ""
    };

    in property <[MessageData]> active-messages: [];
    in-out property <ConversationContext> active-conversation: {
        kind: "direct",
        id: "",
        title: "",
        initials: "",
        is-online: false,
        is-relay: false,
        is-verified: false,
        is-session-ready: false,
        connection-stage: "",
        return-screen: 0,
    };
    in property <int> direct-peers: 0;
    in property <int> relay-peers: 0;
    in property <bool> is-offline: false;
    in property <[GroupCandidateItem]> group-candidates: [];

    // --- Modal State ---
    in-out property <bool> confirm-modal-show: false;
    in-out property <string> confirm-modal-title: "Confirm Action";
    in-out property <string> confirm-modal-subtitle: "Are you sure you want to do this?";
    in-out property <string> confirm-modal-slug: "";
    in-out property <string> confirm-modal-err: "";
    in-out property <bool> confirm-modal-checked: false;

    // --- Callbacks ---
    callback open-settings;
    callback open-contacts;
    callback add-contact;
    callback open-chat(ChatPreview);
    callback add-peer(string);

    open-settings => {
        root.current-screen = 3;
    }
    open-contacts => {
        root.current-screen = 4;
    }
    add-contact => {
        root.current-screen = 5;
    }
    open-chat(chat) => {
        // Rust handles full state population via Command::LoadConversation
        root.load-conversation(chat.id, chat.is-group);
        root.current-screen = chat.is-group ? 2 : 1;
    }

    callback send-message(string);
    callback send-group-message(string);
    callback load-conversation(string, bool);
    callback open-contact-info();
    callback open-group-info();
    callback accept-group-invite(string, string, string);
    callback retry-queued();
    callback request-delete-conversation();
    callback confirm-modal-confirmed(string, string);
    callback edit-display-name();
    callback confirm-name-change(string);
    callback toggle-verify(string, bool);
    callback toggle-group-candidate(string);
    callback create-group(string, string);
    callback copy-node-id();
    callback change-password();
    callback submit-password(string, string);
    callback open-debug-console();
    callback request-clear-history();
    callback request-reset-identity();
    callback open-url(string);
    callback copy-to-clipboard(string);

    // --- Clipboard Integration ---
    in-out property <string> clipboard-buffer: "";
    public function do-copy() {
        clipboard-input.select-all();
        clipboard-input.copy();
    }
    clipboard-input := TextInput {
        text: root.clipboard-buffer;
        visible: false;
    }

    // --- Safe Areas ---
    property <length> safe-area-top: root.safe-area-insets.top;
    property <length> safe-area-bottom: root.safe-area-insets.bottom;
    property <length> kb-height: root.virtual-keyboard-size.height;

    // --- Application Root Shell ---
    HorizontalLayout {
        width: 100%;
        height: 100%;
        spacing: 0;

        // 1. SIDEBAR (Desktop & Tablet Rail)
        if root.concrete-sidebar-width > 0px : Rectangle {
            width: root.concrete-sidebar-width;
            height: 100%;
            clip: true;
            background: AppTheme.surface-secondary;

            VerticalLayout {
                spacing: 0;
                
                // Desktop Mode — NavBar pinned to bottom via absolute positioning
                if root.device == DeviceType.desktop : Rectangle {
                    vertical-stretch: 1;

                    // Chat list fills everything above the nav bar
                    ChatListScreen {
                        x: 0; y: 0;
                        width: parent.width;
                        height: parent.height - 72px;
                        is-desktop: true;
                        chats: root.chats;
                        direct-peers: root.direct-peers;
                        relay-peers: root.relay-peers;
                        is-offline: root.is-offline;
                        active-id: root.active-conversation.id;
                        open-chat(chat) => { root.open-chat(chat); }
                        add-contact => { root.open-contacts(); }
                        open-contacts => { root.open-contacts(); }
                        open-settings => { root.open-settings(); }
                    }

                    // NavBar always pinned to the very bottom
                    NavBar {
                        x: 0;
                        y: parent.height - 72px;
                        width: parent.width;
                        height: 72px;
                        active-screen: root.current-screen;
                        nav-to(id) => { root.current-screen = id; }
                    }
                }

                // Tablet Mode
                if root.device == DeviceType.tablet : HorizontalLayout {
                    spacing: 0;
                    NavBar {
                        width: 90px;
                        active-screen: root.current-screen;
                        is-vertical: true;
                        nav-to(id) => { root.current-screen = id; }
                        add-contact-clicked => { root.add-contact(); }
                    }

                    ChatListScreen {
                        horizontal-stretch: 1;
                        is-desktop: true;
                        compact: true;
                        chats: root.chats;
                        direct-peers: root.direct-peers;
                        relay-peers: root.relay-peers;
                        is-offline: root.is-offline;
                        active-id: root.active-conversation.id;
                        open-chat(chat) => { root.open-chat(chat); }
                        add-contact => { root.add-contact(); }
                        open-contacts => { root.open-contacts(); }
                        open-settings => { root.open-settings(); }
                    }
                }
            }

            // Divider
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                background: AppTheme.divider;
            }
        }

        // 2. PRIMARY CONTENT AREA
        Rectangle {
            horizontal-stretch: 1;
            height: 100%;
            background: AppTheme.surface-primary;
            clip: true;

            VerticalLayout {
                spacing: 0;

                // Safe area spacer (Mobile only)
                if root.device == DeviceType.mobile : Rectangle {
                    height: root.safe-area-top;
                    background: AppTheme.surface-secondary;
                    vertical-stretch: 0;
                }

                // Screen Content
                Rectangle {
                    vertical-stretch: 1;
                    clip: true;

                    if root.device == DeviceType.mobile && root.current-screen == 0: ChatListScreen {
                        width: 100%; height: 100%;
                        is-desktop: false;
                        chats: root.chats;
                        direct-peers: root.direct-peers;
                        relay-peers: root.relay-peers;
                        is-offline: root.is-offline;
                        active-id: root.active-conversation.id;
                        open-chat(chat) => { root.open-chat(chat); }
                        add-contact => { root.open-contacts(); }
                        open-contacts => { root.open-contacts(); }
                        open-settings => { root.open-settings(); }
                    }

                    if root.is-desktop && root.current-screen == 0: VerticalLayout {
                        width: 100%; height: 100%;
                        alignment: center;
                        spacing: AppTheme.sp-lg;
                        padding: AppTheme.sp-xl;
                        Text { text: "💬"; font-size: 56px; horizontal-alignment: center; }
                        Text { text: "Select a conversation"; font-size: 20px; font-weight: 700; color: AppTheme.text-primary; horizontal-alignment: center; }
                        Text { text: "Choose a chat from the left panel to begin."; font-size: 14px; color: AppTheme.text-secondary; horizontal-alignment: center; }
                    }

                    if root.current-screen == 1 || root.current-screen == 2: ChatViewScreen {
                        width: 100%; height: 100%;
                        is-desktop: root.is-desktop;
                        peer-name: root.active-conversation.title;
                        peer-initials: root.active-conversation.initials;
                        peer-node-id: root.active-conversation.id;
                        connection-mode: root.active-conversation.kind;
                        is-online: root.active-conversation.is-online || root.active-conversation.kind == "group";
                        is-relay: root.active-conversation.is-relay;
                        is-verified: root.active-conversation.is-verified || root.active-conversation.kind == "group";
                        connection-stage: root.active-conversation.connection-stage;
                        messages: root.active-messages;
                        virtual-keyboard-height: root.kb-height;
                        go-back => { root.current-screen = root.active-conversation.return-screen; }
                        send-message(msg) => {
                            if root.active-conversation.kind == "group" { root.send-group-message(msg); }
                            else { root.send-message(msg); }
                        }
                        open-contact-info => {
                             root.current-screen = 9;
                        }
                        retry-queued => { root.retry-queued(); }
                        request-delete-conversation => { root.request-delete-conversation(); }
                    }

                    if root.current-screen == 3: SettingsScreen {
                        width: 100%; height: 100%;
                        is-desktop: root.is-desktop;
                        display-name: root.display-name;
                        initials: root.initials;
                        endpoint-ticket: root.endpoint-ticket;
                        app-info: root.app-info;

                        back-clicked => { root.current-screen = 0; }
                        edit-display-name => { root.current-screen = 7; }
                        copy-node-id => { root.copy-node-id(); }
                        change-password => { root.current-screen = 8; }
                        open-about => { root.current-screen = 6; } 
                        request-clear-history => { 
                            root.confirm-modal-title = "Clear Message History";
                            root.confirm-modal-subtitle = "Are you sure you want to permanently delete all localized messages and media?";
                            root.confirm-modal-slug = "clear-history";
                            root.confirm-modal-show = true;
                        }
                        request-reset-identity => { 
                            root.confirm-modal-title = "Reset P2P Identity";
                            root.confirm-modal-subtitle = "Your private keys will be destroyed and you will permanently lose access to your network.";
                            root.confirm-modal-slug = root.has-password ? "delete-identity" : "reset-identity";
                            root.confirm-modal-show = true;
                        }
                    }

                    if root.current-screen == 4: ContactsScreen {
                        width: 100%; height: 100%;
                        is-desktop: root.is-desktop;
                        contacts: root.contacts;
                        groups: root.groups;
                        back-clicked => { root.current-screen = 0; }
                        add-contact => { root.current-screen = 5; }
                        new-group => { root.current-screen = 10; }
                        open-contact(contact) => {
                            root.active-conversation = {
                                kind: "direct",
                                id: contact.id,
                                title: contact.name,
                                initials: contact.initials,
                                is-online: contact.is-online,
                                is-relay: contact.is-relay,
                                is-verified: contact.is-verified,
                                is-session-ready: contact.is-session-ready,
                                connection-stage: "",
                                return-screen: 4,
                            };
                            root.current-screen = 9;
                        }
                        open-group(group) => {
                            root.active-group = group;
                            root.active-conversation = {
                                kind: "group",
                                id: group.id,
                                title: group.name,
                                initials: group.initials,
                                is-online: true,
                                is-relay: false,
                                is-verified: true,
                                is-session-ready: true,
                                connection-stage: "",
                                return-screen: 4,
                            };
                            root.current-screen = 9;
                        }
                    }

                    if root.current-screen == 5: AddScreen {
                        width: 100%; height: 100%;
                        is-desktop: root.is-desktop;
                        back-clicked => { root.current-screen = 4; }
                        add-ticket(t) => { 
                            root.add-peer(t);
                            root.current-screen = 4; 
                        }
                    }

                    if root.current-screen == 6: AboutScreen {
                        width: 100%; height: 100%;
                        is-desktop: root.is-desktop;
                        app-info: root.app-info;
                        back-clicked => { root.current-screen = 3; }
                        open-url(url) => { root.open-url(url); }
                        copy-logs(logs) => { root.copy-to-clipboard(logs); }
                    }

                    if root.current-screen == 7: EditNameScreen {
                        is-desktop: root.is-desktop;
                        display-name: root.display-name;
                        back-clicked => { root.current-screen = 3; }
                        confirm-name(name) => { root.confirm-name-change(name); root.current-screen = 3; }
                    }

                    if root.current-screen == 8: PasswordScreen {
                        is-desktop: root.is-desktop;
                        has-password: root.has-password;
                        app-info: root.app-info;
                        back-clicked => { root.current-screen = 3; }
                        confirm-password(cur, new) => { root.submit-password(cur, new); root.current-screen = 3; }
                        remove-password(cur) => { root.submit-password(cur, ""); root.current-screen = 3; }
                    }

                    if root.current-screen == 9: InfoScreen {
                        is-desktop: root.is-desktop;
                        is-group: root.active-conversation.kind == "group";
                        contact: {
                            id: root.active-conversation.id,
                            name: root.active-conversation.title,
                            initials: root.active-conversation.initials,
                            node-id: "node_" + root.active-conversation.id + "_p2p...",
                            is-online: root.active-conversation.is-online,
                            is-relay: root.active-conversation.is-relay,
                            is-verified: root.active-conversation.is-verified,
                        };
                        group: root.active-group;
                        back-clicked => { root.current-screen = root.active-conversation.kind == "group" ? 2 : 1; }
                        chat-clicked => { 
                            root.load-conversation(root.active-conversation.id, root.active-conversation.kind == "group");
                            root.current-screen = root.active-conversation.kind == "group" ? 2 : 1; 
                        }
                        copy-text(txt) => { root.copy-to-clipboard(txt); }
                        request-clear-history => { 
                             root.confirm-modal-title = "Clear History";
                             root.confirm-modal-subtitle = "Delete all messages locally?";
                             root.confirm-modal-slug = "clear-history";
                             root.confirm-modal-show = true;
                        }
                        request-delete => {
                             root.confirm-modal-title = "Delete Conversation";
                             root.confirm-modal-subtitle = "Remove this conversation permanently?";
                             root.confirm-modal-slug = "delete-chat";
                             root.confirm-modal-show = true;
                        }
                        add-members => {
                            root.temp-group-name = root.active-conversation.title;
                            root.group-selection-return = 9;
                            root.current-screen = 11;
                        }
                        toggle-verify(v) => { root.toggle-verify(root.active-conversation.id, v); }
                    }

                    if root.current-screen == 10: CreateGroupScreen {
                        width: 100%; height: 100%;
                        is-desktop: root.is-desktop;
                        app-info: root.app-info;
                        back-clicked => { root.current-screen = 4; }
                        create-group(name, desc) => {
                            root.temp-group-name = name;
                            root.temp-group-desc = desc;
                            root.group-selection-return = 10;
                            root.current-screen = 11; // Next: Select Members
                        }
                    }

                    if root.current-screen == 11: SelectContactsScreen {
                        width: 100%; height: 100%;
                        is-desktop: root.is-desktop;
                        group-name: root.temp-group-name;
                        return-screen: root.group-selection-return;
                        contacts: root.group-candidates;
                        back-clicked => { root.current-screen = root.group-selection-return; }
                        toggled(id) => { root.toggle-group-candidate(id); }
                        create-clicked() => {
                             root.create-group(root.temp-group-name, root.temp-group-desc);
                             root.current-screen = 0; 
                        }
                    }
                }

                // Keyboard Spacer (Mobile only)
                if root.device == DeviceType.mobile && root.kb-height > 0px: Rectangle {
                    height: root.kb-height;
                    vertical-stretch: 0;
                }

                // Mobile Navigation Bar
                if root.device == DeviceType.mobile && root.kb-height < 20px && (root.current-screen == 0 || root.current-screen == 3 || root.current-screen == 4) : NavBar {
                    height: 72px + root.safe-area-bottom;
                    vertical-stretch: 0;
                    active-screen: root.current-screen;
                    nav-to(id) => { root.current-screen = id; }
                }
            } // Ends VerticalLayout
        } // Ends Rectangle
    } // Ends HorizontalLayout

    // 3. GLOBAL MODALS
    if root.confirm-modal-show: ConfirmModal {
        title: root.confirm-modal-title;
        subtitle: root.confirm-modal-subtitle;
        action-slug: root.confirm-modal-slug;
        error-msg: root.confirm-modal-err;
        is-checked <=> root.confirm-modal-checked;
        cancel => {
            root.confirm-modal-show = false;
        }
        confirm(pin) => {
            root.confirm-modal-confirmed(root.confirm-modal-slug, pin);
        }
    }
}
